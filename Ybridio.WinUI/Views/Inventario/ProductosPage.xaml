<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Inventario.ProductosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:dto="using:Ybridio.Application.DTOs.Catalogos"
      mc:Ignorable="d"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CommandBar -->
        <CommandBar Grid.Row="0"
                    DefaultLabelPosition="Right"
                    HorizontalAlignment="Left">
            <AppBarButton Icon="Add" Label="Nuevo"
                          Command="{x:Bind ViewModel.NuevoCommand}"/>
            <AppBarButton Icon="Edit" Label="Editar"
                          Command="{x:Bind ViewModel.EditarCommand}"/>
            <AppBarButton Icon="Copy" Label="Clonar"
                          Command="{x:Bind ViewModel.ClonarCommand}"/>
            <AppBarButton Icon="Switch" Label="Comparar"
                          Command="{x:Bind ViewModel.CompararCommand}"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Sync" Label="Activar/Desactivar"
                          Command="{x:Bind ViewModel.CambiarActivoCommand}"/>
            <AppBarButton Icon="Delete" Label="Eliminar"
                          Command="{x:Bind ViewModel.EliminarCommand}"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Refresh" Label="Actualizar"
                          Command="{x:Bind ViewModel.RefrescarCommand}"/>
        </CommandBar>

        <!-- Barra de búsqueda -->
        <Grid Grid.Row="1" Padding="8,4" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     PlaceholderText="Buscar por código, código de barras o nombre..."
                     Text="{x:Bind ViewModel.Busqueda, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <CheckBox Grid.Column="1"
                      Content="Solo activos"
                      IsChecked="{x:Bind ViewModel.SoloActivos, Mode=TwoWay}"/>
        </Grid>

        <!-- Lista -->
        <Grid Grid.Row="2">
            <ListView x:Name="ListaProductos"
                      ItemsSource="{x:Bind ViewModel.Productos, Mode=OneWay}"
                      SelectionMode="Extended"
                      SelectionChanged="ListaProductos_SelectionChanged"
                      DoubleTapped="ListaProductos_DoubleTapped">

                <ListView.Header>
                    <Grid Padding="12,6"
                          Background="{ThemeResource LayerFillColorDefaultBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="55"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Código" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Cód. Barras" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="Nombre" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="Categoría" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="4" Text="Unidad" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="5" Text="Precio" FontWeight="SemiBold" TextAlignment="Right"/>
                        <TextBlock Grid.Column="6" Text="Costo" FontWeight="SemiBold" TextAlignment="Right"/>
                        <TextBlock Grid.Column="7" Text="Impuesto" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="8" Text="Activo" FontWeight="SemiBold" TextAlignment="Center"/>
                    </Grid>
                </ListView.Header>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="12,2"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="dto:ProductoDto">
                        <Grid ColumnSpacing="4" Height="32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="55"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{x:Bind Codigo}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind CodigoBarras}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{x:Bind Nombre}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3"
                                       Text="{x:Bind CategoriaNombre}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="4"
                                       Text="{x:Bind UnidadMedidaAbreviatura}"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="5"
                                       Text="{x:Bind Precio}"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="6"
                                       Text="{x:Bind Costo}"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="7"
                                       Text="{x:Bind TipoImpuestoNombre}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <CheckBox Grid.Column="8"
                                      IsChecked="{x:Bind Activo}"
                                      IsEnabled="False"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Width="48" Height="48"/>
        </Grid>

        <!-- StatusBar -->
        <Border Grid.Row="3"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                Padding="12,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12">
                        <Run Text="{x:Bind ViewModel.Productos.Count, Mode=OneWay}"/>
                        <Run Text="producto(s)"/>
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="Red"
                               Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>
                    <TextBlock VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                               Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"/>
                </StackPanel>
                <ProgressRing Grid.Column="1"
                              IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                              Width="16" Height="16"/>
            </Grid>
        </Border>
    </Grid>
</Page>
