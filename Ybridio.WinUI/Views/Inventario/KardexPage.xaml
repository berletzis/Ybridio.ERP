<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Inventario.KardexPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:dto="using:Ybridio.Application.DTOs.Inventario"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left" Margin="8,0,0,0">
            <AppBarButton Label="Actualizar" Command="{x:Bind ViewModel.LoadCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE72C;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Limpiar filtros" Command="{x:Bind ViewModel.LimpiarFiltrosCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE894;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Abrir documento" Command="{x:Bind ViewModel.AbrirDocumentoOrigenCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8A7;"/></AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <!-- Filtros -->
        <Grid Grid.Row="1" Padding="8,8,20,4" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <AutoSuggestBox Grid.Column="0"
                            PlaceholderText="Buscar por producto, código o referencia..."
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.BusquedaProducto, Mode=TwoWay}"/>

            <DatePicker Grid.Column="1"
                        Header="Desde"
                        Date="{x:Bind ViewModel.FiltroDesde, Mode=TwoWay}"
                        MinWidth="180"/>

            <DatePicker Grid.Column="2"
                        Header="Hasta"
                        Date="{x:Bind ViewModel.FiltroHasta, Mode=TwoWay}"
                        MinWidth="180"/>
        </Grid>

        <!-- Grid de kardex -->
        <Border Grid.Row="2" Margin="20,4,20,0" Background="White" BorderBrush="#E5E5E5" BorderThickness="1">
            <Grid>
                <ListView Style="{StaticResource OutlookDataGridStyle}"
                          ItemsSource="{x:Bind ViewModel.Movimientos, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.LineaSeleccionada, Mode=TwoWay}">
                    <ListView.Header>
                        <Border Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                            <Grid Padding="{StaticResource ErpHeaderPadding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1"  Text="Fecha"        Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="2"  Text="Folio/Ref."   Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="3"  Text="Producto"     Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="4"  Text="Movimiento"   Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="5"  Text="Almacén"      Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="6"  Text="Entrada"      Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                <TextBlock Grid.Column="7"  Text="Salida"       Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                <TextBlock Grid.Column="8"  Text="Saldo"        Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                <TextBlock Grid.Column="9"  Text="Costo"        Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                <TextBlock Grid.Column="10" Text="Observaciones" Style="{StaticResource ErpGridHeaderTextStyle}"/>
                            </Grid>
                        </Border>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="dto:KardexLineaDto">
                            <Grid Height="{StaticResource ErpRowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Indicador de tipo: barra lateral estática - el color se ve en las columnas Entrada/Salida -->
                                <Border Grid.Column="0" Width="4" HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        Background="#3399CC" Opacity="0.5"/>

                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind Fecha}"
                                           Style="{StaticResource ErpCellSecondaryStyle}"
                                           VerticalAlignment="Center"
                                           FontSize="11"/>
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind Folio}"
                                           Style="{StaticResource ErpCellPrimaryStyle}"
                                           VerticalAlignment="Center"
                                           FontFamily="Cascadia Code, Consolas, monospace"
                                           FontSize="12"/>
                                <StackPanel Grid.Column="3" Orientation="Vertical" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind ProductoNombre}"
                                               Style="{StaticResource ErpCellPrimaryStyle}"/>
                                    <TextBlock Text="{x:Bind ProductoCodigo}"
                                               Style="{StaticResource ErpCellSecondaryStyle}"
                                               FontSize="11"
                                               Opacity="0.65"/>
                                </StackPanel>
                                <TextBlock Grid.Column="4"
                                           Text="{x:Bind TipoMovimientoNombre}"
                                           Style="{StaticResource ErpCellSecondaryStyle}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5"
                                           Text="{x:Bind AlmacenNombre}"
                                           Style="{StaticResource ErpCellSecondaryStyle}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="6"
                                           Text="{x:Bind Entrada}"
                                           Style="{StaticResource ErpCellPrimaryStyle}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           Foreground="#22BB44"/>
                                <TextBlock Grid.Column="7"
                                           Text="{x:Bind Salida}"
                                           Style="{StaticResource ErpCellPrimaryStyle}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           Foreground="#DD3333"/>
                                <TextBlock Grid.Column="8"
                                           Text="{x:Bind SaldoAcumulado}"
                                           Style="{StaticResource ErpCellPrimaryStyle}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="9"
                                           Text="{x:Bind CostoUnitario}"
                                           Style="{StaticResource ErpCellSecondaryStyle}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"/>
                                <TextBlock Grid.Column="10"
                                           Text="{x:Bind Observaciones}"
                                           Style="{StaticResource ErpCellSecondaryStyle}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                              Width="48" Height="48"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <ContentControl ContentTemplate="{StaticResource ErpGridEmptyTemplate}"
                                Visibility="{x:Bind ViewModel.IsEmptyState, Mode=OneWay}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- StatusBar -->
        <Border Grid.Row="3" Style="{StaticResource ErpGridStatusBarStyle}" Margin="20,0,20,16">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource ErpGridStatusTextStyle}">
                    <Run Text="{x:Bind ViewModel.Movimientos.Count, Mode=OneWay}"/>
                    <Run Text="movimiento(s) · Kardex operacional"/>
                </TextBlock>
                <TextBlock Style="{StaticResource ErpGridErrorTextStyle}"
                           Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>
                <TextBlock Style="{StaticResource ErpGridSuccessTextStyle}"
                           Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
