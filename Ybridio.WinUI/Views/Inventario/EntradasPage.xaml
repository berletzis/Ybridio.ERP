<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Inventario.EntradasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
        Layout de 4 filas:
          Row 0 — CommandBar contextual (Nuevo, Editar, Eliminar | Importar, Exportar | Actualizar)
          Row 1 — Buscador + filtro temporal (default: 30 días)
          Row 2 — Grid Outlook con headers semánticos + EmptyTemplate
          Row 3 — StatusBar con contador de registros
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── CommandBar — contexto Inventario > Entradas ──────────────── -->
        <CommandBar Grid.Row="0"
                    DefaultLabelPosition="Right"
                    HorizontalAlignment="Left"
                    Margin="8,0,0,0">

            <!-- Grupo 1: acciones CRUD -->
            <AppBarButton Label="Nuevo" Command="{x:Bind ViewModel.NuevoCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE710;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Editar" Command="{x:Bind ViewModel.EditarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE70F;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Eliminar" Command="{x:Bind ViewModel.EliminarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE74D;"/></AppBarButton.Icon>
            </AppBarButton>

            <AppBarSeparator/>

            <!-- Grupo 2: transferencia de datos -->
            <AppBarButton Label="Importar" Command="{x:Bind ViewModel.ImportarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8B5;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Exportar" Command="{x:Bind ViewModel.ExportarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xEDE1;"/></AppBarButton.Icon>
            </AppBarButton>

            <AppBarSeparator/>

            <!-- Grupo 3: actualización -->
            <AppBarButton Label="Actualizar" Command="{x:Bind ViewModel.RefrescarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE72C;"/></AppBarButton.Icon>
            </AppBarButton>

        </CommandBar>

        <!-- ── Buscador + filtro temporal ───────────────────────────────── -->
        <Grid Grid.Row="1" Padding="8,8,20,4" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <AutoSuggestBox Grid.Column="0"
                            PlaceholderText="Buscar por referencia, almacén o tipo..."
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.Busqueda, Mode=TwoWay}"
                            VerticalAlignment="Center"/>

            <ComboBox Grid.Column="1"
                      MinWidth="130"
                      VerticalAlignment="Center"
                      SelectedItem="{x:Bind ViewModel.FiltroTemporal, Mode=TwoWay}"
                      ToolTipService.ToolTip="Filtro por período">
                <x:String>Hoy</x:String>
                <x:String>7 días</x:String>
                <x:String>30 días</x:String>
                <x:String>90 días</x:String>
                <x:String>6 meses</x:String>
                <x:String>1 año</x:String>
                <x:String>Todo</x:String>
            </ComboBox>
        </Grid>

        <!-- ── Grid Outlook ─────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Margin="20,4,20,0"
                Background="White"
                BorderBrush="#E5E5E5"
                BorderThickness="1">
            <Grid>
                <ListView x:Name="ListaEntradas"
                          Style="{StaticResource OutlookDataGridStyle}"
                          ItemsSource="{x:Bind ViewModel.Entradas, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.EntradaSeleccionada, Mode=TwoWay}">
                    <ListView.Header>
                        <Border Background="#FAFAFA"
                                BorderBrush="#E8E8E8"
                                BorderThickness="0,0,0,1">
                            <Grid Padding="{StaticResource ErpHeaderPadding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="Referencia" Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="2" Text="Fecha"      Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="3" Text="Almacén"    Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="4" Text="Tipo"       Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="5" Text="Items"      Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="Estado"     Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ListView.Header>
                    <!-- DataTemplate pendiente: se implementa cuando MovimientoInventarioDto esté disponible -->
                </ListView>
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                              Width="48" Height="48"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <ContentControl ContentTemplate="{StaticResource ErpGridEmptyTemplate}"
                                Visibility="{x:Bind ViewModel.IsEmptyState, Mode=OneWay}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- ── StatusBar ──────────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Style="{StaticResource ErpGridStatusBarStyle}"
                Margin="20,0,20,16">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource ErpGridStatusTextStyle}">
                    <Run Text="{x:Bind ViewModel.Entradas.Count, Mode=OneWay}"/>
                    <Run Text="entrada(s)"/>
                </TextBlock>
                <TextBlock Style="{StaticResource ErpGridErrorTextStyle}"
                           Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>
                <TextBlock Style="{StaticResource ErpGridSuccessTextStyle}"
                           Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>
