<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ybridio.WinUI.Views.Inventario.InventarioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <TabView x:Name="InventarioTabs"
             TabWidthMode="Equal"
             IsAddTabButtonVisible="False"
             SelectionChanged="InventarioTabs_SelectionChanged">

        <!-- Existencias -->
        <TabViewItem x:Name="TabExistencias" Header="Existencias">
            <TabViewItem.IconSource>
                <FontIconSource Glyph="&#xE8F1;" />
            </TabViewItem.IconSource>
            <Frame x:Name="FrameExistencias" />
        </TabViewItem>

        <!-- Entradas -->
        <TabViewItem x:Name="TabEntradas" Header="Entradas">
            <TabViewItem.IconSource>
                <FontIconSource Glyph="&#xE8FA;" />
            </TabViewItem.IconSource>
            <Frame x:Name="FrameEntradas" />
        </TabViewItem>

        <!-- Salidas -->
        <TabViewItem x:Name="TabSalidas" Header="Salidas">
            <TabViewItem.IconSource>
                <FontIconSource Glyph="&#xE8FB;" />
            </TabViewItem.IconSource>
            <Frame x:Name="FrameSalidas" />
        </TabViewItem>

        <!-- Kardex -->
        <TabViewItem x:Name="TabKardex" Header="Kardex">
            <TabViewItem.IconSource>
                <FontIconSource Glyph="&#xE8D2;" />
            </TabViewItem.IconSource>
            <Frame x:Name="FrameKardex" />
        </TabViewItem>

        <!-- Conteo -->
        <TabViewItem x:Name="TabConteo" Header="Conteo">
            <TabViewItem.IconSource>
                <FontIconSource Glyph="&#xE8EF;" />
            </TabViewItem.IconSource>
            <Frame x:Name="FrameConteo" />
        </TabViewItem>

        <!-- Órdenes de Compra -->
        <TabViewItem x:Name="TabOrdenesCompra" Header="Órdenes de Compra">
            <TabViewItem.IconSource>
                <FontIconSource Glyph="&#xE8D0;" />
            </TabViewItem.IconSource>
            <Frame x:Name="FrameOrdenesCompra" />
        </TabViewItem>

        <!-- Productos -->
        <TabViewItem x:Name="TabProductos" Header="Productos">
            <TabViewItem.IconSource>
                <FontIconSource Glyph="&#xE8B9;" />
            </TabViewItem.IconSource>
            <Frame x:Name="FrameProductos" />
        </TabViewItem>

    </TabView>
</Page>