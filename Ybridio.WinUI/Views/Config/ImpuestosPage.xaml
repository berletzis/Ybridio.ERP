<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Config.ImpuestosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:dto="using:Ybridio.Application.DTOs.Catalogos"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
        Catálogo Fiscal Institucional — Commercial Tax Pattern
        Única fuente de verdad sobre impuestos en el ERP.
        Los ParametroGlobal fiscales (impuesto.default.producto) referencian el Id de este catálogo.
    -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CommandBar institucional -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left" Margin="8,0,0,0">
            <AppBarButton Label="Nuevo" Command="{x:Bind ViewModel.NuevoCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE710;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Editar" Command="{x:Bind ViewModel.EditarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE70F;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Eliminar" Command="{x:Bind ViewModel.EliminarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE74D;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Actualizar" Command="{x:Bind ViewModel.LoadCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE72C;"/></AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <!-- Buscador -->
        <Grid Grid.Row="1" Padding="8,8,20,4">
            <AutoSuggestBox PlaceholderText="Buscar impuesto por nombre o código..."
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.Busqueda, Mode=TwoWay}"/>
        </Grid>

        <!-- Grid Operational Standard v2 — Catálogo Fiscal -->
        <Border Grid.Row="2" Margin="20,4,20,0" Background="White" BorderBrush="#E5E5E5" BorderThickness="1">
            <Grid>
                <ListView Style="{StaticResource OutlookDataGridStyle}"
                          ItemsSource="{x:Bind ViewModel.Impuestos, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.ImpuestoSeleccionado, Mode=TwoWay}"
                          DoubleTapped="Lista_DoubleTapped">
                    <ListView.Header>
                        <Border Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                            <Grid Padding="{StaticResource ErpHeaderPadding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="Código"      Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="2" Text="Nombre"      Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="3" Text="Tipo"        Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="4" Text="Porcentaje"  Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Exento"      Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="Activo"      Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="dto:TipoImpuestoDto">
                            <Grid Height="{StaticResource ErpRowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>

                                <!-- Código -->
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind Codigo}"
                                           Style="{StaticResource ErpCellSecondaryStyle}"
                                           VerticalAlignment="Center"
                                           FontFamily="Cascadia Code, Consolas, monospace"
                                           FontSize="12"/>

                                <!-- Nombre -->
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind Nombre}"
                                           Style="{StaticResource ErpCellPrimaryStyle}"
                                           VerticalAlignment="Center"/>

                                <!-- Tipo Gravamen -->
                                <TextBlock Grid.Column="3"
                                           Text="{x:Bind GravamenNombre}"
                                           Style="{StaticResource ErpCellSecondaryStyle}"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                                <!-- Porcentaje -->
                                <TextBlock Grid.Column="4"
                                           Style="{StaticResource OgCellFinancialStyle}"
                                           VerticalAlignment="Center">
                                    <Run Text="{x:Bind Porcentaje}"/>
                                    <Run Text="%"/>
                                </TextBlock>

                                <!-- Es Exento -->
                                <CheckBox Grid.Column="5"
                                          IsChecked="{x:Bind EsExento}"
                                          IsEnabled="False"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>

                                <!-- Activo -->
                                <CheckBox Grid.Column="6"
                                          IsChecked="{x:Bind Activo}"
                                          IsEnabled="False"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                              Width="48" Height="48"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- StatusBar -->
        <Border Grid.Row="3" Style="{StaticResource ErpGridStatusBarStyle}" Margin="20,0,20,16">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource ErpGridStatusTextStyle}">
                    <Run Text="{x:Bind ViewModel.Impuestos.Count, Mode=OneWay}"/>
                    <Run Text="impuesto(s) en catálogo fiscal"/>
                </TextBlock>
                <TextBlock Style="{StaticResource ErpGridErrorTextStyle}"
                           Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>
                <TextBlock Style="{StaticResource ErpGridSuccessTextStyle}"
                           Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
