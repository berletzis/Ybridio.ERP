<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Config.AlmacenesTiendaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:dto="using:Ybridio.Application.DTOs.Inventario"
      xmlns:conv="using:Ybridio.WinUI.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter        x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: CommandBar -->
            <RowDefinition Height="Auto"/>  <!-- 1: Buscador -->
            <RowDefinition Height="*"/>     <!-- 2: Grid ListView -->
            <RowDefinition Height="Auto"/>  <!-- 3: Status bar -->
        </Grid.RowDefinitions>

        <!-- ── CommandBar ──────────────────────────────────────────────────────── -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left" Margin="8,0,0,0">
            <AppBarButton Label="Nuevo" Command="{x:Bind ViewModel.NuevoCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE710;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Editar" Command="{x:Bind ViewModel.EditarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE70F;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Marcar Principal" Command="{x:Bind ViewModel.MarcarPrincipalCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8E8;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Activar/Desactivar" Command="{x:Bind ViewModel.CambiarActivoCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8BD;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Eliminar" Command="{x:Bind ViewModel.EliminarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE74D;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Actualizar" Command="{x:Bind ViewModel.LoadCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE72C;"/></AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <!-- ── Buscador (filtro en tiempo real) ───────────────────────────────── -->
        <Grid Grid.Row="1" Padding="8,8,20,4">
            <AutoSuggestBox PlaceholderText="Buscar almacén por nombre o código..."
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.Busqueda, Mode=TwoWay}"/>
        </Grid>

        <!-- ── Grid Operational Standard v2 ─────────────────────────────────── -->
        <Border Grid.Row="2" Margin="20,4,20,0" Background="White" BorderBrush="#E5E5E5" BorderThickness="1">
            <Grid>
                <ListView x:Name="ListaAlmacenes"
                          Style="{StaticResource OutlookDataGridStyle}"
                          ItemsSource="{x:Bind ViewModel.Almacenes, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.AlmacenSeleccionado, Mode=TwoWay}"
                          SelectionChanged="ListaAlmacenes_SelectionChanged"
                          DoubleTapped="ListaAlmacenes_DoubleTapped">
                    <ListView.Header>
                        <Border Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                            <Grid Padding="{StaticResource ErpHeaderPadding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="Principal"   Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Código"      Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="3" Text="Nombre"      Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="4" Text="Descripción" Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="5" Text="Activo"      Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="dto:AlmacenDto">
                            <Grid Height="{StaticResource ErpRowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <!-- Principal — badge accent si true -->
                                <Border Grid.Column="1"
                                        CornerRadius="4" Padding="6,2"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        Visibility="{x:Bind EsPrincipal,
                                                     Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Principal" FontSize="11" FontWeight="SemiBold"
                                               Foreground="White"/>
                                </Border>

                                <!-- Código -->
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind Codigo}"
                                           Style="{StaticResource ErpCellSecondaryStyle}"
                                           VerticalAlignment="Center"
                                           FontFamily="Cascadia Code, Consolas, monospace"
                                           FontSize="12"/>

                                <!-- Nombre -->
                                <TextBlock Grid.Column="3"
                                           Text="{x:Bind Nombre}"
                                           Style="{StaticResource ErpCellPrimaryStyle}"
                                           VerticalAlignment="Center"/>

                                <!-- Descripción -->
                                <TextBlock Grid.Column="4"
                                           Text="{x:Bind Descripcion}"
                                           Style="{StaticResource ErpCellSecondaryStyle}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- Activo — "Activo" verde / "Inactivo" gris -->
                                <TextBlock Grid.Column="5" Text="Activo"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#107C10"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{x:Bind Activo,
                                                        Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock Grid.Column="5" Text="Inactivo"
                                           FontSize="11"
                                           Foreground="#8A8A8A"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{x:Bind Activo,
                                                        Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                              Width="48" Height="48"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Status bar ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="3" Style="{StaticResource OgStatusBarStyle}" Margin="{StaticResource ErpStatusRegionMargin}">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource OgStatusCountStyle}">
                    <Run Text="{x:Bind ViewModel.Almacenes.Count, Mode=OneWay}"/>
                    <Run Text="almacén(es) ·"/>
                    <Run Text="Sucursal:"/>
                    <Run Text="{x:Bind ViewModel.SucursalNombre, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Style="{StaticResource OgStatusErrorStyle}"
                           Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>
                <TextBlock Style="{StaticResource OgStatusSuccessStyle}"
                           Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
