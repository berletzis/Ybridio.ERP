<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Config.EmpresaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="using:Ybridio.WinUI.Converters"
      xmlns:dto="using:Ybridio.Application.DTOs.Core"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter         x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter  x:Key="InvBoolToVis"/>
    </Page.Resources>

    <!--
        Singleton Operational Surface Pattern (ADR-XXX)
        ─────────────────────────────────────────────────
        Aunque Empresa sea un registro único, respeta el mismo patrón
        operacional institucional del ERP:
          · CommandBar con acciones explícitas (Editar / Guardar / Cancelar / Actualizar)
          · Grid institucional izquierdo (registro visible, seleccionable)
          · Surface de edición derecho (active solo cuando IsEditing)
          · StatusBar operacional
    -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ ROW 0: CommandBar institucional ═══════════ -->
        <CommandBar Grid.Row="0"
                    DefaultLabelPosition="Right"
                    HorizontalAlignment="Left"
                    Margin="8,0,0,0">

            <!-- Modo vista: Editar disponible -->
            <AppBarButton Label="Editar"
                          Command="{x:Bind ViewModel.EditarCommand}"
                          Visibility="{x:Bind ViewModel.IsNotEditing, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE70F;"/></AppBarButton.Icon>
            </AppBarButton>

            <!-- Modo edición: Guardar + Cancelar -->
            <AppBarButton Label="Guardar"
                          Command="{x:Bind ViewModel.GuardarCommand}"
                          Visibility="{x:Bind ViewModel.IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE74E;"/></AppBarButton.Icon>
            </AppBarButton>

            <AppBarButton Label="Cancelar"
                          Command="{x:Bind ViewModel.CancelarCommand}"
                          Visibility="{x:Bind ViewModel.IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE711;"/></AppBarButton.Icon>
            </AppBarButton>

            <AppBarSeparator/>

            <AppBarButton Label="Actualizar"
                          Command="{x:Bind ViewModel.LoadCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE72C;"/></AppBarButton.Icon>
            </AppBarButton>

        </CommandBar>

        <!-- ═══════════ ROW 1: Content — Grid izquierdo + Surface derecho ═══════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400" MinWidth="280"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- ── Columna 0: Operational Grid ─────────────────────────── -->
            <Border Grid.Column="0"
                    Margin="20,8,0,0"
                    Background="White"
                    BorderBrush="#E5E5E5"
                    BorderThickness="1">
                <Grid>
                    <ListView Style="{StaticResource OutlookDataGridStyle}"
                              ItemsSource="{x:Bind ViewModel.Empresas, Mode=OneWay}"
                              IsItemClickEnabled="False"
                              SelectionMode="None">

                        <!-- Header institucional -->
                        <ListView.Header>
                            <Border Background="#FAFAFA"
                                    BorderBrush="#E8E8E8"
                                    BorderThickness="0,0,0,1">
                                <Grid Padding="{StaticResource ErpHeaderPadding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="1" Text="Empresa"  Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="2" Text="RFC"      Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="3" Text="Estado"   Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Center"/>
                                </Grid>
                            </Border>
                        </ListView.Header>

                        <!-- Row template -->
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="dto:EmpresaDto">
                                <Grid Height="{StaticResource ErpRowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Nombre -->
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Nombre}"
                                               Style="{StaticResource ErpCellPrimaryStyle}"
                                               VerticalAlignment="Center"/>

                                    <!-- RFC -->
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind RFC}"
                                               Style="{StaticResource ErpCellSecondaryStyle}"
                                               VerticalAlignment="Center"/>

                                    <!-- Estado: siempre Activo -->
                                    <Border Grid.Column="3"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="#EBF3FB"
                                            BorderBrush="#0078D4"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="8,2">
                                        <TextBlock Text="Activo"
                                                   FontSize="11"
                                                   Foreground="#0078D4"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- ProgressRing superpuesto -->
                    <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                                  Width="48" Height="48"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ── Columna 1: Separador vertical ────────────────────────── -->
            <Border Grid.Column="1"
                    Background="#E5E5E5"
                    Margin="0,8,0,16"/>

            <!-- ── Columna 2: Surface de edición ────────────────────────── -->
            <Grid Grid.Column="2">

                <!-- Modo vista: panel informativo -->
                <Border Padding="32,24"
                        Visibility="{x:Bind ViewModel.IsNotEditing, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <StackPanel Spacing="8" VerticalAlignment="Top">

                        <!-- Título sección -->
                        <TextBlock Text="Datos de la Empresa"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   FontSize="15"/>

                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap">
                            <Run Text="Presiona"/>
                            <Run Text="Editar" FontWeight="SemiBold"
                                 Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                            <Run Text="en el CommandBar para modificar los datos de la empresa."/>
                        </TextBlock>

                        <!-- Display de valores actuales (solo lectura) -->
                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8,0,4"/>

                        <StackPanel Spacing="12" Margin="0,4,0,0">

                            <StackPanel Spacing="2">
                                <TextBlock Text="Nombre"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Nombre, Mode=OneWay}"
                                           FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="RFC"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Rfc, Mode=OneWay}"
                                           FontSize="13"/>
                            </StackPanel>

                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- Modo edición: formulario operacional -->
                <ScrollViewer Padding="32,24,32,16"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="{x:Bind ViewModel.IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <StackPanel Spacing="{StaticResource ErpFormFieldSpacing}" MaxWidth="560">

                        <!-- Header del formulario -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="Editar Empresa"
                                       Style="{StaticResource ErpFormTitleStyle}"/>
                            <TextBlock Text="Modifica los datos de la empresa y presiona Guardar para confirmar."
                                       Style="{StaticResource ErpFormSubtitleStyle}"/>
                        </StackPanel>

                        <Rectangle Style="{StaticResource ErpFormHeaderDividerStyle}"/>

                        <!-- Campo: Nombre -->
                        <TextBox Header="Nombre *"
                                 PlaceholderText="Nombre de la empresa"
                                 Text="{x:Bind ViewModel.Nombre, Mode=TwoWay}"
                                 HorizontalAlignment="Stretch"/>

                        <!-- Campo: RFC -->
                        <TextBox Header="RFC"
                                 PlaceholderText="Registro Federal de Contribuyentes (opcional)"
                                 Text="{x:Bind ViewModel.Rfc, Mode=TwoWay}"
                                 HorizontalAlignment="Stretch"/>

                    </StackPanel>
                </ScrollViewer>

            </Grid>

        </Grid>

        <!-- ═══════════ ROW 2: StatusBar ═══════════ -->
        <Border Grid.Row="2"
                Style="{StaticResource ErpGridStatusBarStyle}"
                Margin="20,0,20,16">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">

                <TextBlock Style="{StaticResource ErpGridStatusTextStyle}"
                           Text="1 empresa"/>

                <TextBlock Style="{StaticResource ErpGridErrorTextStyle}"
                           Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>

                <TextBlock Style="{StaticResource ErpGridSuccessTextStyle}"
                           Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"/>

                <!-- Indicador modo edición -->
                <Border Background="#FFF4CC"
                        BorderBrush="#C47F00"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8,2"
                        Visibility="{x:Bind ViewModel.IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Modo edición activo"
                               FontSize="11"
                               Foreground="#C47F00"
                               FontWeight="SemiBold"/>
                </Border>

            </StackPanel>
        </Border>

    </Grid>
</Page>
