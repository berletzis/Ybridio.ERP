<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Config.WorkflowPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24" Padding="20,16,20,24">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="Workflow del Sistema"
                           Style="{StaticResource TitleTextBlockStyle}"
                           FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Text="Estados de documentos comerciales. Los estados protegidos del sistema no pueden eliminarse ni modificar su lógica de transición."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Aviso institucional -->
            <Border Background="#EBF3FB" BorderBrush="#0078D4" BorderThickness="0,0,0,2"
                    Padding="16,12" CornerRadius="4">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE8D0;" FontSize="16" Foreground="#0078D4"/>
                    <TextBlock Text="Los estados de workflow son protegidos del sistema. Representan el ciclo de vida de los documentos y no pueden modificarse arbitrariamente para garantizar integridad transaccional."
                               TextWrapping="Wrap" Foreground="#0078D4" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Estados Cotización -->
            <StackPanel Spacing="8">
                <TextBlock Text="Estados de Cotización" FontSize="14" FontWeight="SemiBold"/>
                <Border Background="White" BorderBrush="#E5E5E5" BorderThickness="1">
                    <StackPanel>
                        <!-- Header -->
                        <Border Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1" Padding="16,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="Estado"       FontSize="12" FontWeight="SemiBold" Foreground="#666"/>
                                <TextBlock Grid.Column="2" Text="Descripción"  FontSize="12" FontWeight="SemiBold" Foreground="#666"/>
                                <TextBlock Grid.Column="3" Text="Protegido"    FontSize="12" FontWeight="SemiBold" Foreground="#666" TextAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Borrador -->
                        <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="0,0,16,0">
                            <Grid Height="52">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="138"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#8A8A8A" VerticalAlignment="Stretch"/>
                                <TextBlock Grid.Column="1" Text="Borrador" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#8A8A8A" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                <TextBlock Grid.Column="2" Text="Estado inicial. Documento en edición, sin efecto transaccional."
                                           FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="3" Glyph="&#xE72E;" FontSize="14" HorizontalAlignment="Center"
                                          VerticalAlignment="Center" Foreground="#0078D4"/>
                            </Grid>
                        </Border>

                        <!-- Aprobada -->
                        <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="0,0,16,0">
                            <Grid Height="52">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="138"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#0078D4" VerticalAlignment="Stretch"/>
                                <TextBlock Grid.Column="1" Text="Aprobada" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#0078D4" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                <TextBlock Grid.Column="2" Text="Cotización confirmada. Puede convertirse en Pedido."
                                           FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="3" Glyph="&#xE72E;" FontSize="14" HorizontalAlignment="Center"
                                          VerticalAlignment="Center" Foreground="#0078D4"/>
                            </Grid>
                        </Border>

                        <!-- Convertida -->
                        <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="0,0,16,0">
                            <Grid Height="52">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="138"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#107C10" VerticalAlignment="Stretch"/>
                                <TextBlock Grid.Column="1" Text="Convertida" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#107C10" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                <TextBlock Grid.Column="2" Text="Terminal. Transformada en Pedido. Solo lectura."
                                           FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="3" Glyph="&#xE72E;" FontSize="14" HorizontalAlignment="Center"
                                          VerticalAlignment="Center" Foreground="#0078D4"/>
                            </Grid>
                        </Border>

                        <!-- Cancelada -->
                        <Border Padding="0,0,16,0">
                            <Grid Height="52">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="138"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#A0A0A0" VerticalAlignment="Stretch"/>
                                <TextBlock Grid.Column="1" Text="Cancelada" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#A0A0A0" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                <TextBlock Grid.Column="2" Text="Terminal. Cancelada por el usuario."
                                           FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="3" Glyph="&#xE72E;" FontSize="14" HorizontalAlignment="Center"
                                          VerticalAlignment="Center" Foreground="#0078D4"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Flujo visual -->
            <StackPanel Spacing="8">
                <TextBlock Text="Diagrama de Transiciones — Cotización" FontSize="14" FontWeight="SemiBold"/>
                <Border Background="#F8F8F8" BorderBrush="#E5E5E5" BorderThickness="1" Padding="24,16">
                    <StackPanel Spacing="4">
                        <TextBlock FontFamily="Cascadia Code, Consolas, monospace" FontSize="12" Foreground="#333"
                                   Text="Borrador ──Aprobar──→ Aprobada ──Convertir──→ Convertida (terminal)"/>
                        <TextBlock FontFamily="Cascadia Code, Consolas, monospace" FontSize="12" Foreground="#333"
                                   Text="                              ╚──Cancelar──→ Cancelada  (terminal)"/>
                        <TextBlock FontFamily="Cascadia Code, Consolas, monospace" FontSize="12" Foreground="#888"
                                   Margin="0,8,0,0"
                                   Text="Nota: Enviar, Imprimir, Duplicar son acciones operacionales sin cambio de estado."/>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
