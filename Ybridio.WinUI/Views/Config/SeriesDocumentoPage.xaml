<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Config.SeriesDocumentoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:dto="using:Ybridio.Application.DTOs.Catalogos"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
        Series Documentales — Shared Sequence/Folio Pattern
        Configura prefijos, longitudes y consecutivos por tipo de documento.
        La generación runtime la hace IFolioGeneratorService (Application layer).
    -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CommandBar institucional -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left" Margin="8,0,0,0">
            <AppBarButton Label="Nueva" Command="{x:Bind ViewModel.NuevoCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE710;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Editar" Command="{x:Bind ViewModel.EditarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE70F;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Eliminar" Command="{x:Bind ViewModel.EliminarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE74D;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Actualizar" Command="{x:Bind ViewModel.LoadCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE72C;"/></AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <!-- Buscador -->
        <Grid Grid.Row="1" Padding="8,8,20,4">
            <AutoSuggestBox PlaceholderText="Buscar por tipo de documento o prefijo..."
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.Busqueda, Mode=TwoWay}"/>
        </Grid>

        <!-- Grid Operational Standard v2 -->
        <Border Grid.Row="2" Margin="20,4,20,0" Background="White" BorderBrush="#E5E5E5" BorderThickness="1">
            <Grid>
                <ListView Style="{StaticResource OutlookDataGridStyle}"
                          ItemsSource="{x:Bind ViewModel.Series, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SerieSeleccionada, Mode=TwoWay}"
                          DoubleTapped="Lista_DoubleTapped">
                    <ListView.Header>
                        <Border Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                            <Grid Padding="{StaticResource ErpHeaderPadding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="Tipo Documento"    Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="2" Text="Prefijo"           Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="3" Text="Longitud"          Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Folio Siguiente"   Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="5" Text="Activo"            Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="dto:SerieDocumentoDto">
                            <Grid Height="{StaticResource ErpRowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>

                                <!-- Tipo documento -->
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind TipoDocumentoNombre}"
                                           Style="{StaticResource ErpCellPrimaryStyle}"
                                           VerticalAlignment="Center"/>

                                <!-- Prefijo -->
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind Prefijo}"
                                           Style="{StaticResource ErpCellSecondaryStyle}"
                                           VerticalAlignment="Center"
                                           FontFamily="Cascadia Code, Consolas, monospace"
                                           FontWeight="SemiBold"/>

                                <!-- Longitud -->
                                <TextBlock Grid.Column="3"
                                           Text="{x:Bind Longitud}"
                                           Style="{StaticResource ErpCellSecondaryStyle}"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"/>

                                <!-- Folio siguiente (computed) -->
                                <Border Grid.Column="4"
                                        Background="#EBF3FB"
                                        BorderBrush="#0078D4"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8,2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind FolioSiguiente}"
                                               FontFamily="Cascadia Code, Consolas, monospace"
                                               FontSize="12"
                                               Foreground="#0078D4"
                                               FontWeight="SemiBold"/>
                                </Border>

                                <!-- Activo -->
                                <CheckBox Grid.Column="5"
                                          IsChecked="{x:Bind Activo}"
                                          IsEnabled="False"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                              Width="48" Height="48"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- StatusBar -->
        <Border Grid.Row="3" Style="{StaticResource ErpGridStatusBarStyle}" Margin="20,0,20,16">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource ErpGridStatusTextStyle}">
                    <Run Text="{x:Bind ViewModel.Series.Count, Mode=OneWay}"/>
                    <Run Text="serie(s) documental(es)"/>
                </TextBlock>
                <TextBlock Style="{StaticResource ErpGridErrorTextStyle}"
                           Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>
                <TextBlock Style="{StaticResource ErpGridSuccessTextStyle}"
                           Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
