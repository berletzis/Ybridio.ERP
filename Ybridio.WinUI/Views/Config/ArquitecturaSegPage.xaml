<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Config.ArquitecturaSegPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <Style x:Key="SecTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{ThemeResource AccentFillColorDefaultBrush}"/>
            <Setter Property="Margin"     Value="0,20,0,8"/>
        </Style>
        <Style x:Key="SecSubTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,12,0,4"/>
        </Style>
        <Style x:Key="CodeBlock" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="#E8E8FF"/>
        </Style>
        <Style x:Key="CodeBorder" TargetType="Border">
            <Setter Property="Background"    Value="#1E1E2E"/>
            <Setter Property="CornerRadius"  Value="4"/>
            <Setter Property="Padding"       Value="12,10,12,10"/>
            <Setter Property="Margin"        Value="0,4,0,4"/>
        </Style>
        <Style x:Key="BadgeOk" TargetType="Border">
            <Setter Property="Background"   Value="#1A7F3C"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding"      Value="6,2,6,2"/>
        </Style>
        <Style x:Key="BadgeBad" TargetType="Border">
            <Setter Property="Background"   Value="#8B1C1C"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding"      Value="6,2,6,2"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,16,32,32" Spacing="0" MaxWidth="900">

            <!-- ═══ ENCABEZADO ════════════════════════════════════════════════ -->
            <TextBlock Text="Arquitectura de Seguridad — Guía de Implementación"
                       FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="Referencia técnica viva para desarrolladores y super-administradores del ERP."
                       FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,24"/>

            <!-- ═══ 1. FLUJO DE AUTORIZACIÓN ══════════════════════════════════ -->
            <TextBlock Text="1. Flujo de Autorización Runtime" Style="{StaticResource SecTitle}"/>

            <Border Style="{StaticResource CodeBorder}">
                <TextBlock Style="{StaticResource CodeBlock}" xml:space="preserve">WinUI ViewModel
    └─ llama al Application Service
           └─ IErpAuthorizationService.PuedeAsync("permiso.clave")
                  └─ IPermisoService — resolución en 3 niveles:
                         Nivel 1: UsuarioPermiso.Permitido  (override explícito)
                                  ├─ true  → PERMITIDO (corta evaluación)
                                  ├─ false → DENEGADO  (corta evaluación, veto absoluto)
                                  └─ null  → hereda al nivel 2
                         Nivel 2: UsuarioPerfil → PerfilPermiso
                                  └─ encontrado → PERMITIDO
                         Nivel 3: UsuarioRol → RolPermiso
                                  └─ encontrado y Permitido=true → PERMITIDO
                  └─ DbContext (seguridad schema, read-optimized + MemoryPermissionCache TTL 10 min)</TextBlock>
            </Border>

            <!-- ═══ 2. IMPLEMENTACIÓN CORRECTA ═══════════════════════════════ -->
            <TextBlock Text="2. Implementación Correcta de Autorización" Style="{StaticResource SecTitle}"/>

            <!-- INCORRECTO -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
                <Border Style="{StaticResource BadgeBad}">
                    <TextBlock Text="❌  INCORRECTO" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                </Border>
                <TextBlock Text="Verificar rol por nombre — no usar nunca" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
            </StackPanel>
            <Border Style="{StaticResource CodeBorder}">
                <TextBlock Style="{StaticResource CodeBlock}" xml:space="preserve">// ❌ Nunca verificar roles por nombre — rompe RBAC
if (rol == "Admin") { ... }
if (usuario.Nombre == "superadmin") { ... }
if (_roleManager.IsInRoleAsync(user, "GerenteSucursal")) { ... }</TextBlock>
            </Border>

            <!-- CORRECTO -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,6">
                <Border Style="{StaticResource BadgeOk}">
                    <TextBlock Text="✔  CORRECTO" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                </Border>
                <TextBlock Text="Usar PermisosClave con IErpAuthorizationService" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
            </StackPanel>
            <Border Style="{StaticResource CodeBorder}">
                <TextBlock Style="{StaticResource CodeBlock}" xml:space="preserve">// ✔ Siempre verificar permisos por clave tipada
if (await _auth.PuedeAsync(PermisosClave.Producto.Editar))   { ... }
if (await _auth.PuedeAsync(PermisosClave.Venta.Crear))       { ... }
if (await _auth.PuedeAsync(PermisosClave.Caja.Abrir))        { ... }
if (await _auth.PuedeAsync(PermisosClave.Salida.Autorizar))  { ... }
if (await _auth.PuedeAsync(PermisosClave.Seguridad.UsuariosGestionar)) { ... }</TextBlock>
            </Border>

            <!-- ═══ 3. SCOPES DE SEGURIDAD ════════════════════════════════════ -->
            <TextBlock Text="3. Scopes de Seguridad — Contexto de Acceso" Style="{StaticResource SecTitle}"/>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
                <Border Style="{StaticResource BadgeBad}">
                    <TextBlock Text="❌  INCORRECTO" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                </Border>
                <TextBlock Text="Consultar sin respetar empresa/sucursal/almacén" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
            </StackPanel>
            <Border Style="{StaticResource CodeBorder}">
                <TextBlock Style="{StaticResource CodeBlock}" xml:space="preserve">// ❌ Query sin scope — expone datos de todas las empresas
var ventas = await _context.Ventas.ToListAsync();

// ❌ No verificar si el usuario puede acceder a la sucursal
var datos  = await _service.ObtenerAsync(sucursalId);</TextBlock>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,6">
                <Border Style="{StaticResource BadgeOk}">
                    <TextBlock Text="✔  CORRECTO" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                </Border>
                <TextBlock Text="Respetar ISessionContext para scopes empresa/sucursal" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
            </StackPanel>
            <Border Style="{StaticResource CodeBorder}">
                <TextBlock Style="{StaticResource CodeBlock}" xml:space="preserve">// ✔ Siempre filtrar por EmpresaId del contexto de sesión
var ventas = await _context.Ventas
    .Where(v => v.EmpresaId == _session.EmpresaId
             &amp;&amp; v.SucursalId == _session.SucursalId)
    .ToListAsync();

// ✔ Verificar acceso a sucursal específica
var puedeVer = await _scopeResolver
    .TieneAccesoSucursalAsync(_session.UsuarioId!.Value, sucursalId);

// ✔ Obtener sucursales permitidas para el usuario
var sucursalesPermitidas = await _scopeResolver
    .ObtenerSucursalesPermitidasAsync(_session.UsuarioId!.Value);</TextBlock>
            </Border>

            <!-- ═══ 4. DEVELOPER GUIDANCE PANEL ══════════════════════════════ -->
            <TextBlock Text="4. Developer Guidance — Ejemplos por Módulo" Style="{StaticResource SecTitle}"/>

            <!-- ProductosViewModel -->
            <TextBlock Text="Módulo Productos — ProductosViewModel" Style="{StaticResource SecSubTitle}"/>
            <Border Style="{StaticResource CodeBorder}">
                <TextBlock Style="{StaticResource CodeBlock}" xml:space="preserve">// Cargar solo si tiene permiso
if (await _auth.PuedeAsync(PermisosClave.Producto.Ver))
    await LoadAsync();

// Habilitar botón Editar solo si tiene permiso
EditarCommand.IsEnabled = await _auth.PuedeAsync(PermisosClave.Producto.Editar);</TextBlock>
            </Border>

            <!-- SalidaService -->
            <TextBlock Text="Módulo Inventario — SalidaService" Style="{StaticResource SecSubTitle}"/>
            <Border Style="{StaticResource CodeBorder}">
                <TextBlock Style="{StaticResource CodeBlock}" xml:space="preserve">// Validar permiso + scope de sucursal antes de ejecutar
if (!await _auth.PuedeAsync(PermisosClave.Salida.Crear))
    return ServiceResult.Fail("Sin permiso para crear salidas.", ErrorCode.Forbidden);

var puedeAcceder = await _scopeResolver
    .TieneAccesoSucursalAsync(usuarioId, dto.SucursalId);
if (!puedeAcceder)
    return ServiceResult.Fail("Sin acceso a esta sucursal.", ErrorCode.Forbidden);</TextBlock>
            </Border>

            <!-- VentaService -->
            <TextBlock Text="Módulo Ventas — VentaService" Style="{StaticResource SecSubTitle}"/>
            <Border Style="{StaticResource CodeBorder}">
                <TextBlock Style="{StaticResource CodeBlock}" xml:space="preserve">// Autorizar operación crítica con permiso específico
if (!await _auth.PuedeAsync(PermisosClave.Venta.Descuento))
    return ServiceResult.Fail("No autorizado para aplicar descuentos.");

// Bypass para SuperAdmin
if (await _scopeResolver.EsSuperAdminAsync(usuarioId))
    return ServiceResult.Ok(); // acceso total garantizado</TextBlock>
            </Border>

            <!-- ═══ 5. MÓDULOS Y PERMISOS ═════════════════════════════════════ -->
            <TextBlock Text="5. Módulos y Claves de Permisos" Style="{StaticResource SecTitle}"/>
            <TextBlock Text="Usar SIEMPRE las constantes de PermisosClave. Nunca cadenas literales."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>

            <Border Style="{StaticResource CodeBorder}">
                <TextBlock Style="{StaticResource CodeBlock}" xml:space="preserve">// Ybridio.Application.Common.PermisosClave
PermisosClave.Venta      → venta.ver · venta.crear · venta.editar · venta.eliminar · venta.descuento
PermisosClave.Entrada    → entrada.ver · entrada.crear · entrada.editar · entrada.eliminar · entrada.aprobar
PermisosClave.Salida     → salida.ver · salida.crear · salida.editar · salida.eliminar · salida.autorizar
PermisosClave.Traspaso   → traspaso.ver · traspaso.crear · traspaso.aprobar
PermisosClave.Ajuste     → ajuste.ver · ajuste.crear · ajuste.aprobar
PermisosClave.Existencia → existencia.ver · existencia.ajustar · existencia.conteo
PermisosClave.Producto   → producto.ver · producto.crear · producto.editar · producto.eliminar
PermisosClave.Caja       → caja.ver · caja.abrir · caja.cerrar · caja.movimiento
PermisosClave.Compra     → compra.ver · compra.crear · compra.editar · compra.aprobar
PermisosClave.Cliente    → cliente.ver · cliente.crear · cliente.editar
PermisosClave.Proveedor  → proveedor.ver · proveedor.crear · proveedor.editar
PermisosClave.Configuracion → configuracion.ver · configuracion.editar
PermisosClave.Seguridad  → seguridad.usuarios.ver · seguridad.usuarios.gestionar
                            seguridad.roles.ver · seguridad.roles.gestionar
                            seguridad.permisos.ver · seguridad.permisos.gestionar
PermisosClave.Reporte    → reporte.ver · reporte.exportar · reporte.financiero</TextBlock>
            </Border>

            <!-- ═══ 6. ROLES PREDEFINIDOS ══════════════════════════════════════ -->
            <TextBlock Text="6. Roles Predefinidos del Sistema" Style="{StaticResource SecTitle}"/>

            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="4" Padding="16,12">
                <StackPanel Spacing="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Rol" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="Permisos" FontWeight="SemiBold" FontSize="12" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Alcance" FontWeight="SemiBold" FontSize="12"/>
                    </Grid>
                    <Rectangle Height="1" Fill="#E5E5E5"/>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SuperAdmin"              FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="51" FontSize="12" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Acceso total, bypass de scopes" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="AdministradorEmpresa"    FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="50" FontSize="12" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Todos excepto administración de seguridad" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="GerenteSucursal"         FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="33" FontSize="12" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Operaciones de sucursal, reportes" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SupervisorInventario"    FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="25" FontSize="12" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Inventario completo + aprobaciones" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SupervisorVentas"        FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="11" FontSize="12" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Ventas + descuentos + clientes" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Cajero"                  FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="10" FontSize="12" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Caja + ventas básicas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="OperadorInventario"      FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="8" FontSize="12" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Entradas, salidas, traspasos, conteo" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Vendedor"                FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="7" FontSize="12" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Ventas básicas + clientes + productos" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══ 7. MODELO DE EVALUACIÓN ══════════════════════════════════ -->
            <TextBlock Text="7. Modelo de Evaluación de Permisos (3 niveles)" Style="{StaticResource SecTitle}"/>
            <Border Style="{StaticResource CodeBorder}">
                <TextBlock Style="{StaticResource CodeBlock}" xml:space="preserve">Nivel 1 — UsuarioPermiso.Permitido
  ├─ true  → PERMITIDO  (override explícito, máxima prioridad)
  ├─ false → DENEGADO   (veto explícito, no puede heredar)
  └─ null  → continúa evaluación

Nivel 2 — UsuarioPerfil → PerfilPermiso
  └─ el usuario tiene un perfil que incluye este permiso → PERMITIDO

Nivel 3 — UsuarioRol → RolPermiso
  └─ el rol del usuario tiene RolPermiso.Permitido = true → PERMITIDO

Resultado final: DENEGADO si ningún nivel lo permite.</TextBlock>
            </Border>

            <TextBlock Text="Caché: MemoryPermissionCache (TTL 10 min). Invalidar con IPermissionCache.InvalidateAsync(userId) tras cambio de rol o permiso."
                       FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,32"/>

        </StackPanel>
    </ScrollViewer>
</Page>
