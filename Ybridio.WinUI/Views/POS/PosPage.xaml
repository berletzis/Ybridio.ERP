<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ybridio.WinUI.Views.POS.PosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="16" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />    <!-- Catálogo -->
            <ColumnDefinition Width="340" />  <!-- Carrito -->
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- CATÁLOGO DE PRODUCTOS                                             -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Mostrador — POS"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Margin="0,0,0,12" />

            <!-- Búsqueda -->
            <AutoSuggestBox Grid.Row="1"
                            PlaceholderText="Buscar producto por nombre o código..."
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.Busqueda, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Margin="0,0,0,12" />

            <!-- Loading -->
            <ProgressBar Grid.Row="2"
                         VerticalAlignment="Top"
                         IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                         Margin="0,0,0,8" />

            <!-- Grid de productos -->
            <GridView Grid.Row="2"
                      ItemsSource="{x:Bind ViewModel.Productos, Mode=OneWay}"
                      SelectionMode="None">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Width="160"
                                Height="110">
                            <Grid RowSpacing="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <FontIcon Grid.Row="0"
                                          Glyph="&#xE8B9;"
                                          FontSize="28"
                                          HorizontalAlignment="Center"
                                          Foreground="{ThemeResource AccentAAFillColorDefaultBrush}" />

                                <TextBlock Grid.Row="1"
                                           Text="{Binding ProductoNombre}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           TextWrapping="Wrap"
                                           MaxLines="2"
                                           TextTrimming="CharacterEllipsis" />

                                <TextBlock Grid.Row="2"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="Stock: " />
                                    <Run Text="{Binding Cantidad}" />
                                </TextBlock>

                                <!-- Botón agregar al carrito -->
                                <Button Grid.Row="3"
                                        Content="+ Agregar"
                                        HorizontalAlignment="Stretch"
                                        FontSize="12"
                                        Padding="4,2"
                                        Command="{x:Bind ((local:PosPage)DataContext).ViewModel.AgregarAlCarritoCommand, RelativeSource={RelativeSource Self}}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- CARRITO                                                           -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Encabezado carrito -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Carrito"
                           Style="{StaticResource TitleTextBlockStyle}" />
                <Button Grid.Column="1"
                        Content="Limpiar"
                        Command="{x:Bind ViewModel.LimpiarCarritoCommand}"
                        Style="{StaticResource TransparentButtonStyle}"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
            </Grid>

            <!-- Lista de ítems -->
            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.Carrito, Mode=OneWay}"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:CartItemViewModel">
                        <Grid Padding="0,6" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="28" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{x:Bind Nombre}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />

                            <NumberBox Grid.Column="1"
                                       Minimum="1"
                                       Value="{x:Bind Cantidad, Mode=TwoWay}"
                                       SpinButtonPlacementMode="Inline"
                                       SmallChange="1"
                                       VerticalAlignment="Center"
                                       FontSize="12" />

                            <TextBlock Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       FontSize="13">
                                <Run Text="$" />
                                <Run Text="{x:Bind Importe, Mode=OneWay}" />
                            </TextBlock>

                            <Button Grid.Column="3"
                                    Command="{x:Bind ((local:PosPage)DataContext).ViewModel.QuitarDelCarritoCommand, RelativeSource={RelativeSource Self}}"
                                    CommandParameter="{x:Bind}"
                                    Style="{StaticResource TransparentButtonStyle}"
                                    Padding="4"
                                    VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE711;" FontSize="12"
                                          Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Separador -->
            <Border Grid.Row="2"
                    Height="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                    Margin="0,8" />

            <!-- Total -->
            <Grid Grid.Row="3" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="TOTAL"
                           Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Grid.Column="1"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           FontWeight="Bold">
                    <Run Text="$" />
                    <Run Text="{x:Bind ViewModel.Total, Mode=OneWay}" />
                </TextBlock>
            </Grid>

            <!-- Mensajes de error / éxito -->
            <InfoBar Grid.Row="4"
                     IsOpen="{x:Bind ViewModel.ErrorMessage.Length, Mode=OneWay, Converter={StaticResource IntToBool}}"
                     Severity="Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     IsClosable="True"
                     Margin="0,0,0,8" />
            <InfoBar Grid.Row="4"
                     IsOpen="{x:Bind ViewModel.SuccessMessage.Length, Mode=OneWay, Converter={StaticResource IntToBool}}"
                     Severity="Success"
                     Message="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"
                     IsClosable="True"
                     Margin="0,0,0,8" />

            <!-- Botón Vender -->
            <Button Grid.Row="5"
                    Content="Registrar venta"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.VenderCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    Height="48"
                    FontSize="16">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8C7;" FontSize="16" />
                            <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <!-- Progreso de venta -->
            <ProgressBar Grid.Row="5"
                         VerticalAlignment="Bottom"
                         IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                         Margin="0,52,0,0" />
        </Grid>
    </Grid>
</Page>
