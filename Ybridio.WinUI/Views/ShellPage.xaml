<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ybridio.WinUI.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dto="using:Ybridio.Application.DTOs.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Botón de módulo estilo Outlook: icono arriba, texto abajo, centrado, sin borde -->
        <Style x:Key="ShellNavButtonStyle" TargetType="Button">
            <Setter Property="Width"             Value="72"/>
            <Setter Property="Height"            Value="64"/>
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="BorderBrush"       Value="Transparent"/>
            <Setter Property="HorizontalAlignment"        Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="CornerRadius"      Value="8"/>
            <Setter Property="Padding"           Value="0"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- TOP BAR (Row 0, full-width)                                         -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="TopBarGrid"
              Grid.Row="0"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo (alineado con el sidebar) -->
            <TextBlock Grid.Column="0"
                       Text="Y"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- Sección activa -->
            <TextBlock Grid.Column="1"
                       Text="{x:Bind ViewModel.SeccionActiva, Mode=OneWay}"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- Tienda + Caja + Usuario -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="4"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center">

                <!-- Selector de tienda -->
                <Button Background="Transparent" BorderThickness="0"
                        Padding="10,6,10,6" CornerRadius="4">
                    <Button.Flyout>
                        <Flyout x:Name="SucursalFlyout" Placement="Bottom">
                            <ListView ItemsSource="{x:Bind ViewModel.SucursalesDisponibles, Mode=OneWay}"
                                      IsItemClickEnabled="True"
                                      ItemClick="TiendaSelector_ItemClick"
                                      MinWidth="180" MaxHeight="320">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="dto:SucursalDto">
                                        <TextBlock Text="{x:Bind Nombre}" Padding="4,2"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Flyout>
                    </Button.Flyout>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE8CE;" FontSize="13"/>
                        <TextBlock Text="{x:Bind ViewModel.SucursalNombre, Mode=OneWay}" FontSize="13"/>
                        <FontIcon Glyph="&#xE70D;" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Caja -->
                <Border Padding="8,4,8,4" CornerRadius="4"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE8C7;" FontSize="12"/>
                        <TextBlock Text="{x:Bind ViewModel.CajaEstado, Mode=OneWay}" FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- Separador -->
                <Border Width="1" Height="22"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                        Margin="4,0"/>

                <!-- Usuario -->
                <Button Background="Transparent" BorderThickness="0"
                        Padding="8,6,8,6" CornerRadius="4"
                        Command="{x:Bind ViewModel.LogoutCommand}"
                        ToolTipService.ToolTip="Cerrar sesión">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE77B;" FontSize="13"/>
                        <TextBlock Text="{x:Bind ViewModel.UsuarioNombre, Mode=OneWay}" FontSize="13"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ÁREA PRINCIPAL (Row 1)                                              -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── SIDEBAR IZQUIERDA (Col 0) ─────────────────────────────── -->
            <Grid Grid.Column="0"
                  Background="{ThemeResource NavigationViewDefaultPaneBackground}"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="0,0,1,0">

                <!--
                    NavButtonsPanel es un Grid con fila * de separación.
                    Todos los Button son hijos directos → SetActiveNavButton itera correctamente.
                    Los separadores (Border) son ignorados por "if (child is Button btn)".
                -->
                <Grid x:Name="NavButtonsPanel" Margin="0,8,0,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Dashboard -->
                        <RowDefinition Height="Auto"/>  <!-- POS -->
                        <RowDefinition Height="Auto"/>  <!-- Inventario -->
                        <RowDefinition Height="Auto"/>  <!-- Ventas -->
                        <RowDefinition Height="Auto"/>  <!-- Contactos -->
                        <RowDefinition Height="*"/>     <!-- Espaciador -->
                        <RowDefinition Height="Auto"/>  <!-- Separador visual -->
                        <RowDefinition Height="Auto"/>  <!-- Config Global -->
                        <RowDefinition Height="Auto"/>  <!-- Config Tienda -->
                        <RowDefinition Height="Auto"/>  <!-- Salir -->
                    </Grid.RowDefinitions>

                    <!-- ── Módulos principales ──────────────────────── -->

                    <Button x:Name="BtnDashboard"
                            Grid.Row="0"
                            Tag="Dashboard"
                            Click="ModuleButton_Click"
                            Style="{StaticResource ShellNavButtonStyle}"
                            ToolTipService.ToolTip="Dashboard">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE80F;" FontSize="20"/>
                            <TextBlock Text="Dashboard" FontSize="10"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="1"
                            Tag="POS"
                            Click="ModuleButton_Click"
                            Style="{StaticResource ShellNavButtonStyle}"
                            ToolTipService.ToolTip="Punto de Venta">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE8A7;" FontSize="20"/>
                            <TextBlock Text="POS" FontSize="10"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="2"
                            Tag="Inventario"
                            Click="ModuleButton_Click"
                            Style="{StaticResource ShellNavButtonStyle}"
                            ToolTipService.ToolTip="Inventario">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE8F1;" FontSize="20"/>
                            <TextBlock Text="Inventario" FontSize="10"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="3"
                            Tag="Ventas"
                            Click="ModuleButton_Click"
                            Style="{StaticResource ShellNavButtonStyle}"
                            ToolTipService.ToolTip="Ventas">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE7BF;" FontSize="20"/>
                            <TextBlock Text="Ventas" FontSize="10"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="4"
                            Tag="Contactos"
                            Click="ModuleButton_Click"
                            Style="{StaticResource ShellNavButtonStyle}"
                            ToolTipService.ToolTip="Contactos">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE77B;" FontSize="20"/>
                            <TextBlock Text="Contactos" FontSize="10"/>
                        </StackPanel>
                    </Button>

                    <!-- Row 5: espaciador (* en RowDefinitions, sin hijo) -->

                    <!-- Separador visual entre módulos y configuración -->
                    <Border Grid.Row="6"
                            Height="1"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                            Margin="12,0"/>

                    <!-- ── Configuración (inferior) ─────────────────── -->

                    <Button Grid.Row="7"
                            Tag="ConfiguracionGlobal"
                            Click="ModuleButton_Click"
                            Style="{StaticResource ShellNavButtonStyle}"
                            ToolTipService.ToolTip="Configuración Global">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xEA3A;" FontSize="20"/>
                            <TextBlock Text="Global" FontSize="10"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="8"
                            Tag="ConfiguracionTienda"
                            Click="ModuleButton_Click"
                            Style="{StaticResource ShellNavButtonStyle}"
                            ToolTipService.ToolTip="Configuración de Sucursal">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE8CE;" FontSize="20"/>
                            <TextBlock Text="Sucursal" FontSize="10"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="9"
                            Style="{StaticResource ShellNavButtonStyle}"
                            Command="{x:Bind ViewModel.LogoutCommand}"
                            ToolTipService.ToolTip="Cerrar sesión">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE8AC;" FontSize="20"/>
                            <TextBlock Text="Salir" FontSize="10"/>
                        </StackPanel>
                    </Button>

                </Grid>
            </Grid>

            <!-- ── CONTENIDO PRINCIPAL (Col 1) ───────────────────────────── -->
            <Frame x:Name="InnerFrame" Grid.Column="1"/>

        </Grid>
    </Grid>
</Page>
