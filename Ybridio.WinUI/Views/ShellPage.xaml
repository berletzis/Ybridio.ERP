<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ybridio.WinUI.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72" />
            <!-- Barra iconos izquierda -->
            <ColumnDefinition Width="*" />
            <!-- Contenido principal -->
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- BARRA IZQUIERDA — estilo Outlook 2026                             -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0"
              Background="{ThemeResource NavigationViewDefaultPaneBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <!-- Logo/App -->
                <RowDefinition Height="*" />
                <!-- Iconos módulos -->
                <RowDefinition Height="Auto"/>
                <!-- Config -->
                <RowDefinition Height="Auto"/>
                <!-- Logout abajo -->
            </Grid.RowDefinitions>

            <!-- Logo -->
            <Border Grid.Row="0"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                <TextBlock Text="Y"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <!-- Iconos de módulos -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <StackPanel x:Name="NavButtonsPanel">

                    <!-- Dashboard -->
                    <Button x:Name="BtnDashboard"
                            Tag="Dashboard"
                            Click="ModuleButton_Click"
                            Width="72" Height="64"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            CornerRadius="8"
                            HorizontalAlignment="Center"
                            ToolTipService.ToolTip="Dashboard">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xEA3A;" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Dashboard" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Separador -->
                    <Rectangle Height="1" Margin="8,4"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- POS -->
                    <Button x:Name="BtnPOS"
                            Tag="POS"
                            Click="ModuleButton_Click"
                            Width="72" Height="64"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            CornerRadius="8"
                            HorizontalAlignment="Center"
                            ToolTipService.ToolTip="Punto de Venta">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xEA3A;" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="POS" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Inventario -->
                    <Button x:Name="BtnInventario"
                            Tag="Inventario"
                            Click="ModuleButton_Click"
                            Width="72" Height="64"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            CornerRadius="8"
                            HorizontalAlignment="Center"
                            ToolTipService.ToolTip="Inventario">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xEA3A;" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Inventario" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Ventas -->
                    <Button x:Name="BtnVentas"
                            Tag="Ventas"
                            Click="ModuleButton_Click"
                            Width="72" Height="64"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            CornerRadius="8"
                            HorizontalAlignment="Center"
                            ToolTipService.ToolTip="Ventas">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xEA3A;" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Ventas" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Contactos -->
                    <Button x:Name="BtnContactos"
                            Tag="Contactos"
                            Click="ModuleButton_Click"
                            Width="72" Height="64"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            CornerRadius="8"
                            HorizontalAlignment="Center"
                            ToolTipService.ToolTip="Contactos">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xEA3A;" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Contactos" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </ScrollViewer>

            <!-- Configuración (fijo sobre Salir) -->
            <Button x:Name="BtnConfiguracion"
                    Grid.Row="2"
                    Tag="Configuracion"
                    Click="ModuleButton_Click"
                    Width="72" Height="64"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    CornerRadius="8"
                    HorizontalAlignment="Center"
                    ToolTipService.ToolTip="Configuración">
                <StackPanel HorizontalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xEA3A;" FontSize="20" HorizontalAlignment="Center"/>
                    <TextBlock Text="Config" FontSize="10" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Logout abajo -->
            <Button Grid.Row="3"
                    Command="{x:Bind ViewModel.LogoutCommand}"
                    Width="72" Height="64"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    CornerRadius="8"
                    HorizontalAlignment="Center"
                    ToolTipService.ToolTip="Cerrar sesión">
                <StackPanel HorizontalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xEA3A;" FontSize="20" HorizontalAlignment="Center"/>
                    <TextBlock Text="Salir" FontSize="10" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- CONTENIDO PRINCIPAL                                               -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <!-- TopBar -->
                <RowDefinition Height="*" />
                <!-- Frame -->
            </Grid.RowDefinitions>

            <!-- ── TOP BAR ─────────────────────────────────────────────── -->
            <Grid x:Name="TopBarGrid"
                  Grid.Row="0"
                  Background="{ThemeResource NavigationViewDefaultPaneBackground}"
                  Padding="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Sección activa -->
                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.SeccionActiva, Mode=OneWay}"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,24,0" />

                <!-- Búsqueda -->
                <AutoSuggestBox Grid.Column="1"
                                PlaceholderText="Buscar..."
                                QueryIcon="Find"
                                MaxWidth="400"
                                VerticalAlignment="Center" />

                <!-- Sesión -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="12">

                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xEA3A;" FontSize="14"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.TiendaNombre, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xEA3A;" FontSize="14"
                                  Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.CajaEstado, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Rectangle Width="1" Height="20"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <PersonPicture DisplayName="{x:Bind ViewModel.UsuarioNombre, Mode=OneWay}"
                                   Width="28" Height="28" />
                    <TextBlock Text="{x:Bind ViewModel.UsuarioNombre, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- ── FRAME CENTRAL ────────────────────────────────────────── -->
            <Frame x:Name="InnerFrame" Grid.Row="1" />
        </Grid>
    </Grid>
</Page>
