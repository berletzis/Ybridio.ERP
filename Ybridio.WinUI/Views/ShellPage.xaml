<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ybridio.WinUI.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56" />
            <!-- Barra iconos izquierda -->
            <ColumnDefinition Width="*" />
            <!-- Contenido principal -->
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- BARRA IZQUIERDA — solo iconos                                     -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0"
              Background="{ThemeResource NavigationViewDefaultPaneBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <!-- Logo/App -->
                <RowDefinition Height="*" />
                <!-- Iconos módulos -->
                <RowDefinition Height="Auto"/>
                <!-- Logout abajo -->
            </Grid.RowDefinitions>

            <!-- Logo -->
            <Border Grid.Row="0"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                <TextBlock Text="Y"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <!-- Iconos de módulos -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <StackPanel>

                    <!-- Dashboard -->
                    <Button Tag="Dashboard"
                            Click="ModuleButton_Click"
                            Style="{StaticResource NavigationBackButtonNormalStyle}"
                            Width="56" Height="52"
                            ToolTipService.ToolTip="Dashboard">
                        <FontIcon Glyph="&#xE8A1;" FontSize="18" />
                    </Button>

                    <!-- Separador -->
                    <Rectangle Height="1" Margin="8,4"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- POS -->
                    <Button Tag="POS"
                            Click="ModuleButton_Click"
                            Style="{StaticResource NavigationBackButtonNormalStyle}"
                            Width="56" Height="52"
                            ToolTipService.ToolTip="Punto de Venta">
                        <FontIcon Glyph="&#xE719;" FontSize="18" />
                    </Button>

                    <!-- Inventario -->
                    <Button Tag="Inventario"
                            Click="ModuleButton_Click"
                            Style="{StaticResource NavigationBackButtonNormalStyle}"
                            Width="56" Height="52"
                            ToolTipService.ToolTip="Inventario">
                        <FontIcon Glyph="&#xE8B9;" FontSize="18" />
                    </Button>

                    <!-- Ventas -->
                    <Button Tag="Ventas"
                            Click="ModuleButton_Click"
                            Style="{StaticResource NavigationBackButtonNormalStyle}"
                            Width="56" Height="52"
                            ToolTipService.ToolTip="Ventas">
                        <FontIcon Glyph="&#xE8FF;" FontSize="18" />
                    </Button>

                    <!-- Contactos -->
                    <Button Tag="Contactos"
                            Click="ModuleButton_Click"
                            Style="{StaticResource NavigationBackButtonNormalStyle}"
                            Width="56" Height="52"
                            ToolTipService.ToolTip="Contactos">
                        <FontIcon Glyph="&#xE716;" FontSize="18" />
                    </Button>

                    <!-- Configuración -->
                    <Button Tag="Configuracion"
                            Click="ModuleButton_Click"
                            Style="{StaticResource NavigationBackButtonNormalStyle}"
                            Width="56" Height="52"
                            ToolTipService.ToolTip="Configuración">
                        <FontIcon Glyph="&#xE713;" FontSize="18" />
                    </Button>

                </StackPanel>
            </ScrollViewer>

            <!-- Logout abajo -->
            <Button Grid.Row="2"
                    Command="{x:Bind ViewModel.LogoutCommand}"
                    Style="{StaticResource NavigationBackButtonNormalStyle}"
                    Width="56" Height="52"
                    ToolTipService.ToolTip="Cerrar sesión">
                <FontIcon Glyph="&#xF3B1;" FontSize="18" />
            </Button>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- CONTENIDO PRINCIPAL                                               -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <!-- TopBar -->
                <RowDefinition Height="Auto" />
                <!-- Ribbon de sub-módulos -->
                <RowDefinition Height="*" />
                <!-- Frame -->
            </Grid.RowDefinitions>

            <!-- ── TOP BAR ─────────────────────────────────────────────── -->
            <Grid Grid.Row="0"
                  Background="{ThemeResource NavigationViewDefaultPaneBackground}"
                  Padding="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Sección activa -->
                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.SeccionActiva, Mode=OneWay}"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,24,0" />

                <!-- Búsqueda -->
                <AutoSuggestBox Grid.Column="1"
                                PlaceholderText="Buscar..."
                                QueryIcon="Find"
                                MaxWidth="400"
                                VerticalAlignment="Center" />

                <!-- Sesión -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="12">

                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE7F4;" FontSize="14"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.TiendaNombre, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE8C7;" FontSize="14"
                                  Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.CajaEstado, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Rectangle Width="1" Height="20"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <PersonPicture DisplayName="{x:Bind ViewModel.UsuarioNombre, Mode=OneWay}"
                                   Width="28" Height="28" />
                    <TextBlock Text="{x:Bind ViewModel.UsuarioNombre, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- ── RIBBON DE SUB-MÓDULOS ────────────────────────────────── -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Background="{ThemeResource LayerFillColorDefaultBrush}">
                <StackPanel x:Name="RibbonPanel"
                            Orientation="Horizontal"
                            Spacing="2"
                            Padding="8,4">

                    <!-- POS sub-módulos -->
                    <StackPanel x:Name="RibbonPOS" Orientation="Horizontal" Spacing="2"
                                Visibility="{x:Bind ViewModel.ShowRibbonPOS, Mode=OneWay}">
                        <Button Tag="POS" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6" ToolTipService.ToolTip="Mostrador POS">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE719;" FontSize="14"/>
                                <TextBlock Text="Mostrador" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="AperturaCaja" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C7;" FontSize="14"/>
                                <TextBlock Text="Apertura Caja" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="CierreCaja" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C8;" FontSize="14"/>
                                <TextBlock Text="Cierre Caja" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="RetiroEfectivo" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8AB;" FontSize="14"/>
                                <TextBlock Text="Retiro" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Cancelaciones" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE711;" FontSize="14"/>
                                <TextBlock Text="Cancelaciones" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Devoluciones" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE7BE;" FontSize="14"/>
                                <TextBlock Text="Devoluciones" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="ReimprimirTicket" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE749;" FontSize="14"/>
                                <TextBlock Text="Reimprimir" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="ConsultaCierres" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8F1;" FontSize="14"/>
                                <TextBlock Text="Consulta Cierres" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Inventario sub-módulos -->
                    <StackPanel x:Name="RibbonInventario" Orientation="Horizontal" Spacing="2"
                                Visibility="{x:Bind ViewModel.ShowRibbonInventario, Mode=OneWay}">
                        <Button Tag="Productos" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8B9;" FontSize="14"/>
                                <TextBlock Text="Productos" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Existencias" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8F1;" FontSize="14"/>
                                <TextBlock Text="Existencias" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Entradas" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8FA;" FontSize="14"/>
                                <TextBlock Text="Entradas" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Salidas" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8FB;" FontSize="14"/>
                                <TextBlock Text="Salidas" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Kardex" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8D2;" FontSize="14"/>
                                <TextBlock Text="Kardex" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Conteo" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8EF;" FontSize="14"/>
                                <TextBlock Text="Conteo" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="OrdenesCompra" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8D0;" FontSize="14"/>
                                <TextBlock Text="Órdenes Compra" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Ventas sub-módulos -->
                    <StackPanel x:Name="RibbonVentas" Orientation="Horizontal" Spacing="2"
                                Visibility="{x:Bind ViewModel.ShowRibbonVentas, Mode=OneWay}">
                        <Button Tag="Cotizaciones" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8A5;" FontSize="14"/>
                                <TextBlock Text="Cotizaciones" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="OrdenTrabajo" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8FD;" FontSize="14"/>
                                <TextBlock Text="Orden Trabajo" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="ConsultaVentas" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8FF;" FontSize="14"/>
                                <TextBlock Text="Consulta Ventas" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Contactos sub-módulos -->
                    <StackPanel x:Name="RibbonContactos" Orientation="Horizontal" Spacing="2"
                                Visibility="{x:Bind ViewModel.ShowRibbonContactos, Mode=OneWay}">
                        <Button Tag="Contactos" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE716;" FontSize="14"/>
                                <TextBlock Text="Contactos" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Configuración sub-módulos -->
                    <StackPanel x:Name="RibbonConfiguracion" Orientation="Horizontal" Spacing="2"
                                Visibility="{x:Bind ViewModel.ShowRibbonConfiguracion, Mode=OneWay}">
                        <Button Tag="ConfigLocal" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE713;" FontSize="14"/>
                                <TextBlock Text="Config. Local" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Impresoras" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE749;" FontSize="14"/>
                                <TextBlock Text="Impresoras" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Cajas" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C7;" FontSize="14"/>
                                <TextBlock Text="Cajas" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Empresas" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE731;" FontSize="14"/>
                                <TextBlock Text="Empresas" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Usuarios" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE77B;" FontSize="14"/>
                                <TextBlock Text="Usuarios" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Catalogos" Click="RibbonButton_Click" Style="{StaticResource NavigationBackButtonNormalStyle}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8A9;" FontSize="14"/>
                                <TextBlock Text="Catálogos" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- ── FRAME CENTRAL ────────────────────────────────────────── -->
            <Frame x:Name="InnerFrame" Grid.Row="2" />
        </Grid>
    </Grid>
</Page>