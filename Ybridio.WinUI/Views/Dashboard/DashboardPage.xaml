<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ybridio.WinUI.Views.Dashboard.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24">

            <!-- Encabezado -->
            <TextBlock Text="Dashboard"
                       Style="{StaticResource TitleLargeTextBlockStyle}" />

            <!-- Loading / Error -->
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="40" Height="40"
                          HorizontalAlignment="Left" />
            <InfoBar IsOpen="{x:Bind ViewModel.ErrorMessage.Length, Mode=OneWay, Converter={StaticResource IntToBool}}"
                     Severity="Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     IsClosable="True" />

            <!-- ── KPI Cards ──────────────────────────────────────────────── -->
            <ItemsControl>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="16" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <!-- Card: Ventas del día -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="20" MinWidth="180">
                    <StackPanel Spacing="4">
                        <FontIcon Glyph="&#xE8C7;" FontSize="28"
                                  Foreground="{ThemeResource AccentAAFillColorDefaultBrush}" />
                        <TextBlock Text="Ventas del día"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Style="{StaticResource TitleTextBlockStyle}">
                            <Run Text="$" />
                            <Run Text="{x:Bind ViewModel.VentasDelDia, Mode=OneWay, Converter={StaticResource DecimalFormat}}" />
                        </TextBlock>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{StaticResource CaptionTextBlockStyle}">
                            <Run Text="{x:Bind ViewModel.TotalTransacciones, Mode=OneWay}" />
                            <Run Text=" transacciones" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Card: Estado de caja -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="20" MinWidth="180">
                    <StackPanel Spacing="4">
                        <FontIcon Glyph="&#xE7EF;" FontSize="28"
                                  Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                        <TextBlock Text="Caja actual"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.CajaEstado, Mode=OneWay}"
                                   Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.CajaDescripcion, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Card: Bajo stock -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="20" MinWidth="180">
                    <StackPanel Spacing="4">
                        <FontIcon Glyph="&#xE8B9;" FontSize="28"
                                  Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                        <TextBlock Text="Bajo stock"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.BajoStock.Count, Mode=OneWay}"
                                   Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="productos críticos"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </ItemsControl>

            <!-- ── Últimas ventas ─────────────────────────────────────────── -->
            <TextBlock Text="Últimas ventas"
                       Style="{StaticResource SubtitleTextBlockStyle}" />

            <ListView ItemsSource="{x:Bind ViewModel.UltimasVentas, Mode=OneWay}"
                      SelectionMode="None"
                      MaxHeight="280">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,8" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center">
                                <Run Text="# " />
                                <Run Text="{Binding Id}" />
                            </TextBlock>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Fecha}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold">
                                <Run Text="$ " />
                                <Run Text="{Binding Total}" />
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- ── Productos con bajo stock ───────────────────────────────── -->
            <TextBlock Text="Productos con bajo stock"
                       Style="{StaticResource SubtitleTextBlockStyle}" />

            <ListView ItemsSource="{x:Bind ViewModel.BajoStock, Mode=OneWay}"
                      SelectionMode="None"
                      MaxHeight="280">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,8" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Vertical">
                                <TextBlock Text="{Binding ProductoNombre}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ProductoCodigo}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AlmacenNombre}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                       FontWeight="SemiBold">
                                <Run Text="{Binding Cantidad}" />
                                <Run Text=" uds." />
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollViewer>
</Page>
