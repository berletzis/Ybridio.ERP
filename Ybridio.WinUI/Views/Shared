<Window
    x:Class="Ybridio.WinUI.Views.Detached.DetachedDocumentWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window Detach Mode (ADR-028): Ventana OS real independiente para Document Surfaces.
         Esta ventana NO incluye:
         - Menú lateral ERP
         - Navegación principal
         - Tabs Workspace
         - Tabs módulo
         - Shell completo

         La ventana ES el workspace documento únicamente. -->

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <!-- Content inyectado dinámicamente via code-behind (Page del documento) -->
        <ContentPresenter x:Name="DocumentContent" />
    </Grid>
</Window>
