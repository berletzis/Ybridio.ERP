<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Configuracion.ConfiguracionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>

        <!-- ═══════════════════════════════════════════════════════════════════
             MODO GLOBAL — NavigationView vertical institucional
             Visible cuando el parámetro de navegación es "Global" o null.
             Estilo: Visual Studio Settings / Outlook Settings / ERP desktop moderno.
             ═══════════════════════════════════════════════════════════════════ -->

        <NavigationView x:Name="NavGlobal"
                        PaneDisplayMode="Left"
                        OpenPaneLength="220"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        Visibility="Collapsed"
                        SelectionChanged="NavGlobal_SelectionChanged">

            <NavigationView.MenuItems>

                <!-- ── Empresa ───────────────────────────────────────────── -->
                <NavigationViewItemHeader Content="EMPRESA"/>

                <NavigationViewItem Content="Empresa" Tag="empresa">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE731;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Sucursales" Tag="sucursales">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE73D;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- ── Configuración Operacional ─────────────────────────── -->
                <NavigationViewItemHeader Content="CONFIGURACIÓN"/>

                <NavigationViewItem Content="Parámetros" Tag="parametros">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Impuestos" Tag="impuestos">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Otros Cargos" Tag="otros-cargos">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8D6;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- ── Catálogos ─────────────────────────────────────────── -->
                <NavigationViewItemHeader Content="CATÁLOGOS"/>

                <NavigationViewItem Content="Unidades de Medida" Tag="unidades-medida">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8EF;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Tipos de Producto" Tag="tipos-producto">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE74C;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Series Documentales" Tag="series-documento">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7C3;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- ── Sistema ──────────────────────────────────────────── -->
                <NavigationViewItemHeader Content="SISTEMA"/>

                <NavigationViewItem Content="Workflow" Tag="workflow">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8AB;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Auditoría" Tag="auditoria">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Seguridad" Tag="seguridad">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE72E;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <!-- Área de contenido derecha — carga la página seleccionada -->
            <Frame x:Name="NavContentFrame"/>

        </NavigationView>

        <!-- ═══════════════════════════════════════════════════════════════════
             MODO TIENDA  (configuración específica de la sucursal activa)
             Visible cuando el parámetro de navegación es "Tienda".
             Mantiene layout de tabs horizontal para tabs de sucursal.
             ═══════════════════════════════════════════════════════════════════ -->

        <Border Padding="16,12,16,16"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                Visibility="Collapsed"
                x:Name="TiendaContainer">

            <TabView x:Name="TabsTienda"
                     TabWidthMode="SizeToContent"
                     IsAddTabButtonVisible="False"
                     Background="Transparent"
                     SelectionChanged="TiendaTabs_SelectionChanged">

                <TabViewItem x:Name="TabTiendaUsuarios" Header="Usuarios" IsClosable="False">
                    <Frame x:Name="FrameUsuariosTienda"/>
                </TabViewItem>

                <TabViewItem x:Name="TabTiendaCajas" Header="Cajas" IsClosable="False">
                    <Frame x:Name="FrameCajasTienda"/>
                </TabViewItem>

                <TabViewItem x:Name="TabTiendaDispositivos" Header="Dispositivos" IsClosable="False">
                    <Frame x:Name="FrameDispositivos"/>
                </TabViewItem>

                <TabViewItem x:Name="TabTiendaPromociones" Header="Promociones" IsClosable="False">
                    <Frame x:Name="FramePromociones"/>
                </TabViewItem>

                <TabViewItem x:Name="TabTiendaAlmacenes" Header="Almacenes" IsClosable="False">
                    <Frame x:Name="FrameAlmacenes"/>
                </TabViewItem>

                <TabViewItem x:Name="TabTiendaPermisos" Header="Permisos" IsClosable="False">
                    <Frame x:Name="FramePermisos"/>
                </TabViewItem>

                <TabViewItem x:Name="TabTiendaFacturacion" Header="Facturación" IsClosable="False">
                    <Frame x:Name="FrameFacturacion"/>
                </TabViewItem>

                <TabViewItem x:Name="TabTiendaPersonalizacion" Header="Personalización" IsClosable="False">
                    <Frame x:Name="FramePersonalizacion"/>
                </TabViewItem>

            </TabView>

        </Border>

    </Grid>
</Page>
