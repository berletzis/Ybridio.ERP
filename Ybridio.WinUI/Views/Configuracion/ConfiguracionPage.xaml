<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Configuracion.ConfiguracionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Aplica OutlookTabItemStyle a todos los TabViewItem de esta página (incluyendo anidados) -->
        <Style TargetType="TabViewItem" BasedOn="{StaticResource OutlookTabItemStyle}"/>
    </Page.Resources>

    <Grid>

        <!-- ═══════════════════════════════════════════════════════════════════
             MODO GLOBAL  (Empresa · Tiendas · Seguridad)
             Visible cuando el parámetro de navegación es "Global" o null.
             ═══════════════════════════════════════════════════════════════════ -->
        <TabView x:Name="TabsGlobal"
                 TabWidthMode="SizeToContent"
                 IsAddTabButtonVisible="False"
                 Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                 SelectionChanged="GlobalTabs_SelectionChanged">

            <!-- ── Empresa ──────────────────────────────────────────────── -->
            <TabViewItem x:Name="TabGlobalEmpresa" Header="Empresa" IsClosable="False">
                <Frame x:Name="FrameEmpresa"/>
            </TabViewItem>

            <!-- ── Tiendas ─────────────────────────────────────────────── -->
            <TabViewItem x:Name="TabGlobalTiendas" Header="Tiendas" IsClosable="False">
                <Frame x:Name="FrameTiendasGlobal"/>
            </TabViewItem>

            <!-- ── Auditoría del Sistema ──────────────────────────────── -->
            <TabViewItem x:Name="TabGlobalAuditoria" Header="Auditoría del Sistema" IsClosable="False">
                <Frame x:Name="FrameAuditoria"/>
            </TabViewItem>

            <!-- ── Seguridad (con sub-tabs propios) ───────────────────── -->
            <TabViewItem x:Name="TabGlobalSeguridad" Header="Seguridad" IsClosable="False">

                <TabView x:Name="TabsSeguridad"
                         TabWidthMode="SizeToContent"
                         IsAddTabButtonVisible="False"
                         Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                         SelectionChanged="SeguridadTabs_SelectionChanged">

                    <TabViewItem x:Name="TabUsuariosGlobal" Header="Usuarios" IsClosable="False">
                        <Frame x:Name="FrameUsuariosGlobal"/>
                    </TabViewItem>

                    <TabViewItem x:Name="TabRolesGlobal" Header="Roles" IsClosable="False">
                        <Frame x:Name="FrameRolesGlobal"/>
                    </TabViewItem>

                    <TabViewItem x:Name="TabPerfilesGlobal" Header="Perfiles" IsClosable="False">
                        <Frame x:Name="FramePerfilesGlobal"/>
                    </TabViewItem>

                </TabView>
            </TabViewItem>

        </TabView>

        <!-- ═══════════════════════════════════════════════════════════════════
             MODO TIENDA  (configuración específica de la sucursal activa)
             Visible cuando el parámetro de navegación es "Tienda".
             ═══════════════════════════════════════════════════════════════════ -->
        <TabView x:Name="TabsTienda"
                 TabWidthMode="SizeToContent"
                 IsAddTabButtonVisible="False"
                 Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                 Visibility="Collapsed"
                 SelectionChanged="TiendaTabs_SelectionChanged">

            <TabViewItem x:Name="TabTiendaUsuarios" Header="Usuarios" IsClosable="False">
                <Frame x:Name="FrameUsuariosTienda"/>
            </TabViewItem>

            <TabViewItem x:Name="TabTiendaCajas" Header="Cajas" IsClosable="False">
                <Frame x:Name="FrameCajasTienda"/>
            </TabViewItem>

            <TabViewItem x:Name="TabTiendaDispositivos" Header="Dispositivos" IsClosable="False">
                <Frame x:Name="FrameDispositivos"/>
            </TabViewItem>

            <TabViewItem x:Name="TabTiendaPromociones" Header="Promociones" IsClosable="False">
                <Frame x:Name="FramePromociones"/>
            </TabViewItem>

            <TabViewItem x:Name="TabTiendaAlmacenes" Header="Almacenes" IsClosable="False">
                <Frame x:Name="FrameAlmacenes"/>
            </TabViewItem>

            <TabViewItem x:Name="TabTiendaPermisos" Header="Permisos" IsClosable="False">
                <Frame x:Name="FramePermisos"/>
            </TabViewItem>

            <TabViewItem x:Name="TabTiendaFacturacion" Header="Facturación" IsClosable="False">
                <Frame x:Name="FrameFacturacion"/>
            </TabViewItem>

            <TabViewItem x:Name="TabTiendaPersonalizacion" Header="Personalización" IsClosable="False">
                <Frame x:Name="FramePersonalizacion"/>
            </TabViewItem>

        </TabView>

    </Grid>
</Page>
