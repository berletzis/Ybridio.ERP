<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Ybridio.WinUI.Views.Diagnostic.DiagnosticPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:diag="using:Ybridio.WinUI.Services.Diagnostic"
    xmlns:vm="using:Ybridio.WinUI.ViewModels.Diagnostic"
    mc:Ignorable="d">

    <Grid BorderBrush="#3E3E3E" BorderThickness="0,1,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── BARRA SUPERIOR ──────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Background="#252526">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Background="Transparent" BorderThickness="0"
                    Padding="10,0" Height="28"
                    Command="{x:Bind ViewModel.TogglePanelCommand}"
                    ToolTipService.ToolTip="Expandir / colapsar (Ctrl+Shift+D)">
                <TextBlock Text="{x:Bind ViewModel.ToggleArrow, Mode=OneWay}"
                           FontSize="10" Foreground="#0078D4"/>
            </Button>

            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        Visibility="{x:Bind ViewModel.TabStripVisibility, Mode=OneWay}">
                <Button x:Name="BtnTab0" Content="Contexto"    Tag="0" Click="DiagTab_Click"
                        Background="#1C1C1C" BorderBrush="#3E3E3E" BorderThickness="1,0,1,0"
                        Foreground="#D4D4D4" FontSize="11" Padding="10,0" Height="28" CornerRadius="0"/>
                <Button x:Name="BtnTab1" Content="Seguridad"   Tag="1" Click="DiagTab_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#858585" FontSize="11" Padding="10,0" Height="28" CornerRadius="0"/>
                <Button x:Name="BtnTab2" Content="Workspace"   Tag="2" Click="DiagTab_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#858585" FontSize="11" Padding="10,0" Height="28" CornerRadius="0"/>
                <Button x:Name="BtnTab3" Content="Filtros EF"  Tag="3" Click="DiagTab_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#858585" FontSize="11" Padding="10,0" Height="28" CornerRadius="0"/>
                <Button x:Name="BtnTab4" Content="Operacional" Tag="4" Click="DiagTab_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#858585" FontSize="11" Padding="10,0" Height="28" CornerRadius="0"/>
                <Button x:Name="BtnTab5" Content="Alertas"     Tag="5" Click="DiagTab_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#858585" FontSize="11" Padding="10,0" Height="28" CornerRadius="0"/>
            </StackPanel>

            <TextBlock Grid.Column="2"
                       Text="{x:Bind ViewModel.StatusBar, Mode=OneWay}"
                       Foreground="#858585" FontSize="11" FontFamily="Consolas"
                       VerticalAlignment="Center" Margin="12,0,8,0"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- ── CONTENIDO ─────────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      MaxHeight="280"
                      Visibility="{x:Bind ViewModel.ContentVisibility, Mode=OneWay}"
                      Background="#1C1C1C"
                      HorizontalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="12,8,12,12">

                <!-- TAB 0 — Contexto ───────────────────────────────────────── -->
                <StackPanel Visibility="{x:Bind ViewModel.Tab0Vis, Mode=OneWay}" Spacing="3">
                    <TextBlock Text="SESIÓN / CONTEXTO OPERACIONAL"
                               Foreground="#0078D4" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Estado"         Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.CtxAuthenticated,  Mode=OneWay}" Foreground="#4EC9B0" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Usuario"        Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.CtxUsuarioNombre,  Mode=OneWay}" Foreground="#D4D4D4" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="UserName"       Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.CtxUsuarioUser,    Mode=OneWay}" Foreground="#9CDCFE" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Email"          Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.CtxUsuarioEmail,   Mode=OneWay}" Foreground="#D4D4D4" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="GUID"           Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.CtxUsuarioId,      Mode=OneWay}" Foreground="#858585" FontFamily="Consolas" FontSize="10"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="EmpresaId"      Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{x:Bind ViewModel.CtxEmpresaId,      Mode=OneWay}" Foreground="#DCDCAA" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="SucursalId"     Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{x:Bind ViewModel.CtxSucursalId,     Mode=OneWay}" Foreground="#DCDCAA" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Sucursal"       Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{x:Bind ViewModel.CtxSucursalNombre, Mode=OneWay}" Foreground="#D4D4D4" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Caja"           Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{x:Bind ViewModel.CtxCaja,           Mode=OneWay}" Foreground="#D4D4D4" FontFamily="Consolas" FontSize="11"/>
                    </Grid>
                </StackPanel>

                <!-- TAB 1 — Seguridad ──────────────────────────────────────── -->
                <StackPanel Visibility="{x:Bind ViewModel.Tab1Vis, Mode=OneWay}" Spacing="3">
                    <TextBlock Text="CONTEXTO DE SEGURIDAD RUNTIME"
                               Foreground="#0078D4" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Sesión"            Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.SecAuthenticated,   Mode=OneWay}" Foreground="#4EC9B0" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Contexto Empresa"  Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.SecEmpresaContext,  Mode=OneWay}" Foreground="#DCDCAA" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Contexto Sucursal" Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.SecSucursalContext, Mode=OneWay}" Foreground="#DCDCAA" FontFamily="Consolas" FontSize="11"/>
                    </Grid>
                    <Border Margin="0,8,0,0" Padding="8,6" CornerRadius="4" Background="#2A2A2A" BorderBrush="#3E3E3E" BorderThickness="1">
                        <TextBlock Foreground="#9CDCFE" FontSize="11" TextWrapping="Wrap">
                            <Run Text="ℹ Para mostrar roles runtime, integrar IReadOnlyList&lt;string&gt; Roles"/>
                            <LineBreak/>
                            <Run Text="  en UsuarioDto y poblarlo desde UserManager en LoginViewModel."/>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- TAB 2 — Workspace ──────────────────────────────────────── -->
                <StackPanel Visibility="{x:Bind ViewModel.Tab2Vis, Mode=OneWay}" Spacing="3">

                    <!-- MÓDULOS ABIERTOS EN SESIÓN (desde navigation history) -->
                    <TextBlock Text="MÓDULOS ABIERTOS EN SESIÓN"
                               Foreground="#0078D4" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Módulos abiertos" Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.WsTabCount,       Mode=OneWay}" Foreground="#DCDCAA" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Módulo activo"    Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.WsActiveTitle,    Mode=OneWay}" Foreground="#4EC9B0" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Sub-módulo activo" Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.WsActiveSubModule,Mode=OneWay}" Foreground="#4EC9B0" FontFamily="Consolas" FontSize="11"/>
                    </Grid>

                    <!-- Historial de navegación de módulos -->
                    <TextBlock Text="HISTORIAL DE NAVEGACIÓN" Foreground="#0078D4" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,4"/>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.NavigationHistory, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="diag:ModuleNavigationEntry">
                                <Grid ColumnSpacing="8" Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="▸" Foreground="#0078D4" FontSize="10" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Display}"    FontFamily="Consolas" FontSize="11" Foreground="#D4D4D4"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind AgeDisplay}" FontFamily="Consolas" FontSize="10" Foreground="#858585" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Separador -->
                    <Border Height="1" Background="#3E3E3E" Margin="0,8,0,4"/>

                    <!-- WORKSPACE SERVICE (persistent workspace items) -->
                    <TextBlock Text="WORKSPACE SERVICE — Ítems Persistentes"
                               Foreground="#858585" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Workspace items" Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.WsPersistentTabCount, Mode=OneWay}" Foreground="#858585" FontFamily="Consolas" FontSize="11"/>
                    </Grid>
                    <Border Padding="8,6" CornerRadius="4" Background="#2A2A2A" BorderBrush="#3E3E3E" BorderThickness="1">
                        <TextBlock Foreground="#858585" FontSize="11" TextWrapping="Wrap">
                            <Run Text="ℹ Workspace items son documentos persistentes abiertos (e.g. Venta #502, Producto específico)."/>
                            <LineBreak/>
                            <Run Text="  Actualmente 0 — los módulos del sidebar navegan vía ModuleFrame (no WorkspaceService)."/>
                        </TextBlock>
                    </Border>

                    <!-- Workspace items persistentes si los hay -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.WsPersistentTabs, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:WorkspaceTabDisplay">
                                <Grid ColumnSpacing="8" Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="▸" Foreground="#555" FontSize="10" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Title}" FontSize="11" Foreground="#D4D4D4"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind Age}"   FontFamily="Consolas" FontSize="10" Foreground="#858585" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                </StackPanel>

                <!-- TAB 3 — Filtros EF ─────────────────────────────────────── -->
                <StackPanel Visibility="{x:Bind ViewModel.Tab3Vis, Mode=OneWay}" Spacing="3">
                    <TextBlock Text="FILTROS GLOBALES EF CORE"
                               Foreground="#0078D4" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Soft-delete"        Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.FilterSoftDelete, Mode=OneWay}" Foreground="#4EC9B0" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="EmpresaId"           Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.FilterEmpresa,    Mode=OneWay}" Foreground="#4EC9B0" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="SucursalId (servicio)" Foreground="#858585" FontSize="11"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.FilterSucursal,   Mode=OneWay}" Foreground="#4EC9B0" FontFamily="Consolas" FontSize="11"/>
                    </Grid>
                    <Border Margin="0,8,0,0" Padding="8,6" CornerRadius="4" Background="#2A2A2A" BorderBrush="#3E3E3E" BorderThickness="1">
                        <TextBlock Foreground="#9CDCFE" FontSize="11" TextWrapping="Wrap">
                            <Run Text="ℹ EmpresaId + !Borrado → HasQueryFilter() en ErpDbContext (automático)."/>
                            <LineBreak/>
                            <Run Text="  SucursalId → filtrado a nivel Application service."/>
                            <LineBreak/>
                            <Run Text="  Ver Tab Operacional para filtros reales de la última consulta."/>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- TAB 4 — Operacional ────────────────────────────────────── -->
                <StackPanel Visibility="{x:Bind ViewModel.Tab4Vis, Mode=OneWay}" Spacing="3">

                    <!-- ── CURRENT CONTEXT (siempre presente cuando hay módulo activo) ── -->
                    <TextBlock Text="CURRENT CONTEXT — Activo Ahora"
                               Foreground="#0078D4" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>

                    <!-- Sin contexto aún -->
                    <Border Visibility="{x:Bind ViewModel.NoCtxVisibility, Mode=OneWay}"
                            Padding="8,6" CornerRadius="4" Background="#2A2A2A" BorderBrush="#3E3E3E" BorderThickness="1">
                        <TextBlock Text="ℹ Sin contexto activo. Navega a un módulo para ver el contexto operacional."
                                   Foreground="#9CDCFE" FontSize="11" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Contexto parcial (módulo sin ViewModel aún) -->
                    <Border Visibility="{x:Bind ViewModel.CtxPartialVisibility, Mode=OneWay}"
                            Padding="8,6" CornerRadius="4" Background="#2A2A2A" BorderBrush="#3E3E3E" BorderThickness="1">
                        <StackPanel Spacing="2">
                            <TextBlock Foreground="#DCDCAA" FontFamily="Consolas" FontSize="12">
                                <Run Text="{x:Bind ViewModel.CurModule, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text=" — esperando ViewModel..."/>
                            </TextBlock>
                            <TextBlock Text="Navega a un sub-módulo para ver el contexto completo." Foreground="#858585" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <!-- Contexto completo (ViewModel activo con datos) -->
                    <StackPanel Visibility="{x:Bind ViewModel.CtxActiveVisibility, Mode=OneWay}" Spacing="3">
                        <Border Padding="8,6" CornerRadius="4" Background="#1A2A1A" BorderBrush="#2A4A2A" BorderThickness="1">
                            <StackPanel Spacing="2">
                                <TextBlock Foreground="#4EC9B0" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold">
                                    <Run Text="{x:Bind ViewModel.CurModule, Mode=OneWay}"/>
                                    <Run Text=" › "/>
                                    <Run Text="{x:Bind ViewModel.CurSubModule, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Foreground="#9CDCFE" FontFamily="Consolas" FontSize="11"
                                           Text="{x:Bind ViewModel.CurViewModel, Mode=OneWay}"/>
                                <TextBlock Foreground="#CE9178" FontFamily="Consolas" FontSize="10"
                                           Text="{x:Bind ViewModel.CurEntity, Mode=OneWay}"/>
                                <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,2,0,0">
                                    <TextBlock Foreground="#4EC9B0" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"
                                               Text="{x:Bind ViewModel.CurRecords, Mode=OneWay}"/>
                                    <TextBlock Foreground="#858585" FontFamily="Consolas" FontSize="10"
                                               Text="{x:Bind ViewModel.CurAge, Mode=OneWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="EmpresaId"    Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.CurFilterEmpresa,    Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="#D4D4D4"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="SucursalId"   Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.CurFilterSucursal,   Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="#D4D4D4"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="AlmacenId"    Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.CurFilterAlmacen,    Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="#D4D4D4"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="SoftDelete"   Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.CurFilterSoftDelete, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="#D4D4D4"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Búsqueda"     Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.CurSearch,           Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="#D4D4D4"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Solo activos" Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{x:Bind ViewModel.CurSoloActivos,      Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="#D4D4D4"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Categoría"    Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{x:Bind ViewModel.CurCategoria,        Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="#D4D4D4"/>
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Período"      Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{x:Bind ViewModel.CurFiltroTemp,       Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="#D4D4D4"/>
                        </Grid>
                    </StackPanel>

                    <!-- Separador entre Current Context y Last Operation -->
                    <Border Height="1" Background="#3E3E3E" Margin="0,8,0,4"/>

                    <!-- ── LAST OPERATION ──────────────────────────────────── -->
                    <!-- Sin operaciones aún -->
                    <Border Visibility="{x:Bind ViewModel.NoOpVisibility, Mode=OneWay}"
                            Padding="8,6" CornerRadius="4" Background="#2A2A2A" BorderBrush="#3E3E3E" BorderThickness="1">
                        <TextBlock Text="ℹ Sin operaciones registradas. Las queries se registran en RefrescarAsync de cada módulo."
                                   Foreground="#9CDCFE" FontSize="11" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Última operación -->
                    <StackPanel Visibility="{x:Bind ViewModel.OpPanelVisibility, Mode=OneWay}" Spacing="3">
                        <TextBlock Text="LAST OPERATION — Última Query Ejecutada"
                                   Foreground="#858585" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Módulo"     Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.OpModule,    Mode=OneWay}" Foreground="#DCDCAA" FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="SubMódulo"  Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.OpSubModule, Mode=OneWay}" Foreground="#DCDCAA" FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="ViewModel"  Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.OpViewModel, Mode=OneWay}" Foreground="#9CDCFE" FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Entidad"    Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.OpEntity,    Mode=OneWay}" Foreground="#CE9178" FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Registros"  Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.OpRecords,   Mode=OneWay}" Foreground="#4EC9B0" FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Duración"   Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{x:Bind ViewModel.OpDuration,  Mode=OneWay}" Foreground="#4EC9B0" FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Timestamp"  Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{x:Bind ViewModel.OpTimestamp, Mode=OneWay}" Foreground="#858585" FontFamily="Consolas" FontSize="11"/>
                        </Grid>

                        <TextBlock Text="FILTROS OPERACIONALES APLICADOS"
                                   Foreground="#0078D4" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,4"/>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="EmpresaId"    Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.OpFilterEmpresa,    Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="#D4D4D4"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="SucursalId"   Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.OpFilterSucursal,   Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="#D4D4D4"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="AlmacenId"    Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.OpFilterAlmacen,    Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="#D4D4D4"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="SoftDelete"   Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.OpFilterSoftDelete, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="#D4D4D4"/>
                        </Grid>

                        <TextBlock Text="CONTROLES ACTIVOS"
                                   Foreground="#0078D4" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,4"/>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Búsqueda"    Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.OpSearch,      Mode=OneWay}" Foreground="#D4D4D4" FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Solo activos" Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.OpSoloActivos, Mode=OneWay}" Foreground="#D4D4D4" FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Categoría"   Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.OpCategoria,   Mode=OneWay}" Foreground="#D4D4D4" FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Período"     Foreground="#858585" FontSize="11"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.OpFiltroTemp,  Mode=OneWay}" Foreground="#D4D4D4" FontFamily="Consolas" FontSize="11"/>
                        </Grid>

                        <!-- Historial de operaciones recientes -->
                        <TextBlock Text="HISTORIAL RECIENTE"
                                   Foreground="#0078D4" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,4"/>
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.RecentOps, Mode=OneWay}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="diag:GridOperationContext">
                                    <Grid ColumnSpacing="8" Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="65"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="65"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind TimeDisplay}"     FontFamily="Consolas" FontSize="10" Foreground="#858585"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind SubModule}"    FontFamily="Consolas" FontSize="10" Foreground="#9CDCFE"/>
                                        <TextBlock Grid.Column="2" Text="{x:Bind RecordCount}"  FontFamily="Consolas" FontSize="10" Foreground="#4EC9B0" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="3" Text="{x:Bind DurationDisplay}" FontFamily="Consolas" FontSize="10" Foreground="#858585" HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </StackPanel>

                <!-- TAB 5 — Alertas ────────────────────────────────────────── -->
                <StackPanel Visibility="{x:Bind ViewModel.Tab5Vis, Mode=OneWay}" Spacing="3">
                    <TextBlock Text="{x:Bind ViewModel.AlertCount, Mode=OneWay}"
                               Foreground="#0078D4" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Alerts, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="diag:DiagnosticAlert">
                                <Border Margin="0,2" Padding="8,4" CornerRadius="3" Background="#252526">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind Icon}"    FontSize="12" VerticalAlignment="Center" Foreground="#D4D4D4"/>
                                        <TextBlock Text="{x:Bind Message}" FontSize="11" Foreground="#D4D4D4" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
