<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ybridio.WinUI.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="380">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!-- Logo / Título -->
		<StackPanel Grid.Row="0" Margin="0,0,0,32" HorizontalAlignment="Center">
			<FontIcon Glyph="&#xEA3A;" FontSize="48" />
			<TextBlock Text="Ybridio ERP"
                       Style="{StaticResource TitleLargeTextBlockStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,4" />
			<TextBlock Text="Inicia sesión para continuar"
                       Style="{StaticResource BodyTextBlockStyle}"
                       HorizontalAlignment="Center" />
		</StackPanel>

		<!-- Email -->
		<TextBox Grid.Row="1"
                 Header="Correo electrónico"
                 PlaceholderText="usuario@empresa.com"
                 Text="{x:Bind ViewModel.Email, Mode=TwoWay}"
                 Margin="0,0,0,16" />

		<!-- Contraseña -->
		<PasswordBox Grid.Row="2"
                     Header="Contraseña"
                     PlaceholderText="••••••••"
                     Margin="0,0,0,24"
                     PasswordChanged="PasswordBox_PasswordChanged" />

		<!-- Error -->
		<TextBlock Grid.Row="3"
                   Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                   Foreground="Red"
                   Margin="0,0,0,16" />

		<!-- Botón -->
		<Button Grid.Row="4"
                Content="Iniciar sesión"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.LoginCommand}" />

		<!-- Progreso -->
		<ProgressBar Grid.Row="5"
                     IsIndeterminate="True"
                     Visibility="Collapsed"
                     Margin="0,16,0,0" />
	</Grid>
</Page>