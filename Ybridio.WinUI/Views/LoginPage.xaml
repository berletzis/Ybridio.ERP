<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ybridio.WinUI.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="380">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Logo / Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,32" HorizontalAlignment="Center">
            <FontIcon Glyph="&#xE7EE;" FontSize="48" Foreground="{ThemeResource AccentAAFillColorDefaultBrush}" />
            <TextBlock Text="Ybridio ERP"
                       Style="{StaticResource TitleLargeTextBlockStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,4" />
            <TextBlock Text="Inicia sesión para continuar"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Email -->
        <TextBox Grid.Row="1"
                 Header="Correo electrónico"
                 PlaceholderText="usuario@empresa.com"
                 Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,16"
                 IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolNegation}}" />

        <!-- Contraseña -->
        <PasswordBox Grid.Row="2"
                     Header="Contraseña"
                     PlaceholderText="••••••••"
                     Password="{x:Bind ViewModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,24"
                     IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolNegation}}" />

        <!-- Error -->
        <InfoBar Grid.Row="3"
                 IsOpen="{x:Bind ViewModel.ErrorMessage.Length, Mode=OneWay, Converter={StaticResource IntToBool}}"
                 Severity="Error"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                 IsClosable="False"
                 Margin="0,0,0,16" />

        <!-- Botón -->
        <Button Grid.Row="4"
                Content="Iniciar sesión"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.LoginCommand}"
                Style="{StaticResource AccentButtonStyle}" />

        <!-- Progreso -->
        <ProgressBar Grid.Row="5"
                     IsIndeterminate="True"
                     Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                     Margin="0,16,0,0" />
    </Grid>
</Page>
