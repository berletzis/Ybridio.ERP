<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Ventas.PedidoDocumentoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:Ybridio.WinUI.ViewModels.Ventas"
      xmlns:dto="using:Ybridio.Application.DTOs.Ventas"
      xmlns:selector="using:Ybridio.WinUI.Controls.Selector"
      xmlns:conv="using:Ybridio.WinUI.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:EstatusPedidoToBgBrushConverter              x:Key="EstatusBgConverter"/>
        <conv:EstatusPedidoToFgBrushConverter              x:Key="EstatusFgConverter"/>
        <conv:EstadoFinancieroPedidoToBgBrushConverter     x:Key="FinBgConverter"/>
        <conv:EstadoFinancieroPedidoToFgBrushConverter     x:Key="FinFgConverter"/>
        <conv:DecimalToCurrencyConverter                    x:Key="CurrencyConverter"/>
        <conv:BoolToVisibilityConverter                     x:Key="BoolToVisibility"/>
        <conv:InverseBoolToVisibilityConverter              x:Key="InverseBoolToVisibility"/>
        <conv:OperationalDateConverter                      x:Key="OperationalDateConverter"/>
        <conv:BoolToSiNoConverter                           x:Key="BoolToSiNo"/>
    </Page.Resources>

    <!--
        Single Document Scroll Pattern (ADR-055) — equivalente a CotizacionDocumentoPage.
        Row 0: CommandBar (Auto) — fijo, siempre visible
        Row 1: ScrollViewer (*) — ÚNICO dueño del scroll documental
        Row 1: ScrollViewer (*) — scroll único; StatusBar integrado al final del contenido
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ════════ ROW 0: CommandBar ════════ -->
        <Border Grid.Row="0" Style="{StaticResource ErpOperationalCommandSurfaceStyle}">
            <CommandBar Style="{StaticResource ErpDocumentCommandBarStyle}"
                        Margin="4,0,0,0"
                        OverflowButtonVisibility="Collapsed">

                <!-- Navegación: visible solo en modo INLINE -->
                <AppBarButton x:Name="BtnVolverALista" Label="Volver a Lista"
                              Click="BtnVolverALista_Click" Visibility="Collapsed">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE72B;"/></AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator x:Name="SepInlineActions" Visibility="Collapsed"/>

                <!-- Grupo 1: Persistencia -->
                <AppBarButton Label="Guardar"
                              IsEnabled="{x:Bind ViewModel.PuedeEditar, Mode=OneWay}"
                              Command="{x:Bind ViewModel.GuardarCommand}">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE74E;"/></AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator/>

                <!-- Grupo 2: Edición de líneas — bloqueado en EnProceso/Parcial/Finalizado/Cancelado -->
                <AppBarButton Label="Agregar Línea"
                              IsEnabled="{x:Bind ViewModel.PuedeEditarLineas, Mode=OneWay}"
                              Click="BtnAgregarLinea_Click">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE710;"/></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Eliminar Línea"
                              IsEnabled="{x:Bind ViewModel.PuedeEditarLineas, Mode=OneWay}"
                              Command="{x:Bind ViewModel.EliminarDetalleCommand}">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE74D;"/></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Agregar Cargo"
                              IsEnabled="{x:Bind ViewModel.PuedeEditarLineas, Mode=OneWay}"
                              Command="{x:Bind ViewModel.AgregarCargoCommand}">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE8EC;"/></AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator/>

                <!-- Grupo 3: Workflow contextual (MenuFlyout dinámico) -->
                <AppBarButton x:Name="BtnWorkflow" Label="Workflow"
                              IsEnabled="{x:Bind ViewModel.PuedeAvanzar, Mode=OneWay}"
                              Click="BtnWorkflow_Click">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE7C4;"/></AppBarButton.Icon>
                    <AppBarButton.Flyout>
                        <MenuFlyout x:Name="WorkflowFlyout" Opening="WorkflowFlyout_Opening"/>
                    </AppBarButton.Flyout>
                </AppBarButton>

                <!-- Grupo 4: Generación de documentos -->
                <AppBarButton Label="Generar Venta"
                              IsEnabled="{x:Bind ViewModel.PuedeGenerarVenta, Mode=OneWay}"
                              Click="BtnGenerarVenta_Click">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE8C8;"/></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Generar OT"
                              IsEnabled="{x:Bind ViewModel.PuedeGenerarOT, Mode=OneWay}"
                              Click="BtnGenerarOT_Click">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE8F1;"/></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Cancelar Pedido"
                              IsEnabled="{x:Bind ViewModel.PuedeCancelar, Mode=OneWay}"
                              Click="BtnCancelarPedido_Click">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE711;"/></AppBarButton.Icon>
                </AppBarButton>

                <!-- Workspace: Abrir en ventana — visible solo en modo INLINE (ADR-039) -->
                <AppBarSeparator x:Name="SepVentana" Visibility="Collapsed"/>
                <AppBarButton x:Name="BtnAbrirEnVentana" Label="Abrir en ventana"
                              Click="BtnAbrirEnVentana_Click" Visibility="Collapsed">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE8A7;"/></AppBarButton.Icon>
                </AppBarButton>
            </CommandBar>
        </Border>

        <!-- ════════ ROW 1: ScrollViewer — ÚNICO dueño del scroll ════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header strip: título + badge estado -->
                    <RowDefinition Height="Auto"/>  <!-- Formulario encabezado -->
                    <RowDefinition Height="Auto"/>  <!-- Líneas de producto -->
                    <RowDefinition Height="Auto"/>  <!-- Otros Cargos -->
                    <RowDefinition Height="Auto"/>  <!-- Totales -->
                    <RowDefinition Height="Auto"/>  <!-- Sección Financiera — Anticipos (ADR-065) -->
                    <RowDefinition Height="Auto"/>  <!-- StatusBar — al pie de totales -->
                </Grid.RowDefinitions>

                <!-- ── Header institucional — SIEMPRE visible.
                     Muestra folio documental + badge de estado. Patrón idéntico a CotizacionDocumentoPage.
                     Navegación inline vía CommandBar BtnVolverALista (se oculta cuando no es inline mode). -->
                <Border x:Name="HeaderStrip"
                        Grid.Row="0"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="#E5E5E5" BorderThickness="0,0,0,1"
                        Padding="{StaticResource ErpDocumentHeaderPadding}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{x:Bind ViewModel.TituloDocumento, Mode=OneWay}"
                                   FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Border Background="{x:Bind ViewModel.Estatus, Mode=OneWay, Converter={StaticResource EstatusBgConverter}}"
                                CornerRadius="4" Padding="8,2,8,2" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.EstatusTextoDisplay, Mode=OneWay}"
                                       Foreground="{x:Bind ViewModel.Estatus, Mode=OneWay, Converter={StaticResource EstatusFgConverter}}"
                                       FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── Formulario encabezado ── -->
                <Border Grid.Row="1" Style="{StaticResource ErpOperationalCardStyle}"
                        Padding="20,16,20,16">
                    <Grid ColumnSpacing="16" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Col 0, Row 0: Cliente -->
                        <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                            <TextBlock Text="Cliente *" FontWeight="SemiBold" FontSize="12"/>
                            <selector:RelacionComercialSelectorControl
                                x:Name="SelectorCliente"
                                PlaceholderText="Buscar socio comercial por nombre, RFC o email..."
                                EmpresaId="{x:Bind ViewModel.EmpresaId, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.PuedeEditarCliente, Mode=OneWay}"
                                SelectionChanged="SelectorCliente_SelectionChanged"/>
                        </StackPanel>

                        <!-- Col 1, Row 0: Observaciones -->
                        <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4">
                            <TextBlock Text="Observaciones" FontWeight="SemiBold" FontSize="12"/>
                            <TextBox PlaceholderText="Observaciones"
                                     Text="{x:Bind ViewModel.Observaciones, Mode=TwoWay}"
                                     IsEnabled="{x:Bind ViewModel.PuedeEditar, Mode=OneWay}"/>
                        </StackPanel>

                        <!-- Col 0, Row 1: Info cliente seleccionado -->
                        <Border Grid.Column="0" Grid.Row="1"
                                Background="#F8F8F8" BorderBrush="#E5E5E5" BorderThickness="1"
                                CornerRadius="4" Padding="10,8"
                                Visibility="{x:Bind ViewModel.TieneClienteSeleccionado, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Email" FontSize="10"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.ClienteEmail, Mode=OneWay}"
                                               FontSize="12" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Teléfono" FontSize="10"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.ClienteTelefono, Mode=OneWay}" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Col 1, Row 1: Descuento Global -->
                        <Border Grid.Column="1" Grid.Row="1"
                                Background="#F8F8F8" BorderBrush="#E5E5E5" BorderThickness="1"
                                CornerRadius="4" Padding="10,8">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Descuento Global (%)" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Text="Se aplica a todas las líneas" TextWrapping="Wrap"/>
                                </StackPanel>
                                <NumberBox Grid.Column="1"
                                           x:Name="NbDescuentoGlobal"
                                           Value="{x:Bind ViewModel.DescuentoGlobalPctDouble, Mode=OneWay}"
                                           Minimum="0" Maximum="100" SmallChange="1" LargeChange="5"
                                           SpinButtonPlacementMode="Compact"
                                           PlaceholderText="0 %"
                                           HorizontalContentAlignment="Right"
                                           VerticalAlignment="Center"
                                           IsEnabled="{x:Bind ViewModel.PuedeEditarDescuentoGlobal, Mode=OneWay}"
                                           ValueChanged="NbDescuentoGlobal_ValueChanged"/>
                            </Grid>
                        </Border>

                        <!-- Col 0, Row 2: Fechas -->
                        <StackPanel Grid.Column="0" Grid.Row="2" Orientation="Horizontal" Spacing="24">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Fecha" FontWeight="SemiBold" FontSize="12"/>
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <CalendarDatePicker x:Name="DpFecha"
                                                       Date="{x:Bind ViewModel.FechaOffset, Mode=OneWay}"
                                                       DateChanged="DpFecha_DateChanged"
                                                       PlaceholderText="Seleccionar"
                                                       IsEnabled="{x:Bind ViewModel.PuedeEditar, Mode=OneWay}"/>
                                    <TextBlock Text="{x:Bind ViewModel.FechaOffset, Mode=OneWay, Converter={StaticResource OperationalDateConverter}}"
                                               VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Entrega Compromiso" FontWeight="SemiBold" FontSize="12"/>
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <CalendarDatePicker x:Name="DpEntrega"
                                                       Date="{x:Bind ViewModel.FechaEntregaCompromisoOffset, Mode=OneWay}"
                                                       DateChanged="DpEntrega_DateChanged"
                                                       PlaceholderText="Seleccionar"
                                                       IsEnabled="{x:Bind ViewModel.PuedeEditar, Mode=OneWay}"/>
                                    <TextBlock Text="{x:Bind ViewModel.FechaEntregaCompromisoOffset, Mode=OneWay, Converter={StaticResource OperationalDateConverter}}"
                                               VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Líneas de producto (Dynamic Operational Grid Growth Rule) ── -->
                <Border Grid.Row="2" Style="{StaticResource ErpOperationalCardStyle}">
                    <Grid>
                        <ListView Style="{StaticResource OutlookDataGridStyle}"
                                  ItemsSource="{x:Bind ViewModel.Detalles, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.DetalleSeleccionado, Mode=TwoWay}"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollMode="Disabled">
                            <ListView.Header>
                                <Border Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                                    <Grid Padding="{StaticResource ErpHeaderPadding}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="SKU"             Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                        <TextBlock Grid.Column="2" Text="Descripción"     Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                        <TextBlock Grid.Column="3" Text="Cantidad"        Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="4" Text="Desc. %"         Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="5" Text="IVA"             Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="6" Text="Precio Unit."    Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="7" Text="Importe Neto"    Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:DetalleLineaEditable">
                                    <Grid Height="{StaticResource ErpRowHeight}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Sku}"
                                                   Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center"
                                                   FontSize="11"/>
                                        <TextBlock Grid.Column="2" Text="{x:Bind Descripcion}"
                                                   Style="{StaticResource ErpCellPrimaryStyle}" VerticalAlignment="Center"/>
                                        <!-- Cantidad editable — bloqueada cuando Pedido no es Borrador/Autorizado -->
                                        <NumberBox Grid.Column="3"
                                                   Value="{x:Bind CantidadDouble, Mode=TwoWay}"
                                                   Minimum="0" SpinButtonPlacementMode="Hidden"
                                                   HorizontalContentAlignment="Right"
                                                   IsEnabled="{x:Bind PuedeEditar, Mode=OneWay}"
                                                   Tag="{x:Bind}"
                                                   ValueChanged="NumberBox_Cantidad_ValueChanged"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                        <!-- Descuento % editable — bloqueado cuando Pedido no es Borrador/Autorizado -->
                                        <NumberBox Grid.Column="4"
                                                   Value="{x:Bind DescuentoPctDouble, Mode=OneWay}"
                                                   Minimum="0" Maximum="100" SpinButtonPlacementMode="Hidden"
                                                   HorizontalContentAlignment="Right"
                                                   IsEnabled="{x:Bind PuedeEditar, Mode=OneWay}"
                                                   Tag="{x:Bind}"
                                                   ValueChanged="NumberBox_Descuento_ValueChanged"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                        <!-- IVA: muestra "Sí"/"No" via BoolToSiNoConverter -->
                                        <TextBlock Grid.Column="5"
                                                   Text="{x:Bind IvaAplicable, Mode=OneWay, Converter={StaticResource BoolToSiNo}}"
                                                   FontSize="11" TextAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="6"
                                                   Text="{x:Bind PrecioUnitario, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                                   Style="{StaticResource ErpCellSecondaryStyle}"
                                                   TextAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="7"
                                                   Text="{x:Bind Importe, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                                   Style="{StaticResource ErpCellPrimaryStyle}"
                                                   TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                                      Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ── Otros Cargos (Commercial Charges Pattern) ── -->
                <Border Grid.Row="3" Style="{StaticResource ErpOperationalCardStyle}"
                        Visibility="{x:Bind ViewModel.HayCargos, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Otros Cargos"
                                   FontWeight="SemiBold" FontSize="13"
                                   Margin="12,8,12,4"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <ListView Grid.Row="1"
                                  ItemsSource="{x:Bind ViewModel.Cargos, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.CargoSeleccionado, Mode=TwoWay}"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollMode="Disabled">
                            <ListView.Header>
                                <Border Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                                    <Grid Padding="{StaticResource ErpHeaderPadding}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="Descripción" Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                        <TextBlock Grid.Column="2" Text="IVA"         Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="Importe"     Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:CargoLineaEditable">
                                    <Grid Height="{StaticResource ErpRowHeight}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Descripcion}"
                                                   Style="{StaticResource ErpCellPrimaryStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind AplicaIva, Converter={StaticResource BoolToSiNo}}"
                                                   FontSize="11" TextAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{x:Bind Importe, Converter={StaticResource CurrencyConverter}}"
                                                   Style="{StaticResource ErpCellPrimaryStyle}"
                                                   TextAlignment="Right" VerticalAlignment="Center"/>
                                        <Button Grid.Column="4"
                                                Style="{StaticResource ErpActionButtonStyle}"
                                                Content="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="12"
                                                IsEnabled="{x:Bind PuedeEditar, Mode=OneWay}"
                                                Tag="{x:Bind}"
                                                Click="BtnEliminarCargo_Click"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- ── Totales ── -->
                <Border Grid.Row="4" Style="{StaticResource ErpTotalesCardStyle}">
                    <Grid HorizontalAlignment="Right" MinWidth="320" RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Grid.Row="0" Text="Subtotal sin descuentos:"
                                   Style="{StaticResource ErpCellSecondaryStyle}"
                                   Visibility="{x:Bind ViewModel.HayDescuento, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Grid.Column="1" Grid.Row="0"
                                   Text="{x:Bind ViewModel.SubtotalBruto, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                   Style="{StaticResource ErpCellSecondaryStyle}" TextAlignment="Right"
                                   Visibility="{x:Bind ViewModel.HayDescuento, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                        <TextBlock Grid.Column="0" Grid.Row="1" Text="(-) Descuento:"
                                   Style="{StaticResource ErpCellSecondaryStyle}"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                   Visibility="{x:Bind ViewModel.HayDescuento, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Grid.Column="1" Grid.Row="1"
                                   Text="{x:Bind ViewModel.DescuentoTotal, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                   Style="{StaticResource ErpCellSecondaryStyle}" TextAlignment="Right"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                   Visibility="{x:Bind ViewModel.HayDescuento, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                        <TextBlock Grid.Column="0" Grid.Row="2" Text="Subtotal:"
                                   Style="{StaticResource ErpCellSecondaryStyle}"/>
                        <TextBlock Grid.Column="1" Grid.Row="2"
                                   Text="{x:Bind ViewModel.Subtotal, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                   Style="{StaticResource ErpCellSecondaryStyle}" TextAlignment="Right"/>

                        <TextBlock Grid.Column="0" Grid.Row="3" Text="(+) Otros Cargos:"
                                   Style="{StaticResource ErpCellSecondaryStyle}"
                                   Visibility="{x:Bind ViewModel.HayCargos, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Grid.Column="1" Grid.Row="3"
                                   Text="{x:Bind ViewModel.TotalOtrosCargos, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                   Style="{StaticResource ErpCellSecondaryStyle}" TextAlignment="Right"
                                   Visibility="{x:Bind ViewModel.HayCargos, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                        <TextBlock Grid.Column="0" Grid.Row="4" Text="Impuestos (IVA):"
                                   Style="{StaticResource ErpCellSecondaryStyle}"/>
                        <TextBlock Grid.Column="1" Grid.Row="4"
                                   Text="{x:Bind ViewModel.Impuestos, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                   Style="{StaticResource ErpCellSecondaryStyle}" TextAlignment="Right"/>

                        <TextBlock Grid.Column="0" Grid.Row="5" Text="Total:"
                                   FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Grid.Column="1" Grid.Row="5"
                                   Text="{x:Bind ViewModel.Total, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                   FontWeight="SemiBold" FontSize="14" TextAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- ════════════════════════════════════════════════════════════════
                     ROW 5: DIMENSIÓN FINANCIERA — Estado + Historial (ADR-065)
                     Bloque independiente del workflow comercial.
                     ════════════════════════════════════════════════════════════════ -->
                <!-- ErpOperationalCardStyle aplica Margin="20,8,20,0" — mismo que bloques superiores.
                     NO sobreescribir Margin para mantener alineación institucional. -->
                <Border Grid.Row="5" Style="{StaticResource ErpOperationalCardStyle}">
                    <StackPanel>

                        <!-- ── Header: Estado Financiero + botón Registrar Pago ── -->
                        <Grid Padding="16,10,16,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <TextBlock Text="Estado Financiero"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Border CornerRadius="4" Padding="8,2"
                                        Background="{x:Bind ViewModel.EstadoFinanciero, Converter={StaticResource FinBgConverter}, Mode=OneWay}">
                                    <TextBlock Text="{x:Bind ViewModel.EstadoFinancieroTexto, Mode=OneWay}"
                                               Style="{StaticResource OgStatusBadgeTextStyle}"
                                               Foreground="{x:Bind ViewModel.EstadoFinanciero, Converter={StaticResource FinFgConverter}, Mode=OneWay}"/>
                                </Border>
                            </StackPanel>
                            <!-- Botón con margen derecho garantizado por el Grid.Padding -->
                            <Button Grid.Column="1"
                                    Content="＋ Registrar Pago"
                                    FontSize="11"
                                    Style="{StaticResource ErpActionButtonStyle}"
                                    IsEnabled="{x:Bind ViewModel.PuedeRegistrarAnticipo, Mode=OneWay}"
                                    Click="BtnRegistrarAnticipo_Click"/>
                        </Grid>

                        <!-- Separador horizontal bajo el header -->
                        <Border Height="1" Background="#E8E8E8" Margin="0,0,0,0"/>

                        <!-- ── Cuerpo: Resumen numérico | Separador vertical | Historial pagos ── -->
                        <Grid Padding="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" MinWidth="220"/>
                                <!-- separador vertical -->
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Col 0: Resumen financiero -->
                            <Grid Grid.Column="0" Padding="16,12,16,0" RowSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="0" Grid.Row="0" Text="Total pedido:"
                                           Style="{StaticResource ErpCellSecondaryStyle}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Grid.Row="0"
                                           Text="{x:Bind ViewModel.Total, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                           Style="{StaticResource ErpCellSecondaryStyle}" FontSize="12" TextAlignment="Right"/>

                                <!-- Fila anticipo requerido — oculta si no está configurado -->
                                <TextBlock Grid.Column="0" Grid.Row="1" Text="Anticipo mínimo:"
                                           Style="{StaticResource ErpCellSecondaryStyle}" FontSize="12"
                                           Visibility="{x:Bind ViewModel.HayAnticipoRequerido, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Grid.Column="1" Grid.Row="1"
                                           Text="{x:Bind ViewModel.AnticiRequerido, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                           Style="{StaticResource ErpCellSecondaryStyle}" FontSize="12" TextAlignment="Right"
                                           Visibility="{x:Bind ViewModel.HayAnticipoRequerido, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                                <TextBlock Grid.Column="0" Grid.Row="2" Text="Total pagado:"
                                           Style="{StaticResource ErpCellSecondaryStyle}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Grid.Row="2"
                                           Text="{x:Bind ViewModel.AnticipoPagado, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                           Style="{StaticResource ErpCellSecondaryStyle}" FontSize="12" TextAlignment="Right" FontWeight="SemiBold"/>

                                <!-- Separador entre cuerpo y resumen -->
                                <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="3"
                                        Height="1" Background="#F0F0F0" Margin="0,4,0,4"/>

                                <TextBlock Grid.Column="0" Grid.Row="4" Text="Saldo pendiente:"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="1" Grid.Row="4"
                                           Text="{x:Bind ViewModel.SaldoPendienteFinanciero, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                           FontSize="12" TextAlignment="Right" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                                <!-- Fila Cambio — visible solo cuando hay excedente real (SobrePagado > $0.00) -->
                                <TextBlock Grid.Column="0" Grid.Row="5" Text="Cambio a devolver:"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                           Visibility="{x:Bind ViewModel.HaySobrePago, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Grid.Column="1" Grid.Row="5"
                                           Text="{x:Bind ViewModel.Excedente, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                           FontSize="12" TextAlignment="Right" FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                           Visibility="{x:Bind ViewModel.HaySobrePago, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                            </Grid>

                            <!-- Col 1: Separador vertical -->
                            <Border Grid.Column="1" Background="#E8E8E8" Margin="0,12,0,0"/>

                            <!-- Col 2: Historial de pagos -->
                            <ListView Grid.Column="2"
                                      ItemsSource="{x:Bind ViewModel.Anticipos, Mode=OneWay}"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      ScrollViewer.VerticalScrollMode="Disabled"
                                      SelectionMode="None">
                                <ListView.Header>
                                    <Border Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                                        <Grid Padding="8,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Fecha"      FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                                            <TextBlock Grid.Column="1" Text="Forma Pago" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                                            <TextBlock Grid.Column="2" Text="Referencia" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                                            <TextBlock Grid.Column="3" Text="Monto"      FontSize="11" FontWeight="SemiBold" Foreground="#888" TextAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </ListView.Header>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="dto:AnticipoPedidoDto">
                                        <Grid Height="36">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Fecha}" FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind FormaPago}" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{x:Bind Referencia}" FontSize="11" VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{x:Bind Monto, Converter={StaticResource CurrencyConverter}}"
                                                       Style="{StaticResource OgCurrencyTextStyle}"
                                                       FontSize="12"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── StatusBar — al pie del bloque de Totales ── -->
                <Border Grid.Row="6" Style="{StaticResource ErpGridStatusBarStyle}" Margin="0,4,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource ErpGridStatusTextStyle}" Text="{x:Bind ViewModel.Folio, Mode=OneWay}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Style="{StaticResource ErpGridStatusTextStyle}">
                                <Run Text="{x:Bind ViewModel.Detalles.Count, Mode=OneWay}"/>
                                <Run Text="línea(s)"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource ErpGridStatusTextStyle}">
                                <Run Text="{x:Bind ViewModel.TotalArticulos, Mode=OneWay}"/>
                                <Run Text="art."/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource ErpGridErrorTextStyle}"   Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>
                            <TextBlock Style="{StaticResource ErpGridSuccessTextStyle}" Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource ErpGridStatusTextStyle}" Text="Total:"/>
                            <TextBlock Style="{StaticResource ErpGridStatusTextStyle}" FontWeight="SemiBold"
                                       Text="{x:Bind ViewModel.Total, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
