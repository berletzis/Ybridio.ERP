<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Ventas.PedidoDocumentoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:Ybridio.WinUI.ViewModels.Ventas"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left" Margin="8,0,0,0">
            <AppBarButton Label="Guardar" Command="{x:Bind ViewModel.GuardarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE74E;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Agregar Línea" Click="BtnAgregarLinea_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE710;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Eliminar Línea" Command="{x:Bind ViewModel.EliminarDetalleCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE74D;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Avanzar Estado" Command="{x:Bind ViewModel.AvanzarEstatusCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE7C4;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Generar OT" Click="BtnGenerarOT_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8F1;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Cancelar" Click="BtnCancelarPedido_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE711;"/></AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="#E5E5E5" BorderThickness="0,0,0,1" Padding="20,8,20,8">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="{x:Bind ViewModel.TituloDocumento, Mode=OneWay}"
                           FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="4" Padding="8,2,8,2">
                    <TextBlock Text="{x:Bind ViewModel.EstatusTextoDisplay, Mode=OneWay}"
                               Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Margin="20,8,20,0" Background="White"
                BorderBrush="#E5E5E5" BorderThickness="1" Padding="16,12">
            <Grid ColumnSpacing="16" RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                    <TextBlock Text="Cliente *" FontWeight="SemiBold" FontSize="12"/>
                    <TextBox PlaceholderText="Nombre del cliente"
                             Text="{x:Bind ViewModel.NombreCliente, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4">
                    <TextBlock Text="Observaciones" FontWeight="SemiBold" FontSize="12"/>
                    <TextBox PlaceholderText="Observaciones"
                             Text="{x:Bind ViewModel.Observaciones, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="1" Orientation="Horizontal" Spacing="16">
                    <StackPanel Spacing="4" Width="180">
                        <TextBlock Text="Fecha" FontWeight="SemiBold" FontSize="12"/>
                        <DatePicker Date="{x:Bind ViewModel.FechaOffset, Mode=TwoWay}"/>
                    </StackPanel>
                    <StackPanel Spacing="4" Width="200">
                        <TextBlock Text="Entrega Compromiso" FontWeight="SemiBold" FontSize="12"/>
                        <DatePicker Date="{x:Bind ViewModel.FechaEntregaCompromisoOffset, Mode=TwoWay}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3" Margin="20,8,20,0" Background="White" BorderBrush="#E5E5E5" BorderThickness="1">
            <Grid>
                <ListView Style="{StaticResource OutlookDataGridStyle}"
                          ItemsSource="{x:Bind ViewModel.Detalles, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.DetalleSeleccionado, Mode=TwoWay}">
                    <ListView.Header>
                        <Border Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                            <Grid Padding="{StaticResource ErpHeaderPadding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="Descripción"     Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="2" Text="Cantidad"        Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Precio Unitario" Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Importe"         Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                            </Grid>
                        </Border>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DetalleLineaEditable">
                            <Grid Height="{StaticResource ErpRowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="{x:Bind Descripcion}"   Style="{StaticResource ErpCellPrimaryStyle}"   VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind Cantidad}"      Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind PrecioUnitario}" Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="{x:Bind Importe}"       Style="{StaticResource ErpCellPrimaryStyle}"   VerticalAlignment="Center" TextAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Margin="20,4,20,0" Background="White" BorderBrush="#E5E5E5" BorderThickness="1" Padding="16,10">
            <Grid HorizontalAlignment="Right" MinWidth="240" RowSpacing="4">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Grid.Column="0" Text="Total:" FontWeight="SemiBold" FontSize="14"/>
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Total, Mode=OneWay}" FontWeight="SemiBold" FontSize="14" TextAlignment="Right"/>
            </Grid>
        </Border>

        <Border Grid.Row="5" Style="{StaticResource ErpGridStatusBarStyle}" Margin="20,0,20,16">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource ErpGridStatusTextStyle}">
                    <Run Text="{x:Bind ViewModel.Detalles.Count, Mode=OneWay}"/>
                    <Run Text="línea(s)"/>
                </TextBlock>
                <TextBlock Style="{StaticResource ErpGridErrorTextStyle}"   Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>
                <TextBlock Style="{StaticResource ErpGridSuccessTextStyle}" Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
