<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Ventas.CotizacionDocumentoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:Ybridio.WinUI.ViewModels.Ventas"
      xmlns:ventas="using:Ybridio.Application.DTOs.Ventas"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CommandBar Enterprise -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left" Margin="8,0,0,0">
            <!-- Document Surface UX Pattern: botón para volver al listado -->
            <AppBarButton x:Name="BtnVolverALista" Label="Volver a Lista" Click="BtnVolverALista_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE72B;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Guardar" Command="{x:Bind ViewModel.GuardarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE74E;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Agregar Línea" Click="BtnAgregarLinea_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE710;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Eliminar Línea" Command="{x:Bind ViewModel.EliminarDetalleCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE74D;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Enviar" Click="BtnEnviar_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE724;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Aprobar" Click="BtnAprobar_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8FB;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Convertir a Pedido" Command="{x:Bind ViewModel.ConvertirAPedidoCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE7C4;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Cancelar Cotización" Click="BtnCancelarCotizacion_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE711;"/></AppBarButton.Icon>
            </AppBarButton>

            <!-- Document Surface Detachable Mode (ADR-027) + Window Detach Mode (ADR-028): acciones avanzadas opcionales -->
            <CommandBar.SecondaryCommands>
                <AppBarButton x:Name="BtnToggleDetach" Label="Desacoplar Surface" Click="BtnToggleDetach_Click">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE89A;"/></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="BtnAbrirEnVentana" Label="Abrir en Ventana" Click="BtnAbrirEnVentana_Click">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE8A7;"/></AppBarButton.Icon>
                </AppBarButton>
            </CommandBar.SecondaryCommands>
        </CommandBar>

        <!-- Header strip: título + badge de estado -->
        <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="#E5E5E5" BorderThickness="0,0,0,1" Padding="20,8,20,8">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="{x:Bind ViewModel.TituloDocumento, Mode=OneWay}"
                           FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="4" Padding="8,2,8,2">
                    <TextBlock Text="{x:Bind ViewModel.EstatusTextoDisplay, Mode=OneWay}"
                               Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Formulario encabezado -->
        <Border Grid.Row="2" Margin="20,8,20,0" Background="White"
                BorderBrush="#E5E5E5" BorderThickness="1" Padding="16,12">
            <Grid ColumnSpacing="16" RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Columna izquierda: selector de cliente + info -->
                <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                    <TextBlock Text="Cliente *" FontWeight="SemiBold" FontSize="12"/>
                    <!-- AutoSuggestBox conectado a IClienteService.BuscarAsync -->
                    <AutoSuggestBox x:Name="AsbCliente"
                                    PlaceholderText="Buscar cliente por nombre, RFC o email..."
                                    QueryIcon="Find"
                                    Text="{x:Bind ViewModel.NombreCliente, Mode=TwoWay}"
                                    TextChanged="ClienteAutoSuggest_TextChanged"
                                    SuggestionChosen="ClienteAutoSuggest_SuggestionChosen"
                                    QuerySubmitted="ClienteAutoSuggest_QuerySubmitted">
                        <!-- Plantilla de sugerencia: muestra nombre + RFC -->
                        <AutoSuggestBox.ItemTemplate>
                            <DataTemplate x:DataType="ventas:ClienteDto">
                                <StackPanel Orientation="Horizontal" Spacing="8" Padding="4,4,4,4">
                                    <FontIcon Glyph="&#xE77B;" FontSize="14" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="{x:Bind Nombre}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="{x:Bind RFC}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{x:Bind Email}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </AutoSuggestBox.ItemTemplate>
                    </AutoSuggestBox>
                </StackPanel>

                <!-- Info de cliente seleccionado (solo lectura) -->
                <Border Grid.Column="0" Grid.Row="1"
                        Background="#F8F8F8" BorderBrush="#E5E5E5" BorderThickness="1"
                        CornerRadius="4" Padding="10,8"
                        Visibility="{x:Bind ViewModel.TieneClienteSeleccionado, Mode=OneWay}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Email" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.ClienteEmail, Mode=OneWay}"
                                       FontSize="12" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Teléfono" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.ClienteTelefono, Mode=OneWay}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="2" MinWidth="100">
                            <TextBlock Text="Límite Crédito" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.ClienteLimiteCredito, Mode=OneWay}"
                                       FontSize="12" FontWeight="SemiBold" TextAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4">
                    <TextBlock Text="Observaciones" FontWeight="SemiBold" FontSize="12"/>
                    <TextBox PlaceholderText="Observaciones"
                             Text="{x:Bind ViewModel.Observaciones, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="2" Orientation="Horizontal" Spacing="16">
                    <StackPanel Spacing="4" Width="180">
                        <TextBlock Text="Fecha" FontWeight="SemiBold" FontSize="12"/>
                        <DatePicker Date="{x:Bind ViewModel.FechaOffset, Mode=TwoWay}"/>
                    </StackPanel>
                    <StackPanel Spacing="4" Width="180">
                        <TextBlock Text="Vigencia" FontWeight="SemiBold" FontSize="12"/>
                        <DatePicker Date="{x:Bind ViewModel.FechaVigenciaOffset, Mode=TwoWay}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Grid de detalles -->
        <Border Grid.Row="3" Margin="20,8,20,0" Background="White"
                BorderBrush="#E5E5E5" BorderThickness="1">
            <Grid>
                <ListView Style="{StaticResource OutlookDataGridStyle}"
                          ItemsSource="{x:Bind ViewModel.Detalles, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.DetalleSeleccionado, Mode=TwoWay}">
                    <ListView.Header>
                        <Border Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                            <Grid Padding="{StaticResource ErpHeaderPadding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="SKU"             Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="2" Text="Descripción"     Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="3" Text="Existencia"      Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Cantidad"        Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Precio Unitario" Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="Importe"         Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                            </Grid>
                        </Border>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DetalleLineaEditable">
                            <Grid Height="{StaticResource ErpRowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="{x:Bind Sku}"
                                           Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center"
                                           FontSize="11"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind Descripcion}"
                                           Style="{StaticResource ErpCellPrimaryStyle}" VerticalAlignment="Center"/>
                                <!-- Existencia informativa: no reserva stock (§3 requerimiento) -->
                                <TextBlock Grid.Column="3" Text="{x:Bind ExistenciaDisponible}"
                                           Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center"
                                           TextAlignment="Right" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="4" Text="{x:Bind Cantidad}"
                                           Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center"
                                           TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="{x:Bind PrecioUnitario}"
                                           Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center"
                                           TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="{x:Bind Importe}"
                                           Style="{StaticResource ErpCellPrimaryStyle}" VerticalAlignment="Center"
                                           TextAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                              Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Totales -->
        <Border Grid.Row="4" Margin="20,4,20,0" Background="White"
                BorderBrush="#E5E5E5" BorderThickness="1" Padding="16,10">
            <Grid HorizontalAlignment="Right" MinWidth="280" RowSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Column="0" Grid.Row="0" Text="Subtotal:"
                           Style="{StaticResource ErpCellSecondaryStyle}"/>
                <TextBlock Grid.Column="1" Grid.Row="0" Text="{x:Bind ViewModel.Subtotal, Mode=OneWay}"
                           Style="{StaticResource ErpCellSecondaryStyle}" TextAlignment="Right"/>
                <TextBlock Grid.Column="0" Grid.Row="1" Text="Total:"
                           FontWeight="SemiBold" FontSize="14"/>
                <TextBlock Grid.Column="1" Grid.Row="1" Text="{x:Bind ViewModel.Total, Mode=OneWay}"
                           FontWeight="SemiBold" FontSize="14" TextAlignment="Right"/>
            </Grid>
        </Border>

        <!-- StatusBar -->
        <Border Grid.Row="5" Style="{StaticResource ErpGridStatusBarStyle}" Margin="20,0,20,16">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource ErpGridStatusTextStyle}">
                    <Run Text="{x:Bind ViewModel.Detalles.Count, Mode=OneWay}"/>
                    <Run Text="línea(s)"/>
                </TextBlock>
                <TextBlock Style="{StaticResource ErpGridErrorTextStyle}"   Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>
                <TextBlock Style="{StaticResource ErpGridSuccessTextStyle}" Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
