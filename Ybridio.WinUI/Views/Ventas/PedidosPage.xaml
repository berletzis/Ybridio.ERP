<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Ventas.PedidosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:dto="using:Ybridio.Application.DTOs.Ventas"
      xmlns:converters="using:Ybridio.WinUI.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CommandBar modulo Pedidos — ADR-031: pertenece a navegacion, NO al documento -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left" Margin="8,0,0,0">
            <AppBarButton Label="Nuevo Pedido" Click="BtnNuevo_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE710;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Abrir" Click="BtnAbrir_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8A7;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Avanzar Estado" Command="{x:Bind ViewModel.AvanzarEstatusCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE7C4;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Eliminar" Command="{x:Bind ViewModel.EliminarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE74D;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Actualizar" Command="{x:Bind ViewModel.RefrescarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE72C;"/></AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <Grid Grid.Row="1" Padding="8,8,20,4" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <AutoSuggestBox Grid.Column="0" PlaceholderText="Buscar por cliente o estado..."
                            QueryIcon="Find" Text="{x:Bind ViewModel.Busqueda, Mode=TwoWay}"
                            VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" MinWidth="130" VerticalAlignment="Center"
                      SelectedItem="{x:Bind ViewModel.FiltroTemporal, Mode=TwoWay}">
                <x:String>7 dias</x:String>
                <x:String>30 dias</x:String>
                <x:String>90 dias</x:String>
                <x:String>6 meses</x:String>
                <x:String>1 ano</x:String>
                <x:String>Todo</x:String>
            </ComboBox>
        </Grid>

        <Border Grid.Row="2" Margin="20,4,20,0" Background="White" BorderBrush="#E5E5E5" BorderThickness="1"
                Visibility="{x:Bind ViewModel.IsDocumentSurfaceVisible, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid>
                <ListView Style="{StaticResource OutlookDataGridStyle}"
                          ItemsSource="{x:Bind ViewModel.Pedidos, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.PedidoSeleccionado, Mode=TwoWay}"
                          DoubleTapped="Lista_DoubleTapped">
                    <ListView.Header>
                        <Border Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                            <Grid Padding="{StaticResource ErpHeaderPadding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="#"       Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="2" Text="Cliente" Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="3" Text="Fecha"   Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="4" Text="Estado"  Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="5" Text="Total"   Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                            </Grid>
                        </Border>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="dto:PedidoResumenDto">
                            <Grid Height="{StaticResource ErpRowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="{x:Bind Id}"
                                           Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind NombreCliente}"
                                           Style="{StaticResource ErpCellPrimaryStyle}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind Fecha}"
                                           Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{x:Bind EstatusTexto}"
                                           Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="{x:Bind Total}"
                                           Style="{StaticResource ErpCellPrimaryStyle}" VerticalAlignment="Center"
                                           TextAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                              Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <ContentControl ContentTemplate="{StaticResource ErpGridEmptyTemplate}"
                                Visibility="{x:Bind ViewModel.IsEmptyState, Mode=OneWay}"
                                HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!--
            ADR-031: Document Surface — superficie operacional que reemplaza el listado.
            Jerarquia oficial: Tab modulo (navegacion) > Document Surface (documento activo).
            SIN apariencia browser tab. SIN tabs ensimados. SIN transparencia hibrida.
        -->
        <ContentPresenter Grid.Row="2"
                          Margin="20,4,20,0"
                          Content="{x:Bind ViewModel.DocumentSurfaceContent, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.IsDocumentSurfaceVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <Border Grid.Row="3" Style="{StaticResource ErpGridStatusBarStyle}" Margin="20,0,20,16">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource ErpGridStatusTextStyle}">
                    <Run Text="{x:Bind ViewModel.Pedidos.Count, Mode=OneWay}"/>
                    <Run Text="pedido(s)"/>
                </TextBlock>
                <TextBlock Style="{StaticResource ErpGridErrorTextStyle}"   Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>
                <TextBlock Style="{StaticResource ErpGridSuccessTextStyle}" Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
