<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Ventas.ClientesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:dto="using:Ybridio.Application.DTOs.Ventas"
      xmlns:converters="using:Ybridio.WinUI.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter       x:Key="BoolToVisibilityConverter"/>
        <converters:DecimalToCurrencyConverter       x:Key="CurrencyConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── CommandBar (ADR-034: ErpModuleCommandBarStyle) ───────────── -->
        <CommandBar Grid.Row="0" Style="{StaticResource ErpModuleCommandBarStyle}">
            <AppBarButton Label="Nuevo" Click="BtnNuevo_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE710;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Abrir" Click="BtnAbrir_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8A7;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Eliminar" Command="{x:Bind ViewModel.EliminarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE74D;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Actualizar" Command="{x:Bind ViewModel.LoadCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE72C;"/></AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <!-- ── Filtros (ADR-034: ErpFilterRegionPadding) ────────────────── -->
        <Grid Grid.Row="1" Padding="{StaticResource ErpFilterRegionPadding}">
            <AutoSuggestBox PlaceholderText="Buscar por nombre, RFC o teléfono..."
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.Busqueda, Mode=TwoWay}"/>
        </Grid>

        <!--
            ADR-032: Document Surface — INLINE mode (content replacement).
            Dos estados: grid visible (IsDocumentSurfaceVisible=false) ó surface visible (=true).
        -->
        <Grid Grid.Row="2">

            <!-- ═══ Listado de Clientes (Operational Grid Standard) ═══════════ -->
            <Border x:Name="ListadoBorder"
                    Style="{StaticResource OgGridContainerStyle}"
                    Margin="{StaticResource ErpContentBoundaryWithTopGap}"
                    Visibility="{x:Bind ViewModel.IsDocumentSurfaceVisible, Mode=OneWay,
                                 Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Encabezado de columnas -->
                    <Border Grid.Row="0" Style="{StaticResource OgHeaderContainerStyle}">
                        <Grid Padding="{StaticResource OgHeaderPadding}">
                            <Grid.ColumnDefinitions>
                                <!-- Gutter -->
                                <ColumnDefinition Width="{StaticResource OgColGutter}"/>
                                <!-- Nombre — PRIMARY EXPANDABLE -->
                                <ColumnDefinition Width="2*"/>
                                <!-- Teléfono — COMPACT SEMANTIC -->
                                <ColumnDefinition Width="{StaticResource OgColStatus}"/>
                                <!-- Email — PRIMARY EXPANDABLE -->
                                <ColumnDefinition Width="*"/>
                                <!-- Límite Crédito — FINANCIAL COMPACT -->
                                <ColumnDefinition Width="{StaticResource OgColFinancial}"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="Nombre"       Style="{StaticResource OgHeaderTextStyle}"/>
                            <TextBlock Grid.Column="2" Text="Teléfono"     Style="{StaticResource OgHeaderTextStyle}"/>
                            <TextBlock Grid.Column="3" Text="Email"        Style="{StaticResource OgHeaderTextStyle}"/>
                            <TextBlock Grid.Column="4" Text="Límite Créd." Style="{StaticResource OgHeaderNumericTextStyle}"/>
                        </Grid>
                    </Border>

                    <ListView Grid.Row="1"
                              Style="{StaticResource OgListViewStyle}"
                              ItemsSource="{x:Bind ViewModel.Clientes, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.ClienteSeleccionado, Mode=TwoWay}"
                              DoubleTapped="Lista_DoubleTapped">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="dto:ClienteDto">
                                <Grid MinHeight="{StaticResource OgRowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <!-- Gutter -->
                                        <ColumnDefinition Width="{StaticResource OgColGutter}"/>
                                        <!-- Nombre — PRIMARY EXPANDABLE -->
                                        <ColumnDefinition Width="2*"/>
                                        <!-- Teléfono — COMPACT SEMANTIC -->
                                        <ColumnDefinition Width="{StaticResource OgColStatus}"/>
                                        <!-- Email — PRIMARY EXPANDABLE -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- Límite Crédito — FINANCIAL COMPACT -->
                                        <ColumnDefinition Width="{StaticResource OgColFinancial}"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Nombre — PRIMARY EXPANDABLE: ocupa espacio útil -->
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Nombre}"
                                               Style="{StaticResource OgCellPrimaryStyle}"/>

                                    <!-- Teléfono -->
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind Telefono}"
                                               Style="{StaticResource OgCellSecondaryStyle}"/>

                                    <!-- Email — PRIMARY EXPANDABLE: ocupa espacio útil -->
                                    <TextBlock Grid.Column="3"
                                               Text="{x:Bind Email}"
                                               Style="{StaticResource OgCellSecondaryStyle}"/>

                                    <!-- Límite Crédito — FINANCIAL COMPACT: símbolo monetario obligatorio -->
                                    <TextBlock Grid.Column="4"
                                               Text="{x:Bind LimiteCredito, Converter={StaticResource CurrencyConverter}, Mode=OneTime}"
                                               Style="{StaticResource OgCurrencyTextStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <ProgressRing Grid.Row="1"
                                  IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                                  Width="48" Height="48"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <ContentControl Grid.Row="1"
                                    ContentTemplate="{StaticResource OgEmptyStateTemplate}"
                                    Visibility="{x:Bind ViewModel.IsEmptyState, Mode=OneWay}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- ═══ Document Surface — INLINE ════════════════════════════════ -->
            <ContentPresenter x:Name="DocumentSurfacePresenter"
                              Margin="{StaticResource ErpContentBoundaryWithTopGap}"
                              Content="{x:Bind ViewModel.DocumentSurfaceContent, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.IsDocumentSurfaceVisible, Mode=OneWay}"/>
        </Grid>

        <!-- ── Status bar (ADR-034: se oculta cuando Document Surface activo) ── -->
        <Border Grid.Row="3"
                Style="{StaticResource OgStatusBarStyle}"
                Margin="{StaticResource ErpStatusRegionMargin}"
                Visibility="{x:Bind ViewModel.IsDocumentSurfaceVisible, Mode=OneWay,
                             Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource OgStatusCountStyle}">
                    <Run Text="{x:Bind ViewModel.Clientes.Count, Mode=OneWay}"/>
                    <Run Text="cliente(s)"/>
                </TextBlock>
                <TextBlock Style="{StaticResource OgStatusErrorStyle}"   Text="{x:Bind ViewModel.ErrorMessage,   Mode=OneWay}"/>
                <TextBlock Style="{StaticResource OgStatusSuccessStyle}" Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
