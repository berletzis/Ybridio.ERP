<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Ventas.ClientesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:dto="using:Ybridio.Application.DTOs.Ventas"
      xmlns:converters="using:Ybridio.WinUI.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left" Margin="8,0,0,0">
            <AppBarButton Label="Nuevo" Click="BtnNuevo_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE710;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Abrir" Click="BtnAbrir_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8A7;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Eliminar" Command="{x:Bind ViewModel.EliminarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE74D;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Actualizar" Command="{x:Bind ViewModel.LoadCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE72C;"/></AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <Grid Grid.Row="1" Padding="8,8,20,4">
            <AutoSuggestBox PlaceholderText="Buscar por nombre, RFC o teléfono..."
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.Busqueda, Mode=TwoWay}"/>
        </Grid>

        <!--
            Document Surface UX Pattern (ADR-025 + ADR-030):
            Tres estados visuales:
            1. Normal (grid visible, surface oculta): IsDocumentSurfaceVisible=false
            2. Content Replacement (surface visible, grid oculto): IsDocumentSurfaceVisible=true, IsDocumentSurfaceDetached=false
            3. Detached (grid + surface simultáneos): IsDocumentSurfaceVisible=true, IsDocumentSurfaceDetached=true
        -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ListadoColumn" Width="*"/>
                <ColumnDefinition x:Name="SplitterColumn" Width="0"/>
                <ColumnDefinition x:Name="SurfaceColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ Listado de Clientes ═══════════════════════════════════════ -->
            <Border x:Name="ListadoBorder"
                    Grid.Column="0"
                    Margin="20,4,20,0"
                    Background="White"
                    BorderBrush="#E5E5E5"
                    BorderThickness="1"
                    Visibility="{x:Bind ViewModel.IsDocumentSurfaceVisible, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <Grid>
                    <ListView Style="{StaticResource OutlookDataGridStyle}"
                              ItemsSource="{x:Bind ViewModel.Clientes, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.ClienteSeleccionado, Mode=TwoWay}"
                              DoubleTapped="Lista_DoubleTapped">
                        <ListView.Header>
                            <Border Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                                <Grid Padding="{StaticResource ErpHeaderPadding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="1" Text="Nombre"        Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="2" Text="Teléfono"      Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="3" Text="Email"         Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="4" Text="Límite Créd."  Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                </Grid>
                            </Border>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="dto:ClienteDto">
                                <Grid Height="{StaticResource ErpRowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Nombre}"
                                               Style="{StaticResource ErpCellPrimaryStyle}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind Telefono}"
                                               Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{x:Bind Email}"
                                               Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="{x:Bind LimiteCredito}"
                                               Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center"
                                               TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                                  Width="48" Height="48"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <ContentControl ContentTemplate="{StaticResource ErpGridEmptyTemplate}"
                                    Visibility="{x:Bind ViewModel.IsEmptyState, Mode=OneWay}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- ═══ Document Surface ══════════════════════════════════════════ -->
            <ContentPresenter x:Name="DocumentSurfacePresenter"
                              Grid.Column="0"
                              Grid.ColumnSpan="3"
                              Margin="20,4,20,0"
                              Content="{x:Bind ViewModel.DocumentSurfaceContent, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.IsDocumentSurfaceVisible, Mode=OneWay}"/>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource ErpGridStatusBarStyle}" Margin="20,0,20,16">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource ErpGridStatusTextStyle}">
                    <Run Text="{x:Bind ViewModel.Clientes.Count, Mode=OneWay}"/>
                    <Run Text="cliente(s)"/>
                </TextBlock>
                <TextBlock Style="{StaticResource ErpGridErrorTextStyle}"   Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>
                <TextBlock Style="{StaticResource ErpGridSuccessTextStyle}" Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
