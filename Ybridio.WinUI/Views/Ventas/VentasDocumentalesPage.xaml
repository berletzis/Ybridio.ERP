<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Ventas.VentasDocumentalesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:dto="using:Ybridio.Application.DTOs.Ventas"
      xmlns:converters="using:Ybridio.WinUI.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:InverseBoolToVisibilityConverter  x:Key="InverseBoolToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter         x:Key="BoolToVisibilityConverter"/>
        <converters:EstatusVentaToBgBrushConverter    x:Key="EstatusBgConverter"/>
        <converters:EstatusVentaToFgBrushConverter    x:Key="EstatusFgConverter"/>
        <converters:DecimalToCurrencyConverter         x:Key="CurrencyConverter"/>
        <converters:OperationalDateConverter           x:Key="OperationalDateConverter"/>
        <converters:NullableLongWithPrefixConverter   x:Key="PedidoIdConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Command Bar ─────────────────────────────────────────────────── -->
        <CommandBar Grid.Row="0" Style="{StaticResource ErpModuleCommandBarStyle}">
            <AppBarButton Label="Nueva Venta" Click="BtnNuevo_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE710;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Ver Detalle" Click="BtnAbrir_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8A9;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Actualizar" Command="{x:Bind ViewModel.RefrescarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE72C;"/></AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <!-- ── Filtros ──────────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Padding="{StaticResource ErpFilterRegionPadding}" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <AutoSuggestBox Grid.Column="0" PlaceholderText="Buscar por cliente o estado..."
                            QueryIcon="Find" Text="{x:Bind ViewModel.Busqueda, Mode=TwoWay}"
                            QuerySubmitted="Busqueda_QuerySubmitted"
                            VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" MinWidth="130" VerticalAlignment="Center"
                      SelectedItem="{x:Bind ViewModel.FiltroTemporal, Mode=TwoWay}"
                      SelectionChanged="FiltroTemporal_SelectionChanged">
                <x:String>7 dias</x:String>
                <x:String>30 dias</x:String>
                <x:String>90 dias</x:String>
                <x:String>6 meses</x:String>
                <x:String>1 ano</x:String>
                <x:String>Todo</x:String>
            </ComboBox>
        </Grid>

        <!--
            ADR-031: Dos estados: listado visible (IsDocumentSurfaceVisible=false)
            ó Document Surface visible (=true).
        -->
        <Grid Grid.Row="2">

            <!-- ═══ Listado de Ventas (Operational Grid Standard v2 — ADR-035) ═══════ -->
            <Border Style="{StaticResource OgGridContainerStyle}"
                    Margin="{StaticResource ErpContentBoundaryWithTopGap}"
                    Visibility="{x:Bind ViewModel.IsDocumentSurfaceVisible, Mode=OneWay,
                                 Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Encabezado de columnas -->
                    <Border Grid.Row="0" Style="{StaticResource OgHeaderContainerStyle}">
                        <Grid Padding="{StaticResource OgHeaderPadding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{StaticResource OgColGutter}"/>
                                <!-- Folio — 130 px (OgColDate) -->
                                <ColumnDefinition Width="{StaticResource OgColDate}"/>
                                <!-- Cliente — PRIMARY EXPANDABLE -->
                                <ColumnDefinition Width="*"/>
                                <!-- Fecha — 130 px -->
                                <ColumnDefinition Width="{StaticResource OgColDate}"/>
                                <!-- Tipo Pago — COMPACT SEMANTIC -->
                                <ColumnDefinition Width="{StaticResource OgColCompact}"/>
                                <!-- Total — FINANCIAL COMPACT -->
                                <ColumnDefinition Width="{StaticResource OgColFinancial}"/>
                                <!-- Pagado — FINANCIAL COMPACT -->
                                <ColumnDefinition Width="{StaticResource OgColFinancial}"/>
                                <!-- Estatus — badge -->
                                <ColumnDefinition Width="{StaticResource OgColStatus}"/>
                                <!-- Pedido Origen — COMPACT SEMANTIC -->
                                <ColumnDefinition Width="{StaticResource OgColCompact}"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="Folio"      Style="{StaticResource OgHeaderTextStyle}"/>
                            <TextBlock Grid.Column="2" Text="Cliente"    Style="{StaticResource OgHeaderTextStyle}"/>
                            <TextBlock Grid.Column="3" Text="Fecha"      Style="{StaticResource OgHeaderTextStyle}"/>
                            <TextBlock Grid.Column="4" Text="Tipo Pago"  Style="{StaticResource OgHeaderTextStyle}"/>
                            <TextBlock Grid.Column="5" Text="Total"      Style="{StaticResource OgHeaderNumericTextStyle}"/>
                            <TextBlock Grid.Column="6" Text="Pagado"     Style="{StaticResource OgHeaderNumericTextStyle}"/>
                            <TextBlock Grid.Column="7" Text="Estatus"    Style="{StaticResource OgHeaderCenteredTextStyle}"/>
                            <TextBlock Grid.Column="8" Text="Pedido"     Style="{StaticResource OgHeaderTextStyle}"/>
                        </Grid>
                    </Border>

                    <!-- Filas -->
                    <ListView Grid.Row="1"
                              Style="{StaticResource OgListViewStyle}"
                              ItemsSource="{x:Bind ViewModel.Ventas, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.VentaSeleccionada, Mode=TwoWay}"
                              DoubleTapped="Lista_DoubleTapped">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="dto:VentaDocumentalResumenDto">
                                <Grid MinHeight="{StaticResource OgRowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{StaticResource OgColGutter}"/>
                                        <ColumnDefinition Width="{StaticResource OgColDate}"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="{StaticResource OgColDate}"/>
                                        <ColumnDefinition Width="{StaticResource OgColCompact}"/>
                                        <ColumnDefinition Width="{StaticResource OgColFinancial}"/>
                                        <ColumnDefinition Width="{StaticResource OgColFinancial}"/>
                                        <ColumnDefinition Width="{StaticResource OgColStatus}"/>
                                        <ColumnDefinition Width="{StaticResource OgColCompact}"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Folio -->
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Folio}"
                                               Style="{StaticResource OgCellIdStyle}"/>

                                    <!-- Cliente — PRIMARY EXPANDABLE -->
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind NombreCliente}"
                                               Style="{StaticResource OgCellPrimaryStyle}"/>

                                    <!-- Fecha — OperationalDateConverter -->
                                    <TextBlock Grid.Column="3"
                                               Text="{x:Bind Fecha, Converter={StaticResource OperationalDateConverter}, Mode=OneTime}"
                                               Style="{StaticResource OgCellSecondaryStyle}"/>

                                    <!-- Tipo Pago -->
                                    <TextBlock Grid.Column="4"
                                               Text="{x:Bind TipoPago}"
                                               Style="{StaticResource OgCellSecondaryStyle}"/>

                                    <!-- Total — FINANCIAL COMPACT -->
                                    <TextBlock Grid.Column="5"
                                               Text="{x:Bind Total, Converter={StaticResource CurrencyConverter}, Mode=OneTime}"
                                               Style="{StaticResource OgCurrencyTextStyle}"/>

                                    <!-- Pagado — FINANCIAL COMPACT -->
                                    <TextBlock Grid.Column="6"
                                               Text="{x:Bind TotalPagado, Converter={StaticResource CurrencyConverter}, Mode=OneTime}"
                                               Style="{StaticResource OgCurrencyTextStyle}"/>

                                    <!-- Estatus — badge semántico -->
                                    <Border Grid.Column="7"
                                            CornerRadius="4"
                                            Padding="8,2"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Background="{x:Bind Estatus, Converter={StaticResource EstatusBgConverter}, Mode=OneTime}">
                                        <TextBlock Text="{x:Bind EstatusTexto}"
                                                   Style="{StaticResource OgStatusBadgeTextStyle}"
                                                   Foreground="{x:Bind Estatus, Converter={StaticResource EstatusFgConverter}, Mode=OneTime}"/>
                                    </Border>

                                    <!-- Pedido Origen — "PED-{id}" o "—" si null -->
                                    <TextBlock Grid.Column="8"
                                               Text="{x:Bind PedidoId, Converter={StaticResource PedidoIdConverter}, ConverterParameter=PED-, Mode=OneTime}"
                                               Style="{StaticResource OgCellSecondaryStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <ProgressRing Grid.Row="1"
                                  IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                                  Width="48" Height="48"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <ContentControl Grid.Row="1"
                                    ContentTemplate="{StaticResource OgEmptyStateTemplate}"
                                    Visibility="{x:Bind ViewModel.IsEmptyState, Mode=OneWay}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- ═══ Document Surface — INLINE (ADR-031) ═════════════════════════════ -->
            <ContentPresenter Margin="{StaticResource ErpContentBoundaryWithTopGap}"
                              Content="{x:Bind ViewModel.DocumentSurfaceContent, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.IsDocumentSurfaceVisible, Mode=OneWay,
                                           Converter={StaticResource BoolToVisibilityConverter}}"/>
        </Grid>

        <!-- ── Status bar — se oculta cuando Document Surface activo (ADR-031 + ADR-034 + ADR-041) ── -->
        <Border Grid.Row="3"
                Style="{StaticResource OgStatusBarStyle}"
                Margin="{StaticResource ErpStatusRegionMargin}"
                Visibility="{x:Bind ViewModel.IsDocumentSurfaceVisible, Mode=OneWay,
                             Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Izquierda: conteos operacionales -->
                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource OgStatusCountStyle}">
                        <Run Text="{x:Bind ViewModel.Ventas.Count, Mode=OneWay}"/>
                        <Run Text="venta(s) cerrada(s)"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource OgStatusErrorStyle}"
                               Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>
                    <TextBlock Style="{StaticResource OgStatusSuccessStyle}"
                               Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"/>
                </StackPanel>
                <!-- Derecha: totales financieros -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Style="{StaticResource OgStatusPaginationStyle}" Text="Total acumulado:"/>
                        <TextBlock Style="{StaticResource OgStatusSummaryStyle}"
                                   Text="{x:Bind ViewModel.TotalAcumulado, Mode=OneWay,
                                          Converter={StaticResource CurrencyConverter}}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
