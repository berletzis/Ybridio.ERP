<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ybridio.WinUI.Views.Ventas.VentasDocumentalesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:dto="using:Ybridio.Application.DTOs.Ventas"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Command Bar ─────────────────────────────────────────────────── -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left" Margin="8,0,0,0">
            <AppBarButton Label="Nueva Venta" Click="BtnNuevo_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE710;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Abrir" Click="BtnAbrir_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8A7;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Actualizar" Command="{x:Bind ViewModel.RefrescarCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE72C;"/></AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <!-- ── Filtros ──────────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Padding="8,8,20,4" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <AutoSuggestBox Grid.Column="0" PlaceholderText="Buscar por cliente o estado..."
                            QueryIcon="Find" Text="{x:Bind ViewModel.Busqueda, Mode=TwoWay}"
                            QuerySubmitted="Busqueda_QuerySubmitted"
                            VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" MinWidth="130" VerticalAlignment="Center"
                      SelectedItem="{x:Bind ViewModel.FiltroTemporal, Mode=TwoWay}"
                      SelectionChanged="FiltroTemporal_SelectionChanged">
                <x:String>7 dias</x:String>
                <x:String>30 dias</x:String>
                <x:String>90 dias</x:String>
                <x:String>6 meses</x:String>
                <x:String>1 ano</x:String>
                <x:String>Todo</x:String>
            </ComboBox>
        </Grid>

        <!-- ── Grid de ventas ───────────────────────────────────────────────── -->
        <Border Grid.Row="2" Margin="20,4,20,0" Background="White" BorderBrush="#E5E5E5" BorderThickness="1">
            <Grid>
                <ListView Style="{StaticResource OutlookDataGridStyle}"
                          ItemsSource="{x:Bind ViewModel.Ventas, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.VentaSeleccionada, Mode=TwoWay}"
                          DoubleTapped="Lista_DoubleTapped">
                    <ListView.Header>
                        <Border Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                            <Grid Padding="{StaticResource ErpHeaderPadding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="#"            Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="2" Text="Fecha"        Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="3" Text="Cliente"      Style="{StaticResource ErpGridHeaderTextStyle}"/>
                                <TextBlock Grid.Column="4" Text="Total"        Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Saldo"        Style="{StaticResource ErpGridHeaderTextStyle}" TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="Estatus"      Style="{StaticResource ErpGridHeaderTextStyle}"/>
                            </Grid>
                        </Border>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="dto:VentaDocumentalResumenDto">
                            <Grid Height="{StaticResource ErpRowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="{x:Bind Id}"            Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind Fecha}"         Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind NombreCliente}" Style="{StaticResource ErpCellPrimaryStyle}"   VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{x:Bind Total}"         Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="{x:Bind SaldoPendiente}" Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center" TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="{x:Bind EstatusTexto}" Style="{StaticResource ErpCellSecondaryStyle}" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="40" Height="40"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Status bar ───────────────────────────────────────────────────── -->
        <Border Grid.Row="3" Style="{StaticResource ErpGridStatusBarStyle}" Margin="20,0,20,0">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource ErpGridStatusTextStyle}">
                    <Run Text="{x:Bind ViewModel.Ventas.Count, Mode=OneWay}"/>
                    <Run Text="venta(s)"/>
                </TextBlock>
                <TextBlock Style="{StaticResource ErpGridErrorTextStyle}"   Text="{x:Bind ViewModel.ErrorMessage,   Mode=OneWay}"/>
                <TextBlock Style="{StaticResource ErpGridSuccessTextStyle}" Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
