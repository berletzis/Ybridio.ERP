<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ═══════════════════════════════════════════════════════════════════════════
    ERP — DataGrid estándar visual (estilo Outlook)
    Prefijo "Erp" en todos los keys para evitar colisiones con WinUI.
    Ningún estilo es implícito (todos llevan x:Key).
    ═══════════════════════════════════════════════════════════════════════════
    -->

    <!-- ── Constantes compartidas ───────────────────────────────────────── -->
    <x:Double  x:Key="ErpRowHeight">52</x:Double>
    <x:Double  x:Key="ErpCellFontSize">13</x:Double>
    <x:Double  x:Key="ErpHeaderFontSize">12</x:Double>
    <Thickness x:Key="ErpRowPadding">16,0</Thickness>
    <Thickness x:Key="ErpHeaderPadding">16,10,16,10</Thickness>

    <!-- ── ListViewItem con indicador de selección izquierdo ────────────── -->
    <!--
        BUG CORREGIDO: WinUI 3 llama GoToState("Selected"), GoToState("PointerOver"),
        GoToState("SelectedPointerOver"), etc. en UN SOLO grupo CommonStates.
        Tener dos grupos separados (CommonStates + SelectionStates) hacía que
        "Selected" nunca se activara. Todos los estados van en UN solo grupo.

        Colores explícitos (no ThemeResources translúcidos) para máxima visibilidad:
          Hover    : #0D000000  (5% negro — gris muy suave sobre blanco)
          Selected : #1A0078D4  (10% azul Fluent — claramente diferente)
          Indicator: 4px, #0078D4 (azul Fluent sólido)
    -->
    <Style x:Key="ErpListViewItemStyle" TargetType="ListViewItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="Padding"                    Value="{StaticResource ErpRowPadding}"/>
        <Setter Property="MinHeight"                  Value="{StaticResource ErpRowHeight}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Grid x:Name="Root" MinHeight="{TemplateBinding MinHeight}">
                        <VisualStateManager.VisualStateGroups>

                            <!--
                                UN SOLO grupo con TODOS los estados.
                                WinUI 3 SelectorItem llama GoToState con nombres combinados
                                (SelectedPointerOver, SelectedPressed) en el mismo grupo.
                            -->
                            <VisualStateGroup x:Name="CommonStates">

                                <VisualState x:Name="Normal"/>

                                <!-- Hover: gris muy ligero (#F8F8F8) — sutil, distinto del fondo -->
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RowBg.Background" Value="#F8F8F8"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- Pressed -->
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RowBg.Background" Value="#F2F2F2"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- Seleccionado: fondo MUY suave (#F5F5F5) — el indicador es el protagonista -->
                                <VisualState x:Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Target="Indicator.Opacity" Value="1"/>
                                        <Setter Target="RowBg.Background" Value="#F5F5F5"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- Seleccionado sin foco -->
                                <VisualState x:Name="SelectedUnfocused">
                                    <VisualState.Setters>
                                        <Setter Target="Indicator.Opacity" Value="0.4"/>
                                        <Setter Target="RowBg.Background" Value="#F8F8F8"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- Seleccionado + hover -->
                                <VisualState x:Name="SelectedPointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Indicator.Opacity" Value="1"/>
                                        <Setter Target="RowBg.Background" Value="#EEEEEE"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- Seleccionado + pressed -->
                                <VisualState x:Name="SelectedPressed">
                                    <VisualState.Setters>
                                        <Setter Target="Indicator.Opacity" Value="1"/>
                                        <Setter Target="RowBg.Background" Value="#E6E6E6"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- Deshabilitado -->
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="ContentArea.Opacity" Value="0.45"/>
                                    </VisualState.Setters>
                                </VisualState>

                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <!-- Fondo de fila (hover / selección) -->
                        <Border x:Name="RowBg"
                                Background="Transparent"
                                CornerRadius="4"
                                Margin="2,1"/>

                        <!-- Contenido de la fila -->
                        <ContentPresenter x:Name="ContentArea"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          ContentTransitions="{TemplateBinding ContentTransitions}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Padding="{TemplateBinding Padding}"/>

                        <!-- Indicador de selección: 3px azul Fluent, overlay izquierdo.
                             Es el cue visual principal al seleccionar una fila. -->
                        <Border x:Name="Indicator"
                                Width="3"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Stretch"
                                Background="#0078D4"
                                CornerRadius="0,2,2,0"
                                Opacity="0"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ListView contenedor ──────────────────────────────────────────── -->
    <!--
        Aplica ErpListViewItemStyle a todas las filas automáticamente.
        Uso: <ListView Style="{StaticResource ErpListViewStyle}" .../>
             <ListView Style="{StaticResource OutlookDataGridStyle}" .../>  (alias)
    -->
    <Style x:Key="ErpListViewStyle" TargetType="ListView">
        <Setter Property="SelectionMode"      Value="Single"/>
        <Setter Property="Background"         Value="Transparent"/>
        <Setter Property="BorderThickness"    Value="0"/>
        <Setter Property="Padding"            Value="0"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource ErpListViewItemStyle}"/>
    </Style>

    <!-- Alias Outlook-style para mayor legibilidad al referenciar -->
    <Style x:Key="OutlookDataGridStyle" TargetType="ListView"
           BasedOn="{StaticResource ErpListViewStyle}"/>

    <!-- ── Encabezado de columnas ───────────────────────────────────────── -->
    <!--
        Uso en ListView.Header → cada TextBlock del header.
        Ejemplo: <TextBlock Text="Nombre" Style="{StaticResource ErpGridHeaderTextStyle}"/>
    -->
    <Style x:Key="ErpGridHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontWeight"        Value="SemiBold"/>
        <Setter Property="FontSize"          Value="{StaticResource ErpHeaderFontSize}"/>
        <Setter Property="Foreground"        Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
    </Style>

    <!-- ── Estilos de celda ─────────────────────────────────────────────── -->

    <!-- Texto principal: nombre del registro — SemiBold para jerarquía visual clara -->
    <Style x:Key="ErpCellPrimaryStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="{StaticResource ErpCellFontSize}"/>
        <Setter Property="FontWeight"        Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
    </Style>

    <!-- Texto secundario: metadata ligera — 1px menor que primario, gris medio -->
    <Style x:Key="ErpCellSecondaryStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="Foreground"        Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
    </Style>

    <!-- Valor numérico: precios, cantidades — alineado a la derecha -->
    <Style x:Key="ErpCellNumericStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="{StaticResource ErpCellFontSize}"/>
        <Setter Property="TextAlignment"     Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ── Botón de acciones "···" (columna derecha) ────────────────────── -->
    <Style x:Key="ErpActionButtonStyle" TargetType="Button">
        <Setter Property="Content"             Value="···"/>
        <Setter Property="Width"               Value="32"/>
        <Setter Property="Height"              Value="32"/>
        <Setter Property="Padding"             Value="0"/>
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="CornerRadius"        Value="4"/>
        <Setter Property="FontSize"            Value="18"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <!-- ── Estado vacío ─────────────────────────────────────────────────── -->
    <!--
        Uso:
            <ContentControl Visibility="{x:Bind ViewModel.IsEmptyState, Mode=OneWay}"
                            ContentTemplate="{StaticResource ErpGridEmptyTemplate}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
    -->
    <DataTemplate x:Key="ErpGridEmptyTemplate">
        <StackPanel Spacing="8" Padding="32"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <FontIcon Glyph="&#xEA3A;" FontSize="40"
                      Foreground="{ThemeResource TextFillColorDisabledBrush}"
                      HorizontalAlignment="Center"/>
            <TextBlock Text="No hay registros"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Ajusta los filtros o agrega un nuevo registro."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </DataTemplate>

    <!-- ── Estado de carga ──────────────────────────────────────────────── -->
    <DataTemplate x:Key="ErpGridLoadingTemplate">
        <StackPanel Spacing="16" Padding="32"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <ProgressRing IsActive="True" Width="40" Height="40" HorizontalAlignment="Center"/>
            <TextBlock Text="Cargando..."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </DataTemplate>

    <!-- ── Estado de error ──────────────────────────────────────────────── -->
    <!--
        Uso:
            <ContentControl Content="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                            ContentTemplate="{StaticResource ErpGridErrorTemplate}"/>
    -->
    <DataTemplate x:Key="ErpGridErrorTemplate">
        <StackPanel Spacing="8" Padding="32"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <FontIcon Glyph="&#xEA39;" FontSize="40"
                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                      HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" MaxWidth="300"
                       TextAlignment="Center"/>
        </StackPanel>
    </DataTemplate>

    <!-- ── Cell DataTemplates reutilizables ────────────────────────────── -->
    <!--
        Uso con ContentControl para células genéricas:
            <ContentControl Grid.Column="2"
                            Content="{x:Bind Nombre}"
                            ContentTemplate="{StaticResource TextPrimaryTemplate}"
                            VerticalAlignment="Center"/>

        El {Binding} dentro del DataTemplate se liga al Content del ContentControl.
    -->

    <!-- Texto principal SemiBold con ellipsis -->
    <DataTemplate x:Key="TextPrimaryTemplate">
        <TextBlock Text="{Binding}"
                   Style="{StaticResource ErpCellPrimaryStyle}"/>
    </DataTemplate>

    <!-- Texto secundario gris con ellipsis -->
    <DataTemplate x:Key="TextSecondaryTemplate">
        <TextBlock Text="{Binding}"
                   Style="{StaticResource ErpCellSecondaryStyle}"/>
    </DataTemplate>

    <!-- Valor numérico alineado a la derecha -->
    <DataTemplate x:Key="NumericTemplate">
        <TextBlock Text="{Binding}"
                   Style="{StaticResource ErpCellNumericStyle}"/>
    </DataTemplate>

    <!--
        LeftIndicatorColumnTemplate — columna de 8px para la zona del indicador.
        El indicador real (3px azul en selección) vive en ErpListViewItemStyle ControlTemplate.
        Usar como primera columna de Width="8" en el header y DataTemplate
        para mantener alineación cuando el indicador se muestra.
    -->
    <DataTemplate x:Key="LeftIndicatorColumnTemplate">
        <Border Width="8" Background="Transparent"/>
    </DataTemplate>

    <!-- ── StatusBar inferior ───────────────────────────────────────────── -->
    <Style x:Key="ErpGridStatusBarStyle" TargetType="Border">
        <Setter Property="Background"      Value="{ThemeResource LayerFillColorDefaultBrush}"/>
        <Setter Property="Padding"         Value="12,4"/>
        <Setter Property="BorderBrush"     Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <Style x:Key="ErpGridStatusTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="Foreground"        Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ErpGridSuccessTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="Foreground"        Value="{ThemeResource AccentFillColorDefaultBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ErpGridErrorTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="Foreground"        Value="{ThemeResource SystemFillColorCriticalBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>
