<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ═══════════════════════════════════════════════════════════════════════════
    ERP — Formularios CRUD estándar
    Aplicar en ventanas de detalle (Productos, Clientes, Ventas…).
    Estructura esperada: Header / ScrollViewer(StackPanel) / Footer
    ═══════════════════════════════════════════════════════════════════════════
    -->

    <!-- ── Constantes ───────────────────────────────────────────────────── -->
    <x:Double  x:Key="ErpFormFieldSpacing">14</x:Double>
    <x:Double  x:Key="ErpFormColumnSpacing">12</x:Double>
    <Thickness x:Key="ErpFormContentPadding">20,0,20,8</Thickness>
    <Thickness x:Key="ErpFormHeaderPadding">20,16,20,12</Thickness>
    <Thickness x:Key="ErpFormFooterPadding">20,8,20,16</Thickness>

    <!--
        Ancho estándar de campos de fecha en documentos comerciales ERP (ADR-043 compacto).
        185px: suficiente para mostrar mes + día + año sin recorte en cualquier locale,
        con apariencia más compacta e institucional que 220px.
        Usar en TODOS los DatePicker de documentos comerciales (Cotización, Pedido, Venta…).
    -->
    <x:Double x:Key="ErpDateFieldWidth">185</x:Double>

    <!-- ── Header ───────────────────────────────────────────────────────── -->

    <!--
        Título principal: "Nuevo Producto" / "Editar Producto"
        Uso: <TextBlock Text="Nuevo Producto" Style="{StaticResource ErpFormTitleStyle}"/>
    -->
    <Style x:Key="ErpFormTitleStyle" TargetType="TextBlock"
           BasedOn="{StaticResource SubtitleTextBlockStyle}">
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <!-- Subtítulo / ID del registro -->
    <Style x:Key="ErpFormSubtitleStyle" TargetType="TextBlock"
           BasedOn="{StaticResource CaptionTextBlockStyle}">
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
    </Style>

    <!-- Línea divisoria bajo el header -->
    <Style x:Key="ErpFormHeaderDividerStyle" TargetType="Rectangle">
        <Setter Property="Height"  Value="1"/>
        <Setter Property="Fill"    Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
        <Setter Property="Margin"  Value="0,8,0,0"/>
    </Style>

    <!-- ── Secciones internas ───────────────────────────────────────────── -->

    <!--
        Encabezado de sección: "Identificación", "Precios", "Inventario"…
        Uso: <TextBlock Text="Precios" Style="{StaticResource ErpFormSectionHeaderStyle}"/>
    -->
    <Style x:Key="ErpFormSectionHeaderStyle" TargetType="TextBlock"
           BasedOn="{StaticResource BodyStrongTextBlockStyle}">
        <Setter Property="Margin"    Value="0,8,0,6"/>
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
    </Style>

    <!-- Separador entre secciones -->
    <Style x:Key="ErpFormSectionDividerStyle" TargetType="Rectangle">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Fill"   Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>

    <!-- ── Campos estándar ──────────────────────────────────────────────── -->

    <Style x:Key="ErpFormTextBoxStyle" TargetType="TextBox">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="ErpFormComboBoxStyle" TargetType="ComboBox">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="ErpFormNumberBoxStyle" TargetType="NumberBox">
        <Setter Property="HorizontalAlignment"     Value="Stretch"/>
        <Setter Property="SpinButtonPlacementMode" Value="Compact"/>
        <Setter Property="Minimum"                 Value="0"/>
    </Style>

    <!-- ── Validación ───────────────────────────────────────────────────── -->

    <!--
        Mensaje de error debajo de un campo.
        Uso:
            <TextBlock Text="{x:Bind ViewModel.ErrorCodigo, Mode=OneWay}"
                       Style="{StaticResource ErpFormFieldErrorStyle}"/>
    -->
    <Style x:Key="ErpFormFieldErrorStyle" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="12"/>
        <Setter Property="Foreground"   Value="{ThemeResource SystemFillColorCriticalBrush}"/>
        <Setter Property="Margin"       Value="0,2,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ── Contenido scrollable ─────────────────────────────────────────── -->

    <!--
        StackPanel principal del formulario.
        Uso:
            <ScrollViewer Padding="{StaticResource ErpFormContentPadding}">
                <StackPanel Style="{StaticResource ErpFormContentStyle}">
                    …secciones…
                </StackPanel>
            </ScrollViewer>
    -->
    <Style x:Key="ErpFormContentStyle" TargetType="StackPanel">
        <Setter Property="Spacing" Value="{StaticResource ErpFormFieldSpacing}"/>
    </Style>

    <!-- ── Footer ───────────────────────────────────────────────────────── -->

    <!--
        Contenedor de botones (Guardar / Cancelar / Eliminar), alineados a la derecha.
        Uso:
            <StackPanel Style="{StaticResource ErpFormFooterStyle}">
                <Button Content="Cancelar"/>
                <Button Content="Guardar" Style="{StaticResource AccentButtonStyle}"/>
            </StackPanel>
    -->
    <Style x:Key="ErpFormFooterStyle" TargetType="StackPanel">
        <Setter Property="Orientation"         Value="Horizontal"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Spacing"             Value="8"/>
        <Setter Property="Padding"             Value="{StaticResource ErpFormFooterPadding}"/>
    </Style>

    <!-- Línea divisoria sobre el footer -->
    <Style x:Key="ErpFormFooterDividerStyle" TargetType="Rectangle">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Fill"   Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
    </Style>

</ResourceDictionary>
