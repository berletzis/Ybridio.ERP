<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ═══════════════════════════════════════════════════════════════════════════════
    YBRIDIO OPERATIONAL GRID STANDARD  v2
    ═══════════════════════════════════════════════════════════════════════════════

    Estándar institucional reusable para TODOS los grids operacionales del ERP.
    v1: Cotizaciones (piloto)
    v2: Column Density System + Financial Formatting Semantics

    PRINCIPIOS
    ──────────
    · Compacto y denso — ERP enterprise, no app móvil.
    · Naming semántico obligatorio (prefijo "Og" = Operational Grid).
    · Alineación semántica de datos (ver §ALIGNMENT SEMANTICS).
    · Semántica visual de estado (ver §STATUS VISUAL LANGUAGE).
    · Distribución por prioridad operacional (ver §COLUMN DENSITY SYSTEM).
    · Todo valor financiero incluye símbolo monetario (ver §FINANCIAL FORMATTING).
    · SIN márgenes arbitrarios — todo medido desde tokens.
    · SIN estilos inline — Styles/ es la única fuente de verdad visual.
    · SIN anchos mágicos — usar los tokens OgCol* o columnas star.

    ALIGNMENT SEMANTICS (regla institucional)
    ─────────────────────────────────────────
    · Textos descriptivos (Cliente, Producto, Descripción) → Left
    · Monedas / Importes (Total, Precio, Costo)            → Right  + SemiBold
    · Cantidades operacionales (Cantidad, Existencia)      → Right
    · Estados (Activo, Cancelado, Borrador)                → Center (badge)
    · IDs / correlativos técnicos                          → Center o compacto Left

    COLUMN DENSITY SYSTEM (v2 — regla institucional)
    ─────────────────────────────────────────────────
    · PRIMARY EXPANDABLE — columna principal que ocupa el espacio sobrante útil.
      Usar Width="*" o Width="2*". Ejemplos: Cliente, Producto, Descripción.
    · COMPACT SEMANTIC — ancho fijo semántico mínimo. NO expandir innecesariamente.
      Usar token OgColCompact (90) o OgColDate (100). Ejemplos: Folio, Fecha, Estado.
    · FINANCIAL COMPACT — ancho fijo financiero institucional, alineación derecha.
      Usar token OgColFinancial (130). Ejemplos: Total, Precio, Costo, LimiteCredito.
    · PROHIBIDO: Width="150", Width="200" u otros anchos arbitrarios.
      La distribución surge del sistema operacional, no de la intuición del momento.

    FINANCIAL FORMATTING STANDARD (v2 — regla institucional)
    ─────────────────────────────────────────────────────────
    · Todo valor financiero visible DEBE incluir símbolo monetario ($3,337.00).
    · Alineación obligatoria: derecha.
    · Usar DecimalToCurrencyConverter en binding — no formatear en ViewModel.
    · Estilo: OgCellFinancialStyle (SemiBold, Right, 13px).
    · PROHIBIDO: mostrar "3337.00" sin contexto monetario.

    STATUS VISUAL LANGUAGE (regla institucional)
    ────────────────────────────────────────────
    · Borrador   → gris neutro            (#8A8A8A text / #F0F0F0 bg)
    · Pendiente  → ámbar institucional    (#C47F00 text / #FFF4CC bg)
    · Aprobado   → azul institucional     (#0078D4 text / #EBF3FB bg)
    · Cancelado  → gris tenue             (#A0A0A0 text / #F8F8F8 bg)
    · NO usar verde/rojo saturado estilo dashboard gaming.

    MÓDULOS QUE DEBEN ADOPTAR ESTE ESTÁNDAR
    ────────────────────────────────────────
    Cotizaciones ✓ (v2), Clientes ✓ (v2), Productos, Pedidos, Ventas,
    Inventario, CxC, CxP, Auditoría.

    Ver: docs/CLAUDE_RULES.md §Operational Grid Standard
         docs/DECISIONS.md    ADR-032 Ybridio Operational Grid Standard
                              ADR-035 Column Density System + Financial Formatting
    ═══════════════════════════════════════════════════════════════════════════════
    -->

    <!-- ══════════════════════════════════════════════════════════════════════
         § TOKENS — constantes de espaciado, tipografía y dimensiones
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- Dimensiones de fila y encabezado -->
    <x:Double  x:Key="OgRowHeight">48</x:Double>
    <x:Double  x:Key="OgHeaderHeight">36</x:Double>

    <!-- Tipografía -->
    <x:Double  x:Key="OgCellFontSize">13</x:Double>
    <x:Double  x:Key="OgHeaderFontSize">12</x:Double>
    <x:Double  x:Key="OgFinancialFontSize">13</x:Double>

    <!-- Espaciado interno -->
    <Thickness x:Key="OgCellPadding">16,0</Thickness>
    <Thickness x:Key="OgHeaderPadding">16,0,16,0</Thickness>

    <!-- ── Column Density System — anchos institucionales (v2) ──────────
         PRIMARY EXPANDABLE  → Width="*" o Width="2*" (inline — star no se puede
                               expresar como GridLength resource en WinUI 3)
         COMPACT SEMANTIC    → OgColCompact / OgColDate / OgColStatus (GridLength fijo)
         FINANCIAL COMPACT   → OgColFinancial (GridLength fijo, alineación derecha)
         PROHIBITED: anchos mágicos arbitrarios (150, 200…).
         NOTA: los tokens deben ser GridLength, NO x:Double — ColumnDefinition.Width
               no acepta Double como StaticResource en WinUI 3.
    -->
    <GridLength x:Key="OgColGutter">8</GridLength>
    <GridLength x:Key="OgColCompact">90</GridLength>
    <GridLength x:Key="OgColDate">100</GridLength>
    <GridLength x:Key="OgColStatus">110</GridLength>
    <GridLength x:Key="OgColFinancial">130</GridLength>

    <!-- Colores semánticos de estado — NO usar directamente en código, solo aquí -->
    <SolidColorBrush x:Key="OgStatusDraftTextBrush"      Color="#8A8A8A"/>
    <SolidColorBrush x:Key="OgStatusDraftBgBrush"        Color="#F0F0F0"/>
    <SolidColorBrush x:Key="OgStatusPendingTextBrush"    Color="#C47F00"/>
    <SolidColorBrush x:Key="OgStatusPendingBgBrush"      Color="#FFF4CC"/>
    <SolidColorBrush x:Key="OgStatusApprovedTextBrush"   Color="#0078D4"/>
    <SolidColorBrush x:Key="OgStatusApprovedBgBrush"     Color="#EBF3FB"/>
    <SolidColorBrush x:Key="OgStatusCancelledTextBrush"  Color="#A0A0A0"/>
    <SolidColorBrush x:Key="OgStatusCancelledBgBrush"    Color="#F8F8F8"/>

    <!-- Colores de fila -->
    <SolidColorBrush x:Key="OgRowHoverBrush"             Color="#F8F8F8"/>
    <SolidColorBrush x:Key="OgRowPressedBrush"           Color="#F2F2F2"/>
    <SolidColorBrush x:Key="OgRowSelectedBrush"          Color="#F5F5F5"/>
    <SolidColorBrush x:Key="OgRowSelectedHoverBrush"     Color="#EEEEEE"/>
    <SolidColorBrush x:Key="OgRowSelectedPressedBrush"   Color="#E6E6E6"/>
    <SolidColorBrush x:Key="OgSelectionIndicatorBrush"   Color="#0078D4"/>


    <!-- ══════════════════════════════════════════════════════════════════════
         § ROW — ListViewItem con indicador de selección izquierdo
         ══════════════════════════════════════════════════════════════════════ -->
    <!--
        OgRowStyle — fila operacional estándar Ybridio.
        · Indicador de selección: 3px azul Fluent, overlay izquierdo.
        · Hover/Selected/Pressed con colores institucionales explícitos.
        · Un solo VisualStateGroup (requerimiento WinUI 3).
        · Padding horizontal = OgCellPadding.
    -->
    <Style x:Key="OgRowStyle" TargetType="ListViewItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="Padding"                    Value="{StaticResource OgCellPadding}"/>
        <Setter Property="MinHeight"                  Value="{StaticResource OgRowHeight}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Grid x:Name="Root" MinHeight="{TemplateBinding MinHeight}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RowBg.Background" Value="{StaticResource OgRowHoverBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RowBg.Background" Value="{StaticResource OgRowPressedBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Target="Indicator.Opacity" Value="1"/>
                                        <Setter Target="RowBg.Background"  Value="{StaticResource OgRowSelectedBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="SelectedUnfocused">
                                    <VisualState.Setters>
                                        <Setter Target="Indicator.Opacity" Value="0.4"/>
                                        <Setter Target="RowBg.Background"  Value="{StaticResource OgRowHoverBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="SelectedPointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Indicator.Opacity" Value="1"/>
                                        <Setter Target="RowBg.Background"  Value="{StaticResource OgRowSelectedHoverBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="SelectedPressed">
                                    <VisualState.Setters>
                                        <Setter Target="Indicator.Opacity" Value="1"/>
                                        <Setter Target="RowBg.Background"  Value="{StaticResource OgRowSelectedPressedBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="ContentArea.Opacity" Value="0.45"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <Border x:Name="RowBg"
                                Background="Transparent"
                                CornerRadius="4"
                                Margin="2,1"/>

                        <ContentPresenter x:Name="ContentArea"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          ContentTransitions="{TemplateBinding ContentTransitions}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Padding="{TemplateBinding Padding}"/>

                        <!-- Indicador de selección: 3px azul Fluent, cue visual principal -->
                        <Border x:Name="Indicator"
                                Width="3"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Stretch"
                                Background="{StaticResource OgSelectionIndicatorBrush}"
                                CornerRadius="0,2,2,0"
                                Opacity="0"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ══════════════════════════════════════════════════════════════════════
         § GRID CONTAINER — ListView operacional estándar
         ══════════════════════════════════════════════════════════════════════ -->
    <!--
        OgListViewStyle — aplica OgRowStyle automáticamente a todas las filas.
        Uso: <ListView Style="{StaticResource OgListViewStyle}" .../>
    -->
    <Style x:Key="OgListViewStyle" TargetType="ListView">
        <Setter Property="SelectionMode"      Value="Single"/>
        <Setter Property="Background"         Value="Transparent"/>
        <Setter Property="BorderThickness"    Value="0"/>
        <Setter Property="Padding"            Value="0"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource OgRowStyle}"/>
    </Style>


    <!-- ══════════════════════════════════════════════════════════════════════
         § HEADER — encabezado de columnas
         ══════════════════════════════════════════════════════════════════════ -->
    <!--
        OgHeaderTextStyle — texto de encabezado de columna.
        · SemiBold, 12px, gris secundario institucional.
        · Uso: <TextBlock Style="{StaticResource OgHeaderTextStyle}" Text="Cliente"/>
    -->
    <Style x:Key="OgHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="{StaticResource OgHeaderFontSize}"/>
        <Setter Property="FontWeight"        Value="SemiBold"/>
        <Setter Property="Foreground"        Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
        <Setter Property="TextAlignment"     Value="Left"/>
    </Style>

    <!--
        OgHeaderNumericTextStyle — encabezado para columnas numéricas/financieras.
        · Igual que OgHeaderTextStyle pero alineado a la derecha.
    -->
    <Style x:Key="OgHeaderNumericTextStyle" TargetType="TextBlock"
           BasedOn="{StaticResource OgHeaderTextStyle}">
        <Setter Property="TextAlignment" Value="Right"/>
    </Style>

    <!--
        OgHeaderCenteredTextStyle — encabezado para columnas centradas (Estado, ID).
    -->
    <Style x:Key="OgHeaderCenteredTextStyle" TargetType="TextBlock"
           BasedOn="{StaticResource OgHeaderTextStyle}">
        <Setter Property="TextAlignment"     Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>


    <!-- ══════════════════════════════════════════════════════════════════════
         § CELL TYPOGRAPHY — jerarquía tipográfica institucional
         ══════════════════════════════════════════════════════════════════════ -->

    <!--
        OgCellPrimaryStyle — texto principal de fila (nombre, descripción, cliente).
        · ALIGNMENT: Left (textos descriptivos → izquierda).
        · FontWeight Medium para jerarquía visual clara vs metadata.
    -->
    <Style x:Key="OgCellPrimaryStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="{StaticResource OgCellFontSize}"/>
        <Setter Property="FontWeight"        Value="Medium"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
        <Setter Property="TextAlignment"     Value="Left"/>
    </Style>

    <!--
        OgCellSecondaryStyle — metadata secundaria (fecha, referencia, RFC, folio).
        · ALIGNMENT: Left.
        · Gris secundario institucional, peso normal.
    -->
    <Style x:Key="OgCellSecondaryStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="{StaticResource OgCellFontSize}"/>
        <Setter Property="FontWeight"        Value="Normal"/>
        <Setter Property="Foreground"        Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
        <Setter Property="TextAlignment"     Value="Left"/>
    </Style>

    <!--
        OgCellFinancialStyle — valores monetarios (Total, Precio, Costo, Subtotal).
        · ALIGNMENT: Right (monedas → derecha, regla institucional).
        · SemiBold para facilitar escaneo financiero.
        · Ligeramente destacado vs metadata.
    -->
    <Style x:Key="OgCellFinancialStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="{StaticResource OgFinancialFontSize}"/>
        <Setter Property="FontWeight"        Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
        <Setter Property="TextAlignment"     Value="Right"/>
    </Style>

    <!--
        OgCurrencyTextStyle — alias semántico de OgCellFinancialStyle.
        Usar cuando la semántica de "moneda formateada con símbolo" deba ser
        explícita en el XAML para facilitar lectura y búsqueda.
        Siempre combinar con DecimalToCurrencyConverter en el binding.
    -->
    <Style x:Key="OgCurrencyTextStyle" TargetType="TextBlock"
           BasedOn="{StaticResource OgCellFinancialStyle}"/>

    <!--
        OgCellQuantityStyle — cantidades operacionales (Cantidad, Existencia, Stock).
        · ALIGNMENT: Right (cantidades → derecha, regla institucional).
        · Normal weight — distinto de financiero.
    -->
    <Style x:Key="OgCellQuantityStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="{StaticResource OgCellFontSize}"/>
        <Setter Property="FontWeight"        Value="Normal"/>
        <Setter Property="Foreground"        Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
        <Setter Property="TextAlignment"     Value="Right"/>
    </Style>

    <!--
        OgCellIdStyle — IDs, folios, correlativos técnicos.
        · ALIGNMENT: Left compacto (lectura rápida en columnas estrechas).
        · Gris secundario — no es el dato principal de la fila.
    -->
    <Style x:Key="OgCellIdStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="FontWeight"        Value="Normal"/>
        <Setter Property="Foreground"        Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
        <Setter Property="TextAlignment"     Value="Left"/>
    </Style>


    <!-- ══════════════════════════════════════════════════════════════════════
         § STATUS BADGES — semántica visual de estado institucional
         ══════════════════════════════════════════════════════════════════════ -->
    <!--
        Uso:
            <Border Style="{StaticResource OgStatusBadgeDraftStyle}">
                <TextBlock Text="Borrador" Style="{StaticResource OgStatusBadgeTextStyle}"/>
            </Border>

        REGLA: NO usar colores saturados gaming.
               Paleta institucional sobria definida en §TOKENS.
    -->

    <!-- Texto interior del badge — común a todos los estados -->
    <Style x:Key="OgStatusBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="11"/>
        <Setter Property="FontWeight"        Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <!-- Borrador: gris neutro -->
    <Style x:Key="OgStatusBadgeDraftStyle" TargetType="Border">
        <Setter Property="Background"    Value="{StaticResource OgStatusDraftBgBrush}"/>
        <Setter Property="CornerRadius"  Value="4"/>
        <Setter Property="Padding"       Value="8,2"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- Pendiente: ámbar institucional -->
    <Style x:Key="OgStatusBadgePendingStyle" TargetType="Border">
        <Setter Property="Background"    Value="{StaticResource OgStatusPendingBgBrush}"/>
        <Setter Property="CornerRadius"  Value="4"/>
        <Setter Property="Padding"       Value="8,2"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- Aprobado / Activo: azul institucional sobrio -->
    <Style x:Key="OgStatusBadgeApprovedStyle" TargetType="Border">
        <Setter Property="Background"    Value="{StaticResource OgStatusApprovedBgBrush}"/>
        <Setter Property="CornerRadius"  Value="4"/>
        <Setter Property="Padding"       Value="8,2"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- Cancelado: gris tenue, menor prominencia visual -->
    <Style x:Key="OgStatusBadgeCancelledStyle" TargetType="Border">
        <Setter Property="Background"    Value="{StaticResource OgStatusCancelledBgBrush}"/>
        <Setter Property="CornerRadius"  Value="4"/>
        <Setter Property="Padding"       Value="8,2"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>


    <!-- ══════════════════════════════════════════════════════════════════════
         § STATUS BAR — región operacional inferior del grid
         ══════════════════════════════════════════════════════════════════════ -->
    <!--
        OgStatusBarStyle — borde inferior del grid con info operacional.
        Debe incluir: cantidad registros, página actual / total páginas,
        resumen operacional opcional.

        Uso:
            <Border Style="{StaticResource OgStatusBarStyle}">
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Style="{StaticResource OgStatusCountStyle}" Text="57 registros"/>
                    <TextBlock Style="{StaticResource OgStatusPaginationStyle}" Text="Página 1 de 6"/>
                </StackPanel>
            </Border>
    -->
    <Style x:Key="OgStatusBarStyle" TargetType="Border">
        <Setter Property="Background"      Value="{ThemeResource LayerFillColorDefaultBrush}"/>
        <Setter Property="Padding"         Value="16,6"/>
        <Setter Property="BorderBrush"     Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <!-- Conteo de registros — dato primario del status bar -->
    <Style x:Key="OgStatusCountStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="FontWeight"        Value="SemiBold"/>
        <Setter Property="Foreground"        Value="{ThemeResource TextFillColorPrimaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Paginación — dato secundario del status bar -->
    <Style x:Key="OgStatusPaginationStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="FontWeight"        Value="Normal"/>
        <Setter Property="Foreground"        Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Resumen financiero opcional (ej: "Total: $125,000") -->
    <Style x:Key="OgStatusSummaryStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="FontWeight"        Value="SemiBold"/>
        <Setter Property="Foreground"        Value="{ThemeResource AccentFillColorDefaultBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Mensaje de error en status bar -->
    <Style x:Key="OgStatusErrorStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="Foreground"        Value="{ThemeResource SystemFillColorCriticalBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Mensaje de éxito en status bar -->
    <Style x:Key="OgStatusSuccessStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="Foreground"        Value="{ThemeResource AccentFillColorDefaultBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>


    <!-- ══════════════════════════════════════════════════════════════════════
         § PAGINATION CONTROL — controles de navegación de páginas
         ══════════════════════════════════════════════════════════════════════ -->
    <!--
        OgPagButtonStyle — botón de paginación (◀ ▶ o numérico).
        · Compacto, transparente, integrado visualmente al status bar.
        · Se activa/desactiva según IsEnabled del ViewModel.
    -->
    <Style x:Key="OgPagButtonStyle" TargetType="Button">
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Padding"             Value="8,4"/>
        <Setter Property="CornerRadius"        Value="4"/>
        <Setter Property="FontSize"            Value="12"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Setter Property="MinWidth"            Value="32"/>
    </Style>


    <!-- ══════════════════════════════════════════════════════════════════════
         § EMPTY / LOADING / ERROR STATES
         ══════════════════════════════════════════════════════════════════════ -->
    <!--
        Estados vacíos, carga y error del grid operacional.
        Uso con ContentControl + Visibility binding desde ViewModel.

        Ejemplo:
            <ContentControl
                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                ContentTemplate="{StaticResource OgEmptyStateTemplate}"
                HorizontalAlignment="Center" VerticalAlignment="Center"/>
    -->

    <DataTemplate x:Key="OgEmptyStateTemplate">
        <StackPanel Spacing="10" Padding="40"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <FontIcon Glyph="&#xEA3A;" FontSize="36"
                      Foreground="{ThemeResource TextFillColorDisabledBrush}"
                      HorizontalAlignment="Center"/>
            <TextBlock Text="Sin registros"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Ajusta los filtros o crea un nuevo registro."
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="OgLoadingStateTemplate">
        <StackPanel Spacing="14" Padding="40"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <ProgressRing IsActive="True" Width="36" Height="36"
                          HorizontalAlignment="Center"/>
            <TextBlock Text="Cargando..."
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="OgErrorStateTemplate">
        <StackPanel Spacing="10" Padding="40"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <FontIcon Glyph="&#xEA39;" FontSize="36"
                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                      HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding}"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" MaxWidth="320"
                       TextAlignment="Center"/>
        </StackPanel>
    </DataTemplate>


    <!-- ══════════════════════════════════════════════════════════════════════
         § HEADER CONTAINER — contenedor estándar del encabezado de columnas
         ══════════════════════════════════════════════════════════════════════ -->
    <!--
        OgHeaderContainerStyle — Border que envuelve la fila de encabezados.
        Uso: <Border Style="{StaticResource OgHeaderContainerStyle}">
                 <Grid Padding="{StaticResource OgHeaderPadding}"> ... </Grid>
             </Border>
    -->
    <Style x:Key="OgHeaderContainerStyle" TargetType="Border">
        <Setter Property="Background"      Value="#FAFAFA"/>
        <Setter Property="BorderBrush"     Value="#E8E8E8"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="MinHeight"       Value="{StaticResource OgHeaderHeight}"/>
    </Style>

    <!--
        OgGridContainerStyle — Border exterior que envuelve ListView + header.
        Alineación perfecta con CommandBars y Document Surfaces.
    -->
