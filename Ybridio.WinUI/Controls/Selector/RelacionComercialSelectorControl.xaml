<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Ybridio.WinUI.Controls.Selector.RelacionComercialSelectorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dir="using:Ybridio.Application.DTOs.Directorio">

    <!--
        RelacionComercialSelectorControl — ADR-038
        Dos estados visuales mutuamente excluyentes:

        ESTADO A — SIN selección:
          InputBorder visible  →  TextBox de búsqueda activo
          EntityChipPanel colapsado

        ESTADO B — CON selección:
          InputBorder colapsado  →  TextBox completamente oculto
          EntityChipPanel visible  →  chip compacto debajo (nombre + badge + limpiar)

        REGLA: La entidad seleccionada NUNCA se renderiza dentro del InputBorder/TextBox.
               El InputBorder es EXCLUSIVAMENTE el campo de búsqueda.
               El chip compacto (EntityChipPanel) es la representación oficial seleccionada.
    -->

    <Grid>
        <Grid.RowDefinitions>
            <!-- Row 0: InputBorder — campo de búsqueda (solo activo sin selección) -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: EntityChipPanel — chip compacto del seleccionado (solo activo con selección) -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── ESTADO A: Campo de búsqueda ──────────────────────────────────── -->
        <Border Grid.Row="0"
                x:Name="InputBorder"
                Style="{StaticResource OgEntitySelectorStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" x:Name="SearchPanel">
                    <FontIcon Glyph="&#xE721;"
                              FontSize="13"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              x:Name="SearchIcon"
                              IsHitTestVisible="False"/>

                    <TextBox x:Name="TxtBusqueda"
                             Style="{StaticResource OgEntitySelectorInputStyle}"
                             PlaceholderText="{x:Bind PlaceholderText, Mode=OneWay}"
                             Padding="28,4,8,4"
                             TextChanged="TxtBusqueda_TextChanged"
                             KeyDown="TxtBusqueda_KeyDown"
                             GotFocus="TxtBusqueda_GotFocus"
                             LostFocus="TxtBusqueda_LostFocus"
                             IsEnabled="{x:Bind IsEnabled, Mode=OneWay}"
                             AutomationProperties.Name="Buscar socio comercial"/>
                </Grid>

                <ProgressRing Grid.Column="1"
                              x:Name="LoadingRing"
                              Width="16" Height="16"
                              Margin="0,0,6,0"
                              IsActive="False"
                              VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── ESTADO B: Chip compacto del seleccionado ─────────────────────── -->
        <!--
            Visible SOLO cuando hay selección activa.
            Muestra glyph + nombre + badge + botón limpiar.
            El email y teléfono se muestran en el bloque de metadatos de la página (no aquí).
            NO duplicar email/teléfono dentro del selector.
        -->
        <Border Grid.Row="1"
                x:Name="EntityChipPanel"
                Visibility="Collapsed"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,7"
                Margin="0,4,0,0">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Glyph -->
                    <ColumnDefinition Width="*"/>     <!-- Nombre -->
                    <ColumnDefinition Width="Auto"/>  <!-- Badge -->
                    <ColumnDefinition Width="Auto"/>  <!-- Limpiar -->
                </Grid.ColumnDefinitions>

                <!-- Ícono semántico por tipo de entidad -->
                <FontIcon Grid.Column="0"
                          x:Name="ChipGlyph"
                          FontSize="14"
                          VerticalAlignment="Center"
                          Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                <!-- Nombre de la entidad seleccionada -->
                <TextBlock Grid.Column="1"
                           x:Name="ChipNombre"
                           FontWeight="SemiBold"
                           FontSize="13"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Badge tipo: Empresa / Persona Física -->
                <Border Grid.Column="2"
                        x:Name="ChipBadge"
                        CornerRadius="3"
                        Padding="5,1,5,1"
                        VerticalAlignment="Center"
                        BorderThickness="1">
                    <TextBlock x:Name="ChipBadgeText" FontSize="10"/>
                </Border>

                <!-- Botón limpiar selección -->
                <Button Grid.Column="3"
                        x:Name="BtnLimpiar"
                        Click="BtnLimpiar_Click"
                        IsEnabled="{x:Bind IsEnabled, Mode=OneWay}"
                        Width="26" Height="26" Padding="0"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="Limpiar selección">
                    <FontIcon Glyph="&#xE711;" FontSize="11"/>
                </Button>
            </Grid>
        </Border>

        <!-- ── Popup de resultados de búsqueda ───────────────────────────────── -->
        <Popup x:Name="ResultsPopup"
               IsOpen="False"
               IsLightDismissEnabled="False">
            <Border Style="{StaticResource OgEntitySelectorPopupStyle}"
                    x:Name="PopupBorder">
                <Grid>
                    <TextBlock x:Name="TxtCargando"
                               Style="{StaticResource OgEntitySelectorStatusTextStyle}"
                               Text="Buscando..."
                               Visibility="Collapsed"/>

                    <TextBlock x:Name="TxtSinResultados"
                               Style="{StaticResource OgEntitySelectorStatusTextStyle}"
                               Text="Sin resultados"
                               Visibility="Collapsed"/>

                    <ListView x:Name="LvResultados"
                              SelectionMode="Single"
                              ItemContainerStyle="{StaticResource OgEntitySelectorItemStyle}"
                              ItemsSource="{x:Bind _resultados}"
                              SelectionChanged="LvResultados_SelectionChanged"
                              KeyDown="LvResultados_KeyDown">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="dir:DirectorioSelectorDto">
                                <Grid ColumnSpacing="8" Padding="0,3,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <FontIcon Grid.Column="0"
                                              FontSize="16"
                                              VerticalAlignment="Center"
                                              Glyph="{x:Bind Glyph}"/>

                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="{x:Bind DisplayName}"
                                                   Style="{StaticResource OgEntityItemPrimaryTextStyle}"/>
                                        <TextBlock Text="{x:Bind InfoSecundaria}"
                                                   Style="{StaticResource OgEntityItemSecondaryTextStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
