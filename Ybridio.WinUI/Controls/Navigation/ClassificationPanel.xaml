<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Ybridio.WinUI.Controls.Navigation.ClassificationPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:nav="using:Ybridio.WinUI.Controls.Navigation"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--
            Override del color de selección de TreeViewItem.
            Los ThemeResources del árbol visual se buscan de local→global,
            por lo que estos valores tapan el azul de acento predeterminado
            dentro del UserControl.
        -->
        <SolidColorBrush x:Key="TreeViewItemBackgroundSelected"             Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TreeViewItemBackgroundSelectedPointerOver"  Color="#D5D5D5"/>
        <SolidColorBrush x:Key="TreeViewItemBackgroundSelectedPressed"      Color="#CCCCCC"/>
        <SolidColorBrush x:Key="TreeViewItemBackgroundPointerOver"          Color="#EBEBEB"/>
        <SolidColorBrush x:Key="TreeViewItemBackgroundPressed"              Color="#E0E0E0"/>
        <!-- Mantener el texto con el color del tema (no blanco sobre gris claro) -->
        <SolidColorBrush x:Key="TreeViewItemForegroundSelected"             Color="#1A1A1A"/>
        <SolidColorBrush x:Key="TreeViewItemForegroundSelectedPointerOver"  Color="#1A1A1A"/>

        <!-- Estilo de item del TreeView: Outlook 2026 -->
        <Style x:Key="OutlookTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="Margin"                     Value="4,1"/>
            <Setter Property="MinHeight"                  Value="34"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="CornerRadius"               Value="4"/>
        </Style>
    </UserControl.Resources>

    <!-- Panel principal: fondo gris claro tipo Outlook -->
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- TreeView -->
        </Grid.RowDefinitions>

        <!-- ── Header del panel ─────────────────────────────────────────── -->
        <!--
            Siempre visible (no depende de PanelTitle vacío).
            Derecha: ToggleButton compacto — icono tipo filtro sin texto (estilo Outlook).
            IsChecked vinculado TwoWay a IsFilterActive DP → propaga a ViewModel.MostrarSoloCategorias.
        -->
        <Border Grid.Row="0"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="12,6,8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{x:Bind PanelTitle, Mode=OneWay}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#5A5A5A"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Botón toggle: icono compacto, sin texto.
                     Estado activo (checked) → fondo de acento WinUI 3 automático.
                     &#xE71C; = Filter en Segoe MDL2 Assets. -->
                <ToggleButton Grid.Column="1"
                              IsChecked="{x:Bind IsFilterActive, Mode=TwoWay}"
                              Width="28" Height="28"
                              Padding="0"
                              Background="Transparent"
                              BorderThickness="0"
                              CornerRadius="4"
                              VerticalAlignment="Center"
                              ToolTipService.ToolTip="Solo categorías con productos">
                    <FontIcon Glyph="&#xE71C;" FontSize="12"/>
                </ToggleButton>
            </Grid>
        </Border>

        <!-- ── TreeView ──────────────────────────────────────────────────── -->
        <!--
            ItemsSource se asigna desde código en OnItemsSourceChanged.
            El TreeView observa CollectionChanged del ObservableCollection
            directamente: no se necesita suscripción manual.

            DataTemplate con x:DataType="nav:ClassificationItem" y {x:Bind}:
            DataContext = ClassificationItem (fuente directa, no TreeViewNode),
            por eso {x:Bind Name} resuelve correctamente.

            Jerarquía: TreeViewItem.ItemsSource={x:Bind Children} para N niveles.
        -->
        <TreeView x:Name="ClassTree"
                  Grid.Row="1"
                  SelectionMode="Single"
                  SelectionChanged="ClassTree_SelectionChanged"
                  Background="Transparent"
                  Padding="4,4,4,4">

            <TreeView.ItemTemplate>
                <DataTemplate x:DataType="nav:ClassificationItem">
                    <!--
                        La raíz del DataTemplate es TreeViewItem:
                        · ItemsSource=Children → construye el árbol jerárquico
                        · IsExpanded → respeta el estado inicial del nodo
                        · Style → aplica el look Outlook directamente aquí
                        DataContext dentro del DataTemplate = ClassificationItem
                        → {x:Bind Name} y {x:Bind CountDisplay} resuelven correctamente
                    -->
                    <TreeViewItem ItemsSource="{x:Bind Children, Mode=OneWay}"
                                  IsExpanded="{x:Bind IsExpanded}"
                                  Style="{StaticResource OutlookTreeViewItemStyle}">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="5">
                            <TextBlock Text="{x:Bind Name}"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind CountDisplay}"
                                       FontSize="12"
                                       Foreground="#909090"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </TreeViewItem>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
