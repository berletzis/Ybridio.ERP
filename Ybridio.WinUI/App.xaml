<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Ybridio.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ybridio.WinUI">
    <Application.Resources>
        <!--
            App.xaml - Bootstrap visual del ERP (ADR-033)
            Este archivo es SOLO un punto de bootstrap. NO contiene estilos.
            Todos los estilos viven en Styles/ (source of truth visual).
            Styles/Styles.xaml es el dictionary maestro del Design System.
            PROHIBIDO agregar estilos nuevos aqui.
            Ver: Documentation/CLAUDE_RULES.md Design System
                 Documentation/DECISIONS.md (ADR-033)
        -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- WinUI 3 controles base -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
                <!-- ERP Visual Design System - todos los estilos viven en Styles/ -->
                <ResourceDictionary Source="ms-appx:///Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
