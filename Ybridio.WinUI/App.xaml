<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Ybridio.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ybridio.WinUI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Styles/DataGrid/DataGridBase.xaml"/>
                <ResourceDictionary Source="ms-appx:///Styles/Forms/FormBase.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- Other app resources here -->

            <!--
                DocumentSurfaceBackActionButtonStyle — acción de navegación secundaria/lightweight
                dentro de Document Surface headers (ADR-031).

                Contexto de uso:
                  · Botón "← Volver" en el header breadcrumb de un Document Surface.
                  · Acciones de navegación discreta que NO compiten visualmente con el
                    contenido operacional del documento.

                Intención UX:
                  · Fondo transparente para integrarse en LayerFillColorDefaultBrush del header.
                  · Sin borde (BorderThickness=0) para evitar ruido visual en zonas densas.
                  · CornerRadius=4 para hover state coherente con el resto del ERP.
                  · Padding compacto (6px) para alinearse con iconografía FontIcon 14px.

                Regla de no-proliferación:
                  · NO usar para botones primarios (usar AccentButtonStyle).
                  · NO usar fuera de Document Surface headers o zonas UX equivalentes.
                  · NO renombrar a algo genérico como "TransparentButtonStyle" — ese nombre
                    no porta intención UX y provoca proliferación de usos incorrectos.
                  · Si se necesita un botón ghost en otro contexto, crear un estilo semántico
                    nuevo con nombre que refleje su contexto real.

                Ver: docs/CLAUDE_RULES.md §UX Button Styles Standard
                     ADR-031 Document Surface Visual Separation Standard
            -->
            <Style x:Key="DocumentSurfaceBackActionButtonStyle" TargetType="Button">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="6"/>
                <Setter Property="CornerRadius"    Value="4"/>
            </Style>

            <!--
                OutlookTabItemStyle — tabs de navegación interna de módulos (Module Layer)
                Jerarquía visual secundaria: compacto, fondo transparente, padding moderado.
                Usado por páginas de módulos (Ventas, Finanzas, Inventario, Configuración).
                Diferenciación clara vs Workspace Tabs (WorkspaceTabItemStyle).
                Uso implícito: declarar en TabView.Resources sin x:Key con BasedOn.
            -->
            <Style x:Key="OutlookTabItemStyle" TargetType="TabViewItem">
                <Setter Property="Background"       Value="Transparent"/>
                <Setter Property="BorderThickness"  Value="0"/>
                <Setter Property="MinWidth"         Value="0"/>
                <Setter Property="FontSize"         Value="14"/>
                <Setter Property="FontFamily"       Value="{ThemeResource ContentControlThemeFontFamily}"/>
                <Setter Property="Foreground"       Value="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabViewItem">
                            <Grid x:Name="TabContainer"
                                  MinHeight="40"
                                  Background="Transparent">
                                <VisualStateManager.VisualStateGroups>

                                    <!-- Estados comunes de interacción -->
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="HeaderPresenter.Foreground"
                                                        Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                <Setter Target="CloseButton.Opacity" Value="1"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="HeaderPresenter.Foreground"
                                                        Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Selected">
                                            <VisualState.Setters>
                                                <Setter Target="HeaderPresenter.Foreground"
                                                        Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                <Setter Target="HeaderPresenter.FontWeight"
                                                        Value="SemiBold"/>
                                                <Setter Target="SelectionBar.Visibility"
                                                        Value="Visible"/>
                                                <Setter Target="CloseButton.Opacity" Value="1"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="HeaderPresenter.Foreground"
                                                        Value="{ThemeResource TextFillColorDisabledBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>

                                    <!-- Estados de cierre — usados por TabViewItem.OnApplyTemplate -->
                                    <VisualStateGroup x:Name="DataContextStates">
                                        <VisualState x:Name="Closable">
                                            <VisualState.Setters>
                                                <Setter Target="CloseButton.Visibility" Value="Visible"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="NotClosable">
                                            <VisualState.Setters>
                                                <Setter Target="CloseButton.Visibility" Value="Collapsed"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>

                                </VisualStateManager.VisualStateGroups>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="3"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Título del tab -->
                                <ContentPresenter x:Name="HeaderPresenter"
                                                  Grid.Row="0" Grid.Column="0"
                                                  Content="{TemplateBinding Header}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                  FontSize="{TemplateBinding FontSize}"
                                                  FontFamily="{TemplateBinding FontFamily}"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="16,8,4,8"/>

                                <!-- Botón cerrar: nombre "CloseButton" es requerido por TabViewItem.OnApplyTemplate -->
                                <Button x:Name="CloseButton"
                                        Grid.Row="0" Grid.Column="1"
                                        Width="20" Height="20"
                                        Margin="0,0,6,0"
                                        Padding="0"
                                        Opacity="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        VerticalAlignment="Center"
                                        ToolTipService.ToolTip="Cerrar">
                                    <FontIcon Glyph="&#xE711;" FontSize="10"/>
                                </Button>

                                <!-- Indicador de selección (underline azul) -->
                                <Border x:Name="SelectionBar"
                                        Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Background="#0078D4"
                                        CornerRadius="1"
                                        Visibility="Collapsed"
                                        Margin="6,0"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!--
                WorkspaceTabItemStyle — tabs de documentos persistentes (Workspace Layer)
                Jerarquía visual dominante: más altura, padding generoso, fondo sutil, tipografía SemiBold.
                Diferenciación clara vs Module Tabs (OutlookTabItemStyle).
                Uso: aplicar explícitamente al WorkspaceTabView en ShellPage.xaml.
            -->
            <Style x:Key="WorkspaceTabItemStyle" TargetType="TabViewItem">
                <Setter Property="Background"       Value="Transparent"/>
                <Setter Property="BorderThickness"  Value="0"/>
                <Setter Property="MinWidth"         Value="0"/>
                <Setter Property="FontSize"         Value="14"/>
                <Setter Property="FontFamily"       Value="{ThemeResource ContentControlThemeFontFamily}"/>
                <Setter Property="Foreground"       Value="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabViewItem">
                            <Grid x:Name="TabContainer"
                                  MinHeight="48"
                                  Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <VisualStateManager.VisualStateGroups>

                                    <!-- Estados comunes de interacción -->
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="HeaderPresenter.Foreground"
                                                        Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                <Setter Target="TabContainer.Background"
                                                        Value="{ThemeResource SubtleFillColorTertiaryBrush}"/>
                                                <Setter Target="CloseButton.Opacity" Value="1"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="HeaderPresenter.Foreground"
                                                        Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                <Setter Target="TabContainer.Background"
                                                        Value="{ThemeResource SubtleFillColorTertiaryBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Selected">
                                            <VisualState.Setters>
                                                <Setter Target="HeaderPresenter.Foreground"
                                                        Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                <Setter Target="HeaderPresenter.FontWeight"
                                                        Value="SemiBold"/>
                                                <Setter Target="TabContainer.Background"
                                                        Value="{ThemeResource LayerFillColorDefaultBrush}"/>
                                                <Setter Target="SelectionBar.Visibility"
                                                        Value="Visible"/>
                                                <Setter Target="CloseButton.Opacity" Value="1"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="HeaderPresenter.Foreground"
                                                        Value="{ThemeResource TextFillColorDisabledBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>

                                    <!-- Estados de cierre — usados por TabViewItem.OnApplyTemplate -->
                                    <VisualStateGroup x:Name="DataContextStates">
                                        <VisualState x:Name="Closable">
                                            <VisualState.Setters>
                                                <Setter Target="CloseButton.Visibility" Value="Visible"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="NotClosable">
                                            <VisualState.Setters>
                                                <Setter Target="CloseButton.Visibility" Value="Collapsed"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>

                                </VisualStateManager.VisualStateGroups>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="4"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Título del tab (padding superior/inferior mayor para jerarquía visual) -->
                                <ContentPresenter x:Name="HeaderPresenter"
                                                  Grid.Row="0" Grid.Column="0"
                                                  Content="{TemplateBinding Header}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                  FontSize="{TemplateBinding FontSize}"
                                                  FontFamily="{TemplateBinding FontFamily}"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="18,12,6,12"/>

                                <!-- Botón cerrar: nombre "CloseButton" es requerido por TabViewItem.OnApplyTemplate -->
                                <Button x:Name="CloseButton"
                                        Grid.Row="0" Grid.Column="1"
                                        Width="22" Height="22"
                                        Margin="0,0,8,0"
                                        Padding="0"
                                        Opacity="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        VerticalAlignment="Center"
                                        ToolTipService.ToolTip="Cerrar documento">
                                    <FontIcon Glyph="&#xE711;" FontSize="11"/>
                                </Button>

                                <!-- Indicador de selección (underline azul más prominente) -->
                                <Border x:Name="SelectionBar"
                                        Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Background="#0078D4"
                                        CornerRadius="2"
                                        Visibility="Collapsed"
                                        Margin="8,0"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
